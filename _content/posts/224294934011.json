re0CWWtnNbIKSOdYnSGUg.F7P1HEXszIOmKnMf1AmvS9Dy71kVmk6Oex9ZSqNuoCAg.PNG/SE-23b06ab8-71ac-48e5-9573-fe578dadd49b.png\", \"originalWidth\" : \"1004\", \"originalHeight\" : \"1152\", \"linkUse\" : \"false\", \"link\" : \"\", \"fileSize\": \"177364\" }' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfMjA0/MDAxNzc5NTg1MDAxMzQw.juV-GwTgbuqkWRr61-HBjLore0CWWtnNbIKSOdYnSGUg.F7P1HEXszIOmKnMf1AmvS9Dy71kVmk6Oex9ZSqNuoCAg.PNG/SE-23b06ab8-71ac-48e5-9573-fe578dadd49b.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-12464b77-6760-4992-92df-493b06939e9f\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-5fd36cf5-537f-4c24-90d9-0882e853caa5\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-430c7b97-9782-48bb-95db-6be8f5f9a8d5\" style=\"color:#aa1f91;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-b08133d6-b90a-4b42-9379-939328d587ad\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-7e8037e0-d66c-4bc0-bb88-01348347383e\" style=\"color:#aa1f91;\"><b>■ 디자인 컨펌과 확인</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-2423c847-793e-41f7-922f-9db8ba9eff42\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-2423c847-793e-41f7-922f-9db8ba9eff42\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfMjY4/MDAxNzc5NTg1ODI0OTEy.iIV5eaPg8DOgsu16AQbPYm32f1-ye8SF3FFb6FjhkIwg.zKvS25u5WRIPF0MKAP4jjLC4e1d1a10NSl1y4lw7tpog.PNG/SE-2423c847-793e-41f7-922f-9db8ba9eff42.png\", \"originalWidth\" : \"978\", \"originalHeight\" : \"1187\", \"linkUse\" : \"false\", \"link\" : \"\", \"fileSize\": \"151088\" }' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfMjY4/MDAxNzc5NTg1ODI0OTEy.iIV5eaPg8DOgsu16AQbPYm32f1-ye8SF3FFb6FjhkIwg.zKvS25u5WRIPF0MKAP4jjLC4e1d1a10NSl1y4lw7tpog.PNG/SE-2423c847-793e-41f7-922f-9db8ba9eff42.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-cc56720a-91d6-4c52-b0bc-72c51d37159c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-14371f51-8ac4-409f-b2b0-bca463d94135\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-80473651-9479-4801-9e51-1f61bba02645\" style=\"color:#555555;\">정확한 다자인 사양이 확정되면 작업 준비를 합니다. 고객님의 최종 컨펌이 이루어져야 작업이 진행됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-fdbc429d-5cfe-48d6-9a95-1c66d7455c6d\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0ebc7558-1a73-47de-9966-25e13e519253\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-b26f0c56-af35-4b70-8e06-c867b783e7cd\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-b339e093-8bbf-4519-a6ef-4902f7becefb\" style=\"color:#aa1f91;\"><b>■ 작업 진행</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-c58a2ded-d46f-4cee-aecc-9c96ddb12920\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-c58a2ded-d46f-4cee-aecc-9c96ddb12920\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfMjE2/MDAxNzc5NTg1MTc2NTMy.geGiSJwr6zALyPx9gziaTVxIRsfnAr6jG4UtHblOelog.ysqnyDkU-JVVhysx98QCV9u__nLUJ37HQHH92wqQ330g.PNG/SE-c58a2ded-d46f-4cee-aecc-9c96ddb12920.png\", \"originalWidth\" : \"1003\", \"originalHeight\" : \"1186\", \"linkUse\" : \"false\", \"link\" : \"\", \"fileSize\": \"224672\" }' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfMjE2/MDAxNzc5NTg1MTc2NTMy.geGiSJwr6zALyPx9gziaTVxIRsfnAr6jG4UtHblOelog.ysqnyDkU-JVVhysx98QCV9u__nLUJ37HQHH92wqQ330g.PNG/SE-c58a2ded-d46f-4cee-aecc-9c96ddb12920.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-6b8c0ab2-4697-423c-9d88-0683ead87ba3\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-86f82ba1-9a21-4322-a406-1b312f8093c6\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-063ddc70-f529-4382-9271-fd31ae6e83f1\" style=\"color:#555555;\">작업 진행과정을 고객님과 함께합니다. 진행에 대한 과정을 설명드리는 것이 (주)파파스컴퍼니의 가장 큰 강점입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3665c6e8-0282-4b4e-b603-24b485892cf0\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-746a7f45-940b-4d07-9fc6-875c9a51db0a\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-0db13e6e-0f65-4781-83ac-47342b8a55e8\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-63bc14ca-9811-4483-b746-5c2f2ab637ab\" style=\"color:#aa1f91;\"><b>■ 납품 및 피드백</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-28eecb44-6803-425d-99b8-e2ec881bd3ab\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-28eecb44-6803-425d-99b8-e2ec881bd3ab\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfNzkg/MDAxNzc5NTg1MTY0MTQz.Z2DBg8k3OOh90wyc1eNFHQ1DNkVTcvKaM2V-OmlQLO8g.uXXN-tCMe-n8biVBkdXA3VwOdTd_zRHlIyFVt1TO7Tgg.PNG/SE-28eecb44-6803-425d-99b8-e2ec881bd3ab.png\", \"originalWidth\" : \"999\", \"originalHeight\" : \"1168\", \"linkUse\" : \"false\", \"link\" : \"\", \"fileSize\": \"427901\" }' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfNzkg/MDAxNzc5NTg1MTY0MTQz.Z2DBg8k3OOh90wyc1eNFHQ1DNkVTcvKaM2V-OmlQLO8g.uXXN-tCMe-n8biVBkdXA3VwOdTd_zRHlIyFVt1TO7Tgg.PNG/SE-28eecb44-6803-425d-99b8-e2ec881bd3ab.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-4a273af2-6495-4cb4-b1bf-dec47f31009d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a62fd689-569f-4b0b-9580-c7decde3cc3d\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-66bb7e11-9242-4592-ae8d-44661ba6213c\" style=\"color:#555555;\">작업이 완료되면 배송을 보내드리고 피드백을 받습니다. 이 작업이 이루어지면 최종으로 보람을 느낍니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4795bdc5-119b-4dfb-96b1-5b380dd9d7aa\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d8abd3e2-ba79-4ae5-81e4-0ee3aaeac37b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-0ede6402-cdae-4502-93f2-5a8c626a1eda\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-775cb8ca-df21-48b9-9afb-7bb6fca4c620\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-350aa839-c90c-4c8c-9be9-5a9f131ba80b\" style=\"\">(주)파파스컴퍼니의 강점</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-a445d7f4-7cae-4927-865b-145d3b2058a2\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-24072378-1aeb-4fb7-b55d-c7cde302cfb8\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-1a9849cb-249d-481f-9605-94e5e82f18e9\" style=\"color:#aa1f91;\"><b>· (주)파파스컴퍼니은 소통에 강합니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5831cd1b-26eb-40ea-8ead-8fe7bea1d657\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ccfcf075-4d3b-47ef-9cf4-33a5e904130a\" style=\"color:#555555;\">작은 인쇄물이라도 최대한 고객님께 만족을 드리기 위해 소통을 강조하고 있습니다. 고객님과의 소통이 가장 큰 강점입니다. 소통이 잘되면 사고가 발생할 이유가 줄어듭니다. 소통이 잘 돼야 고객님의 만족도가 높아집니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4368b77b-b329-4002-89ee-05a507ca6762\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e0018e34-d37b-4cee-8204-fe0f1aec7c21\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-fbafa60b-007d-4b3f-b60e-d27c0a13799c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-643e0e4a-0ae8-440b-9177-d01bacd58bbd\" style=\"color:#aa1f91;\"><b>· (주)파파스컴퍼니은 고객님의 불편한 사항을 이해합니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5560bf99-6724-45fa-9405-ebede11ff007\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8ed6e70b-7ca5-4aa5-9bbc-fb983059d75c\" style=\"color:#555555;\">납기가 중요한 급한 인쇄물이나 수량이 적어 거의 작업을 거부(?) 하는 인쇄물에 강합니다. (주)파파스컴퍼니은 다른 업체가 하기 까다로운 인쇄물에 최적화되어 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6697f1e3-fcb8-4e4d-9b68-be5910c0559c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ba1101bb-ec03-459d-aab0-35b8f3223521\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-39b9eaae-85c5-4618-99bc-3cae872746ce\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-df3dcf65-a85a-4dcc-9e76-3451647907d2\" style=\"color:#555555;\">\"며칠 안에 납품이 가능해요?</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ab66145f-5549-4409-89e3-bf6ce49d6500\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-29bb30b5-1665-4143-90d6-251c10290dc2\" style=\"color:#555555;\">\"수량이 얼마 안 되는데 작업이 가능할까요?</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ae937b1c-b649-4f1a-83d9-adde8387aac1\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2cd89700-27b9-4a57-a79f-b7e80911415e\" style=\"color:#555555;\">\"샘플만 일단 만들어 보려고 하는데 될까요?</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-28d7e7fa-52dc-4e65-9ff4-5b8466e3010b\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-12ee2ada-f7fd-4702-b5be-2029d53558dc\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4e02647a-cfc6-4d5f-8b3d-3e84c31cb88d\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6be7c658-dfe0-48e6-afdb-3899058c70d3\" style=\"color:#555555;\">(주)파파스컴퍼니이 가장 좋아(?) 하는 질문입니다. 어떤 건이든 문의하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d27a1331-3df7-4743-ae23-9fc7e58f4dd8\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a57fdd9e-894a-4e48-8347-bfe5c83aec85\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-23e5db8d-1421-4cd2-a304-c8a986183e1c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-d759a423-aab9-4223-9089-fccf00c4c72f\" style=\"color:#aa1f91;\"><b>· (주)파파스컴퍼니은 고객님이 하시려는 인쇄물에만 관심 있습니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d3bfa0d3-6db1-4af0-80f9-eeb3caac8357\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-f7bc26df-1778-425e-9b0f-b5bc71f469d9\" style=\"color:#555555;\">비교견적, 단가, 타 업체에 관심이 없습니다. 오로지 고객님이 사고 없이 안전한 인쇄물을 받으시고 성공하는 것에만 관심이 있습니다. 어떤 문의든 친절하게 응대하려고 최선의 노력을 다하고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-89606e70-0d1c-45c3-9302-2260a5edc0d2\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-195d8c72-2fc8-4925-b3bc-c62df2590fcd\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-7bd6f169-550c-46d8-a51a-c09e37c1559b\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link-use se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-7bd6f169-550c-46d8-a51a-c09e37c1559b\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfNjQg/MDAxNzc5NTg1ODQ1MjUw.kDIbHPJYmGWqe3mmGmEZr_lqLTJtw6hs0cQr23K6fjIg.ddAkjJc780s9KC0P-pwsjE_tskTmrkHchLvDZuKtaW0g.PNG/SE-7bd6f169-550c-46d8-a51a-c09e37c1559b.png\", \"originalWidth\" : \"1773\", \"originalHeight\" : \"887\", \"linkUse\" : \"true\", \"link\" : \"tel:010-6451-8185\", \"fileSize\": \"251455\" }' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfNjQg/MDAxNzc5NTg1ODQ1MjUw.kDIbHPJYmGWqe3mmGmEZr_lqLTJtw6hs0cQr23K6fjIg.ddAkjJc780s9KC0P-pwsjE_tskTmrkHchLvDZuKtaW0g.PNG/SE-7bd6f169-550c-46d8-a51a-c09e37c1559b.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-image se-l-default\" id=\"SE-364dcdda-6c07-42aa-a5f7-3f3628914ba6\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link-use se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-364dcdda-6c07-42aa-a5f7-3f3628914ba6\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNjA1MjRfMjAx/MD