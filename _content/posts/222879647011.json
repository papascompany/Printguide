gn-center\" id=\"SE-ae8d4117-8f24-4f98-86ab-5364b4f038c3\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-8aa66dde-6242-4c17-b6b4-8032b1265ddc\" style=\"\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-881b6cd4-fe45-4cda-912a-1ee26ee3aeff\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-fd207de6-f186-47cd-872e-f5029109fd3f\" style=\"\">ps. 본 프로젝트는 3개월로 예정되어 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-1927a1bd-6e44-4ff2-90b9-61d73984a735\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-80ac1824-f6da-4301-b93b-36141927efd2\" style=\"\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-f6e295ef-714d-4c3f-8881-a544ac9ff34a\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_line\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ebab69e5-03ca-44be-9ae2-6cba38f5d3a1\" style=\"\"><span class=\"se-fs-fs24 se-ff-\" id=\"SE-6322c0c0-643a-4b7f-bc67-31c440069b50\" style=\"color:#555555;\"><b>다음 글의 내용</b></span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-2dfb5357-ea5e-4b2e-a87f-9ea0f44542bf\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-left\" id=\"SE-c36aa0cf-da97-4d27-af50-055c77155b25\" style=\"line-height:1.5;\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-9bebde94-9b67-4765-b0a7-7f65913ee909\" style=\"color:#ff5f45;background-color:#ffffff;\"><b>[기획]</b></span><span class=\"se-fs-fs19 se-ff- se-st