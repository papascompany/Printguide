 se-l-default\" id=\"SE-2a1b52c0-1c92-42cd-b3ed-398252750e56\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-8b707cac-3a0c-4c5e-8fc5-f8d10b9aaed8\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-weight-unset se-style-unset\" id=\"SE-6d95641f-346c-4969-a182-e458f5000ced\" style=\"color:#000000;background-color:#ffffff;\">내용, 텍스트, 서체 등</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-e7d93782-29a0-47b0-b072-38f14631f451\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-e7d93782-29a0-47b0-b072-38f14631f451\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDdfODkg/MDAxNjY1MTQzOTAyOTU0.G1iXBuVljaAzIEmAz03zC0_6caw8a01wvxOksCLBmE0g.0bxmBXTMVP6k2TZk103BrBF5zadBuLSBVaksdf4lHZIg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png\", \"originalWidth\" : \"2009\", \"originalHeight\" : \"1418\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDdfODkg/MDAxNjY1MTQzOTAyOTU0.G1iXBuVljaAzIEmAz03zC0_6caw8a01wvxOksCLBmE0g.0bxmBXTMVP6k2TZk103BrBF5zadBuLSBVaksdf4lHZIg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-e4fb1481-16cf-4bd7-840e-89aeadfd6d3c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-94bb329c-e01a-4b10-861a-d3600f200a26\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-9e3205ac-d0c1-45a6-9884-e73a78fc2dcd\" style=\"color:#555555;background-color:#ffffff;\">정보는 자세하게 그리고 비휘발성으로 전달하는것이 중요합니다. 이 부분때문에 저는 (주)파파스컴퍼니 사이트를 개발하려고 하는것입니다. 고객은 다소 귀찮더라도 정확하게 정보를 전달할 수 있습니다. 커뮤니케이션창이 좋은 사이트로 만들어 지기를 희망합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-34be9a85-b3c1-4bd8-b1a9-af5f3239b724\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-4f66104a-0b35-4709-bd02-f1292683091b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line2\" id=\"SE-0945a3fa-c22f-4a3e-94d2-278ed491b66b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line2 se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-65a5f7ca-7894-49c9-8a16-8b6975f4701e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-41397eec-115a-4485-8e02-cf58eb94c460\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-weight-unset se-style-unset\" id=\"SE-d3b4f0c5-af22-4c31-808e-ea52e69b135f\" style=\"color:#000000;background-color:#ffffff;\">이미지, 사진</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-1e25ba3a-70db-47c4-8330-531669fc7c5b\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-1e25ba3a-70db-47c4-8330-531669fc7c5b\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDdfOTQg/MDAxNjY1MTQ0MTMzNzc4.witZmxNNjSAv8XqtTsDWS7F8VhAb1-B1NWAZEZ2zDXog.XsUd6-T3-WooJ5kfokizOjKynnzvXg6NCSAatIP_g5cg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png\", \"originalWidth\" : \"2009\", \"originalHeight\" : \"1418\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDdfOTQg/MDAxNjY1MTQ0MTMzNzc4.witZmxNNjSAv8XqtTsDWS7F8VhAb1-B1NWAZEZ2zDXog.XsUd6-T3-WooJ5kfokizOjKynnzvXg6NCSAatIP_g5cg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-58d8bccf-bdb4-4a7b-a45a-4838bf45c332\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-c8a0702b-92ab-44d8-af66-8652ac17edb4\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-c12dc41d-05a8-4f5b-a33a-fc339a518c7e\" style=\"color:#555555;background-color:#ffffff;\">기본적으로 사진은 고해상도의 파일로 기타 자료는 벡터이미지로 자료를 받아야합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-d85dfe2f-b68c-4c40-8747-4d7619269f31\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-ab57a80e-ff41-41ab-8e95-2a19d5f7f538\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-72de4624-c851-49df-849a-aa394e0b0f57\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_line\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b2f46888-f21f-4e57-a060-4eafa455f8c1\" style=\"\"><span class=\"se-fs-fs24 se-ff- se-style-unset\" id=\"SE-9673e6fc-61b9-404e-a5d2-cae0022e2675\" style=\"color:#555555;\"><b>주문시 고객으로 부터 받아야 할 자료</b></span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-line5\" id=\"SE-f651256b-03f6-4b5f-a7da-482e612d7f8f\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line5 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-2f1b5783-861f-47d1-9e0b-3c8328fc9652\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-92e5435f-f0c5-4024-abd0-327c509bcfad\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-weight-unset se-style-unset\" id=\"SE-1dfbf4f7-3114-4bba-9a93-5867fc539e29\" style=\"color:#555555;background-color:#ffffff;\">1. 사이즈 정보 : (주)파파스컴퍼니 사이트는 템플릿 번호로 하겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-24a14479-ddef-4caa-8696-ad732d0bb57a\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-weight-unset se-style-unset\" id=\"SE-88c0d795-b5e8-4d0d-ae57-d0eb4a987752\" style=\"color:#555555;background-color:#ffffff;\">2. 본문 내용 : (주)파파스컴퍼니 사이트는 템플릿에 있는 수정 가능한 영역으로 정의하겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-51e4d2ef-7e2e-4687-a849-1140d833f2c7\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-weight-unset se-style-unset\" id=\"SE-a818ef01-ab0e-4410-bbe7-1f9e7bc5fa58\" style=\"color:#555555;background-color:#ffffff;\">3. 이미지 / 사진 (포토) : 첨부파일을 통해 자료를 받겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-dc0e34a4-d891-4313-ba92-33ae87ebc0b2\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-weight-unset se-style-unset\" id=\"SE-7a8fe35b-2d0a-4d49-8533-5b6850f3bc32\" style=\"color:#555555;background-color:#ffffff;\">4. 레이아웃 (폼, 형태, 효과 등) : 템플릿 디자인 속성으로 정의됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e0f4a14b-6080-40ae-b2f1-65055cd62cb0\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-weight-unset se-style-unset\" id=\"SE-00a099f5-c2ae-460f-b5f9-7d5c49bdfecf\" style=\"color:#555555;background-color:#ffffff;\">5. 회사 참고 정보 (로고, 회사정보 등) : 첨부파일을 통해 자료를 받고 견적에 반영합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-1de27feb-d6ec-4749-82b8-bcd748cfacbd\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-e623a453-cb46-432c-a548-3dff5b8ca7a9\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-2c89e053-e0ba-4058-af1c-bd2182083d00\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-df88c192-cde3-4300-95aa-937e92ef1c04\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-ecb1d0c8-401f-493d-8b6b-89b7df1a98b6\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-a0183939-7b09-41c5-81ce-8cff682ea7b8\" style=\"color:#555555;background-color:#ffffff;\">최종 사이트 주문이미지</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\