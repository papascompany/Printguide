c5OTg1OTk2.Lb2saTr7C1Ip-rcqNhLL4ThIWq-6EtagGkFL03v-0lMg.uHC60MAvd5vlxXoItvIHd-gtDrge9SXs8m71mbRPK68g.PNG/2.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-c85a4476-29c3-4740-b891-82d084129914\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-e5486066-a1af-4748-ad79-0d016cef0eaf\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e9240c14-a31c-45ca-a09f-8c693422e054\" style=\"color:#555555;background-color:#fff8b2;\">위 사이즈는 A4를 접는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-e6dd755d-cb22-43eb-bb54-317522a5c5f0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-873be7a7-b333-4859-8608-014c027f3a47\" style=\"color:#555555;background-color:#fff8b2;\">사이즈입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-4301bd3b-2f3f-4b6d-94bb-a3aa4e7d1402\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-f73b0b68-11e5-439c-9911-d07e2f16e86f\" style=\"color:#555555;background-color:#fff8b2;\">여기서 주의할 점은</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-44587482-23fb-4a42-a721-fe94441bc43d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-acb1f8af-5472-4888-be6c-602f7bb14bad\" style=\"color:#555555;background-color:#fff8b2;\">접히는 부분의 여분이</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-332608d5-28db-4470-9c99-0a87fe8960d0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-fad8d710-dc1a-4e2c-9ff3-5acc642658b2\" style=\"color:#555555;background-color:#fff8b2;\">약 2mm 정도 줄여서</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-93e505d6-e02e-4086-bf1d-3bf6227a5446\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7a5ea001-d289-45e2-8a8c-60ec89efa15b\" style=\"color:#555555;background-color:#fff8b2;\">디자인하는 데 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9fadcea1-30d3-4c0b-94a7-6b78425ad1de\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-419fe8e8-f030-49ef-84f0-c3c4c8928fd1\" style=\"color:#555555;background-color:#fff8b2;\">그러므로 이 사이즈도</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-8ed00956-a49b-4177-9d49-f7a4181ac061\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e29365cb-b2b4-4cab-b694-dae92ea783fd\" style=\"color:#555555;background-color:#fff8b2;\">정확하게는 100mm로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-14e52515-8c64-4924-a7d1-4403c05ded2f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2d67ed69-f130-4e11-904c-6816029caf87\" style=\"color:#555555;background-color:#fff8b2;\">나오고 접히는 내지가 3mm 정도</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-a7d52730-17b7-4506-af8b-3ecca59c5622\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-50109cdb-a922-4ed4-8270-6c7403ec030f\" style=\"color:#555555;background-color:#fff8b2;\">적어질 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-a3423dc2-5f97-4c87-9a94-e0870a316192\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a29be742-5d5d-48f5-91c6-e03c56ea1949\" style=\"color:#555555;background-color:#fff8b2;\">내지 3mm가 적어지는 것이</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-f5c2f30d-b6a6-487f-a6f6-6f269712b384\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ab1d3f4d-a791-43ad-b1a2-cc45c6d1a274\" style=\"color:#555555;background-color:#fff8b2;\">안 좋다면 다음 사이즈로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-5f2dfd5b-3adc-40b6-998f-49f47c30d865\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-dd7ac382-79f1-41b8-a043-ccca67740c8c\" style=\"color:#555555;background-color:#fff8b2;\">대부분 작업합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2b6452f1-553d-46d9-b5ef-e799d6b43f1f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c7ad467e-341a-4ad9-a043-8ebe093ebfb6\" style=\"color:#555555;background-color:#fff8b2;\">99mm×99mm×98mm</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-7e7cab94-4254-47ee-8087-ced2230d3a7f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ad6c93cf-1634-4a6b-bf2e-00c558594777\" style=\"color:#555555;background-color:#fff8b2;\">296mm입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-efc4535b-b3c5-4ac9-b76e-a38a18e9e470\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-4c739500-831b-48f2-b6af-133e2d242c34\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-392d15c6-4eed-4e3a-a095-107b865f425f\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-392d15c6-4eed-4e3a-a095-107b865f425f\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMzFfNjIg/MDAxNzQzMzc1MjM3NDgx.z-oEJ6ekRzV1jMqOUvJJC2A55agWVkyAyxEx_RY9VYog.TRWGkDdZi06nqmwc11P6oZ_cJ8Payce74LiwlWERReIg.PNG/A4_3%EB%8B%A8%EC%A0%91%EC%A7%80_1.png\", \"originalWidth\" : \"4000\", \"originalHeight\" : \"3000\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMzFfNjIg/MDAxNzQzMzc1MjM3NDgx.z-oEJ6ekRzV1jMqOUvJJC2A55agWVkyAyxEx_RY9VYog.TRWGkDdZi06nqmwc11P6oZ_cJ8Payce74LiwlWERReIg.PNG/A4_3%EB%8B%A8%EC%A0%91%EC%A7%80_1.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-d0056202-5c40-411e-a261-a2696db8ed70\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ee2e2e50-f621-44e6-9936-603a9967ccfc\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-ca6e791e-218c-4d90-84ab-6b16bdb1bd87\" style=\"\">3단 리플렛 접지</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-72cdfec4-7648-4a1a-b7fe-6b6bedd80655\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8bcda57f-ca4e-4102-8f36-bd2e80d4ac97\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6bf84c0f-1e9d-45c3-97f8-ea3609187753\" style=\"color:#555555;\">3단 리플렛의 접지 방법은 다음과 같습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-c417f024-1a1b-41aa-b156-1c9d211823e1\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-c417f024-1a1b-41aa-b156-1c9d211823e1\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMzFfMTE4/MDAxNzQzMzc5NzM4MDc1.k8Z0MbY2Qc3mq6vzRcKbRyicvu2oLJxNOMcy0qVTLrsg.rfooPhmCrAc2yn4z0B7dlJXedCLqF4ce27HEkmoujd8g.PNG/1.png\", \"originalWidth\" : \"1392\", \"originalHeight\" : \"807\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMzFfMTE4/MDAxNzQzMzc5NzM4MDc1.k8Z0MbY2Qc3mq6vzRcKbRyicvu2oLJxNOMcy0qVTLrsg.rfooPhmCrAc2yn4z0B7dlJXedCLqF4ce27HEkmoujd8g.PNG/1.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-4dfa0250-991d-42c7-8103-a74f089ff5f4\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-216d82af-5bb2-497e-bf41-6a8a88e40036\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-cb0c4f03-a24a-4770-a5e9-e1eb651142ae\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fa55af17-7bba-471b-8b4d-3e7bdb725be0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-5c7cb861-e2ac-41e8-9e9a-05db228a64a0\" style=\"color:#555555;\">3단 접지는 왼쪽 면부터 접습니다. 그리고 오른쪽이 표지로 올라가게 됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a5ef88c2-edfc-493b-bea5-79f21559c5b4\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-aab488fc-d90c-4ee1-8d0a-6fe150d0090a\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-65d9bd53-ef6c-4c71-92b7-3407f082fa32\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8e3ec72c-97ad-4f39-b39d-ff2a7515ebdb\" style=\"color:#555555;\">3단 접지의 경우 4단보다는 접는 방법이 하나뿐이지만 안쪽에 접히는 부분의 사이즈 줄임만 기억하시면 작업하시는데 어려움이 없으실 겁니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-63394db4-bf97-4572-9ab7-52a6c003b68a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-adc4b034-ee96-4f6d-ba6f-259a08d1484a\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-c94764b8-dc95-40cd-a973-f0acd8027baf\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6183999a-5b89-4119-aa7a-88f8942981da\" style=\"color:#555555;\">또 하나 고려해야 하는 것이 종이 두께에 따른 오시(누름선)작업 유무입니다. 150g 이상의 두꺼운 종이는 반드시 오시를 넣지 않으면 터짐 현상이 발생됩니다. 그리고 코팅을 하시는 것이 안전합니다. 터짐뿐 아니라 뒤 묻음도 방지할 수 있습니다. 참고하시기 바랍니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-395d9122-dc1f-476a-8d23-806dadeb7565\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-df80619c-30e8-4caf-9809-f951c0afa2fa\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-019b44f7-ccc9-4e42-bbb1-1b74bd4b6c3c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-41bda053-4202-4728-9f80-ac65c679695d\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-1a2e6455-2823-4520-8581-64bbab8fa134\" style=\"\">3단 리플렛 인쇄</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-8e3ebe7b-d1b5-4734-bd19-1053ab41b541\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5d9e3936-8ab9-4661-9879-3c57104580a8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d1f7be88-da26-4009-905c-92507e60d271\" style=\"color:#555555;\">리플렛 인쇄는 4도 인쇄가 기본이고 별색인쇄도 되지만 가장 중요한 것은 인쇄 방법입니다. 리플렛은 일반 종이가 아니라면 종이 지분으로 인해 뒤 묻음이 많이 발생될 수 있습니다. 그러므로 수입지로 제작되는 리플렛의 경우 UV 인쇄를 사용합니다. UV 인쇄는 간단하게 설명하면 속건성 인쇄잉크를 사용한 빠른 정착성을 차지합니다. 이 말은 인쇄 후 빨리 말라서 뒤 묻음이 적다는 뜻입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9e0dc59c-4494-4bce-ba06-37d9acae2777\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6dc5ffad-7c7d-4fd4-8dd1-dc3df39b7b8d\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a9fe546a-4ba2-4315-84c4-ec1639f8685d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-15cfc13f-1787-421e-919d-2e9408400274\" style=\"color:#555555;\">만야 좋은 종이로 고퀄리티의 리플렛을 제작하고 싶으시다면 좋은 종이에 UV 인쇄를 진행하시기 바랍니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-5fb8a70e-5e31-4fbd-b218-47efc62e434f\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-b167eef4-d00a-4922-8208-a58a8efa54b5\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-29b6d0bc-face-4d81-96e2-db00af71c670\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-84e57c5e-8eac-4e18-8860-6994fc73da4e\" style=\"color:#555555;\">이처럼 리플렛 제작 시에 고려해야 할 사항이 있습니다. 가장 중요한 것은 본인 회사에 맞는 종이, 사이즈, 인쇄 방법 등을 선택하는 것입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b0ed7e23-cce3-418d-82e7-b778918059e1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d496a1a9-7dd9-408e-bf0e-d305ca9ee5c0\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b613992d-1b26-4355-a4d3-ca5680d3e62b\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0231606e-2293-4c29-80c5-4890dbee7ba6\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b5ba5460-6c82-4127-89e1-9f536b2a43a3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-40ed384e-537b-44bb-ab81-33660b0b3b1f\" style=\"color:#007aa6;\"><b>고객님이 선택해야 하는 고려 사항</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-06951557-29c3-4cfa-9254-7396f258382c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-896c0ef0-5c4b-44c1-8ca8-6141d5761079\" style=\"color:#007aa6;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e5d108cf-623f-4f29-b0a3-d047ce265ef1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-64d47148-ecfc-4c6e-9604-0846f544127a\" style=\"color:#555555;background-color:#ffe3c8;\">디자인을 잘할 업체를 찾는다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4a1da68e-16ba-4dcb-97e1-62a50e27c582\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-091ed524-3550-4488-b314-82164833c67d\" style=\"color:#555555;background-color:#ffe3c8;\">소통을 잘 하는 업체를 선택한다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-04e109f3-b9c4-4b8e-b20c-c941bd6b6c40\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2c5970a3-240f-46c9-8be4-997cb469a10a\" style=\"color:#555555;background-color:#ffe3c8;\">자신의 홍보물에 대한 조언을 할 수 있는 업체를 찾는다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b47e88d8-6616-4937-b38b-c3e3b473d8b2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b3f4e6d8-f1c8-4bd2-a116-ddeec4da152e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9f6d11a0-5e65-4adb-b119-11eb8883f219\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-678e52a0-c14e-4093-aadb-86852f015873\" style=\"color:#555555;\">이 3가지 부분은 (주)파파스컴퍼니이 가장 잘하는 것입니다. 언제든지 문의하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1ab981af-f2a6-45bb-b923-83020b248b2a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-1dec53fb-c5c3-49a0-92d9-fb9cbba5df85\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-05ac0359-4ccf-4e92-a2cc-10fc25cc2508\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a70618cb-c2ed-44b1-bada-22802e4854ed\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-53910440-e932-4d17-80ef-bd87a85f4fb8\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align-center se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;ref=https%3A%2F%2Fm.blog.naver.com%2Fcookthedesign%2F223815760286#nafullscreen\" onclick=\"sendClickNlog('pst.talktalk', '');\">\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n</a>\n</div>\n</div>\n</div>",
