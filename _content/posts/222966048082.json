se-l-default\" id=\"SE-f3046acb-7797-40b7-a5ec-237605f10e9b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f7ea7425-63b2-4131-a55c-a0781b7db0b2\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-9468a54f-d927-4a41-b705-da35f37cefe1\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3a88eb00-6d87-4f80-b970-e94910f61311\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-19c45491-fdb6-4903-a8ef-df7c223a7bec\" style=\"color:#555555;background-color:#ffffff;\">ID 000001번은 주문 상세를 기록하지 않아도 되는 간단한 주문건입니다. 이 때는 상세등록을 하지 않아도 됩니다. 주문상세를 입력하기 전에 주문의 기본을 입력해서 기본 내용을 기록하고 관리합니다. 지금의 상대는 모두 상세가 미등록된 상황입니다. 주문 상세를 기록하고 저장하게 되면 등록으로 변환됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5ab33851-c230-474c-a154-46acd7fad0df\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-470e0a46-52a8-475b-a62e-e1867656ecdb\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-55e89234-153a-485e-b707-97eb8f3d17ca\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-55e89234-153a-485e-b707-97eb8f3d17ca\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEyMjZfMTY5/MDAxNjcyMDMwNDY0ODc3.aIeS-O-fiN1JKB3ST5a4WS_mrsTksYJ76p67njopsE8g.uCcF4OgPK2hxhF9wEMrgw3ViHHww9Nr_5JooXRkliO4g.PNG.cookthedesign/image.png\", \"originalWidth\" : \"2403\", \"originalHeigh