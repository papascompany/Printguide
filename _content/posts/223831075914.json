ADBO1005J8wfsg.PNG/1.png\", \"originalWidth\" : \"1388\", \"originalHeight\" : \"982\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTA0MTJfMjk3/MDAxNzQ0NDU2ODIxMjk0.H2pLz1sLSMB2Z_ROqITcJEb7lVHtQsDqJUfB37mMOpQg.05RfJatvGkK4hpyQ6EHgEJzr0uYh5kADBO1005J8wfsg.PNG/1.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-f62e86b0-4b1f-420c-8335-198d4999cd6b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6d8212c3-cf79-4f9e-a06c-b3fb37f42f00\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-dca85903-28c0-4ad3-809b-ce96313dcddb\" style=\"color:#555555;\">3단 접지의 방향은 위 그림과 같습니다. 오른쪽의 면을 먼저 접고 왼쪽의 면이 위로 올라가게 접는 겁니다. 이런 이유로 한쪽을 1mm 짧게 디자인하는 방향을 이해하실 겁니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bb7b2a0b-b39e-42e4-aa31-5336b0d61f39\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-15ea60b4-9d5d-4007-af2e-e02296e9316f\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7764ebae-d552-4c82-8f11-1ed9394b4b5f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e670f4c3-2d90-4530-a593-a4facba862f2\" style=\"color:#555555;\">그러므로 각 디자인 페이지는 다음과 같이 배치됩니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-0ebf3001-3718-48db-856b-b7dfe5ab6b94\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-s