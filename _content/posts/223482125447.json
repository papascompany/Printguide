-phinf.pstatic.net/MjAyNDA2MTdfMTE1/MDAxNzE4NjAzNDU5MzA4.ApPPIPYkD-coNrSp9TnQ3xZOGUgZ6JaysJFYGnwY6X8g.ngZ4z5LumaklSsZZqydeqbXSTjG6x79vJq-QS4o00lwg.PNG/Key_point.png\", \"originalWidth\" : \"969\", \"originalHeight\" : \"238\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNDA2MTdfMTE1/MDAxNzE4NjAzNDU5MzA4.ApPPIPYkD-coNrSp9TnQ3xZOGUgZ6JaysJFYGnwY6X8g.ngZ4z5LumaklSsZZqydeqbXSTjG6x79vJq-QS4o00lwg.PNG/Key_point.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n<div class=\"se-component-slot\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5f23d3d4-964d-4747-9636-4a34ca423d5a\" style=\"\"><span class=\"se-fs-fs38 se-ff-nanumgothic se-style-unset\" id=\"SE-2ed96903-3619-428d-ba4f-74c03ceb8233\" style=\"color:#333333;background-color:#ffffff;\"><b>가격 로직을 가지고 있는가?</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4504c47d-1cc7-4905-b313-0998689b9fb7\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-045a0d3b-34c0-4236-9576-20e5e895ede9\" style=\"color:#555555;background-color:#ffffff;\">인쇄 사이트에서 가장 중요한 것은 가격 로직을 가지고 있는가의 부분입니다. 이유는 간단합니다. 인쇄 가격 로직을 구현하기 위해서는 사이트 개발자가 일단 인쇄의 기본 속성을 이해하고 있어야 합니다. 인쇄의 프로세스를 이해하지 못하는데 가격 로직을 개발한다는 것은 거의 불가능에 가깝습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-6c66e899-8c46-4227-9f9b-6488ab3d8741\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-6c66e899-8c46-4227-9f9b-6488ab3d8741\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNDA2MTdfODEg/MDAxNzE4NjAzNjU3MTg0.QycdtvKLEtjUgiOGsFJ97mQBXLlv0b0TjM-ZLO03NSwg.-NiL83VZLP2a_ba9aspx1B6BeaiaD9-5Je2f1OqX8P0g.PNG/image.png\", \"originalWidth\" : \"1101\", \"originalHeight\" : \"742\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNDA2MTdfODEg/MDAxNzE4NjAzNjU3MTg0.QycdtvKLEtjUgiOGsFJ97mQBXLlv0b0TjM-ZLO03NSwg.-NiL83VZLP2a_ba9aspx1B6BeaiaD9-5Je2f1OqX8P0g.PNG/image.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-bc838e97-78fc-42e5-ac7a-8f920396181c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-21ad02f5-8d4f-44eb-9301-a4624427bb03\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-ec22d619-fc2d-437e-8ccb-8e09dd0698b7\" style=\"color:#555555;background-color:#ffffff;\">기본적인 가격 로직을 개발자가 이해하고 있을 때 비로소 자동견적 책정이 가능하다는 이야기입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bc2396d0-4d6e-4ae4-b2a0-e83850d148bc\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-72cf96a9-8689-4d44-abb6-255695dcad9d\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-bddbf65b-ab99-4bb4-97ad-0a050f207399\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-bddbf65b-ab99-4bb4-97ad-0a050f207399\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNDA2MTdfMTY2/MDAxNzE4NjAzNzMxNDcx.flqGxks_iAGizX_dhheYUWnKiB06jvpsfFZoyk8Y63gg.NQgJDf8Dptqeu-2xcRXLEgX6bdAGCTp7f6OvWPwTRj8g.PNG/image.png\", \"originalWidth\" : \"1113\", \"originalHeight\" : \"795\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNDA2MTdfMTY2/MDAxNzE4NjAzNzMxNDcx.flqGxks_iAGizX_dhheYUWnKiB06jvpsfFZoyk8Y63gg.NQgJDf8Dptqeu-2xcRXLEgX6bdAGCTp7f6OvWPwTRj8g.PNG/image.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-b831648b-76fa-4855-8edd-1cbcd227eae3\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-12cd975c-5f5c-4bd6-baeb-560138292d1a\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-8a2d24a3-c71c-4bc0-8252-f2ed48250035\" style=\"color:#555555;background-color:#ffffff;\">또한 이런 책자형의 경우 종이비와 출력비와 인쇄비와 제본비와 후공정비가 합산되어 계산식으로 구현되어야만 가능한 품목이 있습니다. 데버 솔루션은 원가 종이비가 몇 절에 얼마에 사 와서 얼마에 판매해 마진이 얼마인지를 페이지와 사이즈와 수량에 의해 계산하는 로직을 완성했습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f25bbfea-18de-426a-8fb1-56aeab57634d\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-23a1e7fa-21f6-4679-9408-3d0caf6473f6\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-60483658-b3e9-4a8a-9d01-f765a9333e19\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-0ff9ffaa-3ab6-44e7-93d1-3cb206b2b941\" style=\"color:#555555;background-color:#ffffff;\">이 자동견적 로직 구현은 쉬운 일이 아닙니다. 출력 판수와 인쇄 방식에 따라서도 변경되고 매우 복잡한 구성요소를 가지고 있습니다. 이를 개발자가 이해하고 구현할 수 있는지가 관건입니다. 반드시 이 부분의 로직이 어떻게 구현되어 있는지를 점검하십시오. 그래야 개발에 실패가 없습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-44e7b519-b951-4b10-bb76-a574ccb8f301\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-wrappingParagraph se-l-inner-left\" id=\"SE-f4da8fa3-69d3-4b13-a493-3cc2d856a184\">\n<div class=\"se-component-content\">\n<div class=\"se-component-slot se-component-slot-float\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-97d09c20-c71e-4db7-9e05-ac3f302bc277\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNDA2MTdfMTE1/MDAxNzE4NjAzNDU5MzA4.ApPPIPYkD-coNrSp9TnQ3xZOGUgZ6JaysJFYGnwY6X8g.ngZ4z5LumaklSsZZqydeqbXSTjG6x79vJq-QS4o00lwg.PNG/Key_point.png\", \"originalWidth\" : \"969\", \"originalHeight\" : \"238\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNDA2MTdfMTE1/MDAxNzE4NjAzNDU5MzA4.ApPPIPYkD-coNrSp9TnQ3xZOGUgZ6JaysJFYGnwY6X8g.ngZ4z5LumaklSsZZqydeqbXSTjG6x79vJq-QS4o00lwg.PNG/Key_point.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n<div class=\"se-component-slot\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ad8f1aa0-8648-472c-b99b-bc47c415857c\" style=\"\"><span class=\"se-fs-fs38 se-ff-nanumgothic se-style-unset\" id=\"SE-1c40ab07-61cc-4acc-b4ca-068e2857d615\" style=\"color:#333333;background-color:#ffffff;\"><b>개발에 최적화된 인원을 보유하고 있는가?</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f7f9acd4-aaad-4f04-b3f1-9bcacdd7252f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-50b464c9-6c8e-484f-8acd-f16064305949\" style=\"color:#555555;background-color:#ffffff;\">인쇄 사이트에서 파트별 담당자는 매우 중요합니다. 인쇄를 잘 아는 기획자가 필요하고 실질적으로 성과를 낼 개발자와 동시에 잘 그려주는 디자인/퍼블리싱 영역까지 이 모든 부분의 인원을 충분히 보유하고 있어야 합니다. 어떤 파트는 외주로 의뢰해 제작한다거나 어떤 파트는 보유 일원이 없어 자주 바뀌는 경우 실질적인 개발 퍼포먼스를 내는데 걸림돌이 될 수 있습니다. 데버는 총 32명의 직원 중에 약 6명이 인쇄 솔루션 개발 작업에 역할을 하고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f2223720-ddd8-425a-9acb-fc0a77f489b8\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-d6152440-4c5f-4beb-94db-9c2364c5d8bd\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-97f516ec-37d0-4c6e-bab6-68cfd11f326b\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-68cdb705-febe-493c-bc56-d5a97426b128\" style=\"color:#555555;background-color:#ffffff;\">인쇄를 잘 아는 기획자는 물론 여러 사이트의 디자인과 퍼블리싱을 담당했던 인원과 개발 핵심 CTO가 포진하고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-78f175e8-e7bf-4b61-a87e-a9b74b63b78e\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-dd43bd3b-ea39-4005-8527-c54cd05cd336\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3fdbedb9-68f1-4f93-854c-0d7b6ab5adb3\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-a0229612-da67-4412-960f-c34dc5093648\" style=\"color:#555555;background-color:#ffffff;\">이 솔루션 키포인트 법칙은 비단 인쇄 개발에만 통용되는 것은 아닙니다. 전산개발을 의뢰하다면 반드시 체크해야 될 사항입니다. </span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-2c25e4ad-a35e-4292-8673-aec9243be548\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-0f90bd96-2e87-4c31-836e-19faf9b702ca\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-2360fa97-bdfd-49ea-842e-4f82f6098b32\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-86fb8263-824e-4891-8416-2e1f804f8145\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-5c3a6db9-354c-49fa-83e2-caa08d4a0210\" style=\"color:#555555;background-color:#ffffff;\">아래의 데버 홍보 파일을 다운로드하셔서 검토해 주십시오.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-file se-l-default\" id=\"SE-e4f7fed6-1e38-4b43-a84c-e8f2e9d4f398\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-file se-l-default se-section-align-\">\n<div class=\"se-module se-module-file\">\n<span class=\"se-file-icon\"><strong class=\"se-blind\">첨부파일</strong></span>\n<div class=\"se-file-name-container\">\n<span class=\"se-file-name\">00 홍보문서 240204_opt</span><span class=\"se-file-extension\">.pdf</span>\n</div>\n<a class=\"se-file-save-button __se_link\" data-linkdata='{\"link\": \"https://download.blog.naver.com/open/d742cb706c5c5de9cd24417c49a6d2a8085ba07c/EFsQabdMxbjO9d1RLuoSggWaFwbSq-dpeF8XKG00xEFxTtTRU3on5Pm_DoFlhi4hryTxWHX50Ac-wR9SN10mMQoEQWApKj-plnyTng/00%20%ED%99%8D%EB%B3%B4%EB%AC%B8%EC%84%9C%20240204_opt.pdf\"}' data-linktype=\"file\" href=\"https://download.blog.naver.com/open/d742cb706c5c5de9cd244