h09C4zJsl5y--iVaCN4gSC6d_HXq--vTefCqIAg.Ehk3SqN9keTm7RUQOJoso9tj5ll-v7INckYjpk5oR0Mg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png\", \"originalWidth\" : \"3508\", \"originalHeight\" : \"2482\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfMTYg/MDAxNjY4NTY4NjM1MDE4.6Yj81h09C4zJsl5y--iVaCN4gSC6d_HXq--vTefCqIAg.Ehk3SqN9keTm7RUQOJoso9tj5ll-v7INckYjpk5oR0Mg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-4a746750-f10b-4c7a-90a2-ac4128e04c39\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-57f73119-4a64-45d4-9252-4bb2ec86352f\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-d8c7ad39-0351-4b63-a775-cc9b034f8121\" style=\"color:#555555;background-color:#ffffff;\">기업의 사업과 관련한 이미지 형상이 가장 무난한 CI로 가는 지름길입니다. 회사의 요청에 의해 색상은 무거운 톤에서 밝은 톤으로 진화하는 그라데이션을 사용하였으며 그 목적에 걸맞은 아이콘 개체를 이미지 형상화에 삽입하였습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2796e7d5-2ac5-4973-b842-73412853aaa1\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-6b279894-aa40-48f7-ac3a-9e598fbcbb10\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a5f3a917-4d40-413e-ba7e-4832d1deb2f2\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-cf5b9206-3f70-40d3-acc3-a6f210f30648\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-33b7805f-eb0e-4672-b806-b959986c05d1\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-33b7805f-eb0e-4672-b806-b959986c05d1\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfNzMg/MDAxNjY4NTY4NzYzNTcw.4KjPfVZIpoUWV4RmPCs_Ia8IwObPDYiTtaJSyy20nqIg.c8r3W3ao9eS0MOmLzC563uJvuC5PmTyWnktSs-_ID_wg.PNG.cookthedesign/2.png\", \"originalWidth\" : \"2364\", \"originalHeight\" : \"237\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfNzMg/MDAxNjY4NTY4NzYzNTcw.4KjPfVZIpoUWV4RmPCs_Ia8IwObPDYiTtaJSyy20nqIg.c8r3W3ao9eS0MOmLzC563uJvuC5PmTyWnktSs-_ID_wg.PNG.cookthedesign/2.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-8db0a04a-9d9a-49a7-9ce7-50eb70fbbcf1\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4616150c-1057-4f53-a680-298dfa3c2d70\" style=\"\"><span class=\"se-fs-fs24 se-ff-system se-style-unset\" id=\"SE-3ae4bdc4-c42f-4533-8556-4b80ecae2d12\" style=\"color:#00b3f2;background-color:#ffffff;\"><b>Typography</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-83241b2f-f10b-4b22-9073-e73590eaa0cd\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-40d1bf7a-a8a5-4110-a137-6562d4ee782d\" style=\"color:#555555;background-color:#ffffff;\">서체와 그에 맞는 이미지화를 전체적으로 타이포그래피(Typography)라는 용어로 통상 불립니다. 서체를 응용 또는 디자인화하여 그래픽의 일부로 표현한다는 의미입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-26556e3f-b349-4c53-b149-1d0eefbe9f37\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-460624d2-8d64-4805-b91d-c694d84ea2a2\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b26271aa-c5ce-4d36-abd9-50e6b65d46e6\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-7590865a-0032-49fc-bf89-ea98721effae\" style=\"color:#555555;background-color:#ffffff;\"><a class=\"se-link\" href=\"https://terms.naver.com/entry.naver?docId=264320&amp;cid=42635&amp;categoryId=42635\" target=\"_blank\">https://terms.naver.com/entry.naver?docId=264320&amp;cid=42635&amp;categoryId=42635</a></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>  <div class=\"se-component se-text se-l-default\" id=\"SE-06225a4a-1bc7-4911-9cfb-e30763260f95\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5a6a75ba-6659-4fcf-90bd-16359f29402d\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-e7773dce-06c3-413e-93a4-2d4d4a7777c9\" style=\"color:#555555;background-color:#ffffff;\">로고와 기업 취지에 맞는 서체의 선택, 그리고 그것을 이미지로 표현하는 기술이 타이포 그래픽 방법입니다. 보통 서체의 저작권 등으로 기본적인 서체를 골라 사용하며 특별한 경우 서체를 이미지화하여 로고처럼 활용하는 경우도 많습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-865af8c1-134d-4ff9-a06d-65bc111226cb\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-73820120-a197-48b5-86f0-dc42dc6ab51e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-50fe3de9-4a60-4895-be55-08af0ce398d6\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-50fe3de9-4a60-4895-be55-08af0ce398d6\", \"src\" : \"https://cdn.dribbble.com/users/45787/screenshots/3299497/attachments/711831/big_ci_sf.jpg\", \"originalWidth\" : \"1400\", \"originalHeight\" : \"5090\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.dribbble.com/users/45787/screenshots/3299497/attachments/711831/big_ci_sf.jpg\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-7a283d6d-b0d1-4b9d-8915-8875d9c0b920\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6c703e76-f95b-45fe-8e42-bbc9f85e00b4\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-dd6aaac0-3587-4ff7-becf-ec953d584bcb\" style=\"color:#555555;background-color:#ffffff;\"><a class=\"se-link\" href=\"https://dribbble.com/shots/3299497-SF-identity-book/attachments/711831\" target=\"_blank\">https://dribbble.com/shots/3299497-SF-identity-book/attachments/711831</a></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>  <div class=\"se-component se-text se-l-default\" id=\"SE-3eb81f46-0d6d-47ae-9483-a20bcacdef08\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-df18dace-1b76-4e2f-bd0b-0bd924c148d6\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-b67eb203-16c7-4faf-95b8-69cb6f07cc5a\" style=\"color:#555555;background-color:#ffffff;\">서체의 프로토 타입은 클라이언트에 제공하거나 제시하는 것이 좋습니다. </span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-fa6e9179-e47c-4eb7-8a7a-8b05743753d9\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-fa6e9179-e47c-4eb7-8a7a-8b05743753d9\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfMjY1/MDAxNjY4NTY5MzA4Mzcw.ynOwfgN6wddEdPnbuOH9lil9rYcQiJflgb5eiIDuIhYg.f3oLzuoGmoXgexwZ35scM8XhacqV7VlYRr-nUnpgXPAg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png\", \"originalWidth\" : \"2552\", \"originalHeight\" : \"1843\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfMjY1/MDAxNjY4NTY5MzA4Mzcw.ynOwfgN6wddEdPnbuOH9lil9rYcQiJflgb5eiIDuIhYg.f3oLzuoGmoXgexwZ35scM8XhacqV7VlYRr-nUnpgXPAg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-2399c79e-211c-4289-82fd-4990f538cda7\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e87c52f2-b06a-43f8-827c-a70623d51680\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-f01c21ef-bb3b-4ac7-b69e-e46ade80e3b0\" style=\"color:#555555;background-color:#ffffff;\">서체의 종류, 크기, 줄 간격, 언어 간격, 문자 간격, 단어 간격 등을 명시하여 추후 다른 웹, 앱에 이 타입을 표준화하는 작업을 CI라고 할 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-dd46a9bf-a1a0-41c4-927a-106f764168c2\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-a954437c-536c-41c5-8149-f941f108d7ca\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-0ee862a4-e344-4aa7-aa4e-72d8638c6cfc\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-0ee862a4-e344-4aa7-aa4e-72d8638c6cfc\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfOTEg/MDAxNjY4NTY5NTU5Mjk2.nWatRl3QMJEHih41iFzh4fUXqkL5p3fljfu0MicYyTMg.9CGoxqyRLiNrExZrcAqwJgzqYiYtgn8DlpYwQNR1ubQg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png\", \"originalWidth\" : \"4253\", \"originalHeight\" : \"3072\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfOTEg/MDAxNjY4NTY5NTU5Mjk2.nWatRl3QMJEHih41iFzh4fUXqkL5p3fljfu0MicYyTMg.9CGoxqyRLiNrExZrcAqwJgzqYiYtgn8DlpYwQNR1ubQg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-d4feb985-35fd-4667-b4fb-071277b31607\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7ba06640-dcf2-4684-a18c-072957c0a2e5\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-5720d96b-dacd-49c3-a6b5-c3b9090be6af\" style=\"color:#555555;background-color:#ffffff;\">기본적으로 한글, 영문, 숫자를 제시하여 표현해 주고 나아가 더 특별한 기호나 타입 등을 제시하는 경우도 많습니다. 서체의 저작권이 허용되지 않을 경우에는 다른 서체를 권해드리고 있으며 꼭 그 서체를 원할 경우 서체사와의 컨택도 진행해 드립니다. (가급적 권장하지 않습니다.) 서체는 다음 사이트를 참고해 주세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-c4cd8807-62f4-4d26-a9a6-acf01fa21ad9\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-70b76580-8381-4ee0-b531-44f1d6d7cc22\" style=\"color:#555555;background-color:#ffffff;\"><a class=\"se-link\" href=\"https://noonnu.cc/\" target=\"_blank\">https://noonnu.cc/</a></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>  <div class=\"se-component se-text se-l-default\" id=\"SE-55364f51-55dd-4a2b-a784-85bb7d204cee\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e2c57461-367e-449a-b70b-52b0f62e2ea1\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-b5361841-6f0a-448b-981c-60ecedcfd5fc\" style=\"color:#555555;background-color:#ffffff;\">다음에는 더 디테일하고 자세한 사항으로 찾아뵙겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-0dd39ec2-80d7-4ca8-b19e-96338a7699af\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-1ccc5db6-18da-42da-a857-15c7e2c5dd08\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-077d342a-d2c4-4521-b98f-d83bd3c5efca\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align- se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;r