t-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-161a85c2-99c3-49b7-aea1-0e0a468bc880\", \"src\" : \"https://blogfiles.pstatic.net/MjAyMjExMTVfNzAg/MDAxNjY4NTExNjE4ODYy._GESUg7sm3xdGmiQ1N1t7Fm89mg5O0_6buGhenZuknUg.IgOoi9GfR7bmdlUueRTDz8aF4-d_rLIOrF2piJoao48g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w1\", \"originalWidth\" : \"2364\", \"originalHeight\" : \"414\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://blogfiles.pstatic.net/MjAyMjExMTVfNzAg/MDAxNjY4NTExNjE4ODYy._GESUg7sm3xdGmiQ1N1t7Fm89mg5O0_6buGhenZuknUg.IgOoi9GfR7bmdlUueRTDz8aF4-d_rLIOrF2piJoao48g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-de992c7e-60e9-4d8a-9efd-47a3989c4064\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e1c77b20-6a86-43f6-84ae-3482fb78faa6\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-a992c20f-d5fc-4131-a69f-71cf366d065c\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-e3ae1780-eb66-4530-b34f-2baf3c9cba9d\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-e3ae1780-eb66-4530-b34f-2baf3c9cba9d\", \"src\" : \"https://blogfiles.pstatic.net/MjAyMjExMTVfMTY0/MDAxNjY4NTExNjg3NzYy.CfztqB98qRkFM7nDfAkGwLDmj0WBDfuXv_NFPVhDavMg.yXze0Uo7fwhYinDm9oSXYcw-V_3S_twJdFxkMSl3RIsg.PNG.cookthedesign/1.png?type=w1\", \"originalWidth\" : \"2364\", \"originalHeight\" : \"237\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://blogfiles.pstatic.net/MjAyMjExMTVfMTY0/MDAxNjY4NTExNjg3NzYy.CfztqB98qRkFM7nDfAkGwLDmj0WBDfuXv_NFPVhDavMg.yXze0Uo7fwhYinDm9oSXYcw-V_3S_twJdFxkMSl3RIsg.PNG.cookthedesign/1.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-6c0e2c23-fc99-42ac-b47a-5a37bedaa4c2\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-578c2362-c8dd-4b1e-8c9c-c7da36574793\" style=\"\"><span class=\"se-fs-fs24 se-ff-system se-style-unset\" id=\"SE-8a0887fa-8f9c-45a7-ac2c-90c160f1391b\" style=\"color:#00b3f2;background-color:#ffffff;\"><b>LOGO Types</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8941385d-a92b-4d99-b278-b19f443b3a29\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-1137859c-b581-43b2-8771-13cee62f33f6\" style=\"color:#555555;background-color:#ffffff;\">기본적인 로고타이프를 작성한 페이지입니다. 이 CI Book은 기본적인 페이지만 작성하여 완성하였습니다. 기본적으로는 시안을 3개 제출하였으며 그중에 최종적으로 선택된 디자인을 매뉴얼로 만들었습니다. CI/BI 모두 기업의 이념과 철학을 이미지로 담는 것임에 포커스가 맞춰져 있습니다. 이 이미지 형상화는 대단히 어려운 작업입니다. 한 번에 통과되기도 쉽지 않습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1693b413-4dc2-46f5-b353-7e66e039ad53\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-10236a3c-6107-4102-95c2-a9807d6694e7\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-019b15b9-5748-445e-a08d-d6d2d12a36b3\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-00e75428-5b43-4144-a9b5-3ef199492478\" style=\"color:#555555;background-color:#ffffff;\">그래서 실제로 여러 개의 디자인 시안을 제출합니다. 그중에 컨택의 과정을 거치게 됩니다. 그중에 일정 부분의 시안료만 받고 캔슬되는 경우도 허다합니다. 그만큼 CI 작업은 거칠고 많은 공수가 들어가는 작업입니다. 다음은 캔슬된 작업의 일부입니다. 시안을 6개 제출했지만 결국 드롭되었습니다. 지인 소개라 시안 비용도 못 받았습니다.~^^</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-0277b251-2d7f-4409-a0b0-0d9aa11702f2\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-0277b251-2d7f-4409-a0b0-0d9aa11702f2\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfMTc3/MDAxNjY4NTY3ODQyOTg5.GRnA2zPdkT2pxyIQczm7JnXmBeVeslRFxos3PbwNk-cg.xIDKBBog5peKp4R_DSrsZSxhjopLQSFL6M01EBVHCGkg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png\", \"originalWidth\" : \"1183\", \"originalHeight\" : \"1801\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfMTc3/MDAxNjY4NTY3ODQyOTg5.GRnA2zPdkT2pxyIQczm7JnXmBeVeslRFxos3PbwNk-cg.xIDKBBog5peKp4R_DSrsZSxhjopLQSFL6M01EBVHCGkg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-26ed8cf4-bf1b-449d-8c66-49d093003220\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-717aaa18-d6bf-412c-b1bc-39a2bd43f8ad\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-897be3e1-8c57-4ba1-a3b6-519366e251ee\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a98684cd-4657-4d5c-84ea-7fd57fd832a5\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-289627fe-6435-458e-a466-229311f759bf\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e1e7a5a2-2cf2-48f1-b24d-beda13e02afa\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-16af6c41-d94d-48d3-b0a3-c799d1ce399a\" style=\"color:#555555;background-color:#ffffff;\">드롭이 되지 않기 위해서는 반드시 CI 작업 시작 전에는 다음과 같은 사항을 파악해야 합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ee59de65-733d-4441-a38d-3b15cce54d60\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-d5ab1205-8d46-4731-8c19-d9668151687d\" style=\"color:#555555;background-color:#ffffff;\">첫째로 고객이 선호하는 스타일입니다. 참 애매하기는 한데 미팅을 통해 반드시 파악해야 합니다. 클라이언트가 선호하는 로고의 스타일을 받을 수 있으면 더없이 좋습니다. 항상 좋은 디자인의 출발은 벤치마킹에서 시작합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-41482921-08c0-43e4-ab4b-d7a5e3312443\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-8f9ffd65-8ea4-4257-a12d-e5d80ecc3b7f\" style=\"color:#555555;background-color:#ffffff;\">두 번째로는 고객이 좋아하는 색상이나 글자체를 알면 좋습니다. 내가 좋아하는 컬러는 누구에게나 있습니다. 그것을 파악하는고 작업을 시작하는 것이 서로를 위해 좋습니다.  마지막으로 제일 중요한 것은 무난, 독특 중에 골라보라고 하고 있습니다. 디자인의 호불호에서 가장 판가름이 되는 것은 무난한 일반적인 느낌과 톡톡 튀는 독특한 스타일의 선호 여부입니다. 이건 정말로 클라이언트 개인의 취향입니다. 저는 사전 질문지를 통해 사전 미팅 작업을 진행합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-86f7d61b-d44a-4356-b56c-023adaf1cd3c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-a29eb20f-7f85-4c72-80ea-fc7b287016ac\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fee8a574-4bdf-4c41-868e-d9f9cf5f209d\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-e636b6bf-db08-4560-afad-a354e9ee739f\" style=\"color:#555555;background-color:#ffffff;\">사전 질문지 양식은 추후에 pdf로 업로드해 드리겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2820e6fd-50fa-460e-8c04-8c61fe759a69\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-923f9d52-4f7e-491e-a23d-ed6f4f3ff3ee\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-2149be27-3d30-4b6e-93d0-a3398841d0a2\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-2149be27-3d30-4b6e-93d0-a3398841d0a2\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTZfMzQg/MDAxNjY4NTY4NDkzODM3.PzFCjMetxsc3Bpb_WMtY27n1k5pUbCIXqF3XVHxtsHog.7G8N45hse_weTmpl4sus0zW_epuYQdoPlE6MR6V4ZUwg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png\", \"originalWidth\" : \"2552\", \"originalHeight\" : \"1843\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class