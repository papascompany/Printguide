png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-image se-l-default\" id=\"SE-d28f255d-89c5-4b5a-9d9e-6ef9c7875a13\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-d28f255d-89c5-4b5a-9d9e-6ef9c7875a13\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMTlfMjU0/MDAxNjc0MTE4ODQ4OTI2.SIoP7Z2c3kuNuDoUWAdwvuQusyU_tSwytCxkkr2Lp2sg.-Z0uGdDVws35G4TyyJkXoUGDks-cneacInB79HRxOOwg.PNG.cookthedesign/image.png\", \"originalWidth\" : \"1260\", \"originalHeight\" : \"703\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMTlfMjU0/MDAxNjc0MTE4ODQ4OTI2.SIoP7Z2c3kuNuDoUWAdwvuQusyU_tSwytCxkkr2Lp2sg.-Z0uGdDVws35G4TyyJkXoUGDks-cneacInB79HRxOOwg.PNG.cookthedesign/image.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-bbcc0378-4d71-4d96-a436-d316b1ce21d5\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-c611121b-cef9-4ec5-86cd-87b90198e5ca\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-style-unset\" id=\"SE-9bb681f1-77b0-49f6-aee7-73c88aa79c04\" style=\"color:#555555;background-color:#ffffff;\">코렐드로우 프로그램으로 3시간동안 작업해서 그렸으며 저희가 제작한 고유한 디자인이므로 다운로드해서 사용하셔도 무방합니다. 본인회사의 로고를 삽입해서 카렌다를 제작하고 싶으신 분이 있으시면 언제든지 문의 주시기 바랍니다. 종이든 디지털이든 뭐든 상관이 없습니다. 무료로 만들어 드릴 수도 있습니다.  2023년 (주)파파스컴퍼니은 기버라는 마음으로 고객 여러분께 다가 가겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a9d52750-e0b6-40d7-9edc-ffa1b8043b10\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-style-unset\" id=\"SE-80212610-98c1-47f2-8c1f-23d08ee2abd3\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-53c6c658-97e9-48c8-ad91-951af93f4f3b\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-style-unset\" id=\"SE-18de0a49-911e-426f-9a68-67041e9e987f\" style=\"color:#555555;background-color:#ffffff;\">행복한 2023년 되시기 바랍니다.~</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-file se-l-default\" id=\"SE-762bdac6-b55a-424c-ad36-66d2f782ef41\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-file se-l-default se-section-align-\">\n<div class=\"se-module se-module-file\">\n<span class=\"se-file-icon\"><strong class=\"se-blind\">첨부파일</strong></span>\n<div class=\"se-file-name-container\">\n<span class=\"se-file-name\">2023 새해이미지</span><span class=\"se-file-extension\">.png</span>\n</div>\n<a class=\"se-file-save-button __se_link\" data-linkdata='{\"link\": \"https://download.blog.naver.com/open/d441c873605f5eeace27427f4aa4d3ab0e5ca285/EFsQbrdLxbbO8bULHecZiwuQG0XU6-ttY1wGJG0jyFV2dou4VXkn7fa_DYdlhS5KwhivdwHJ1xAP1oyiWJvfkz4WdSzVnI8P7Mk/2023%20%EC%83%88%ED%95%B4%EC%9D%B4%EB%AF%B8%EC%A7%80.png\"}' data-linktype=\"file\" href=\"https://download.blog.naver.com/open/d441c873605f5eeace27427f4aa4d3ab0e5ca285/EFsQbrdLxbbO8bULHecZiwuQG0XU6-ttY1wGJG0jyFV2dou4VXkn7fa_DYdlhS5KwhivdwHJ1xAP1oyiWJvfkz4WdSzVnI8P7Mk/2023%20%EC%83%88%ED%95%B4%EC%9D%B4%EB%AF%B8%EC%A7%80.png\" role=\"button\" target=\"_blank\">\n<span class=\"se-blind\">파일 다운로드</span>\n</a>\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-c518aa2c-fd41-4b79-aeb7-23733f4fb529\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr 