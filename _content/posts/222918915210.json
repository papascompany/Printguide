component se-horizontalLine se-l-line5\" id=\"SE-113a20e7-9752-4c80-b9ac-c5e4b751fcc7\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line5 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-f906950d-fbee-449c-aabb-d0b0a6e1face\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-f906950d-fbee-449c-aabb-d0b0a6e1face\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMDNfMTYg/MDAxNjY3NDczNTgzMjc3.BNFxaOzGJtlQ3PXEhW9vzrBcLFtV-EyfiKHl0nAlV-Mg.PTtyoBGdj7BDkYi7z5kHHT9ew6NmLmPUtTsUj-acI3og.PNG.cookthedesign/02_A4_4%EB%8B%A8_%EB%B3%91%EC%9B%90_%EC%82%AC%EC%9D%B4%EC%A6%88.png\", \"originalWidth\" : \"4797\", \"originalHeight\" : \"2952\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMDNfMTYg/MDAxNjY3NDczNTgzMjc3.BNFxaOzGJtlQ3PXEhW9vzrBcLFtV-EyfiKHl0nAlV-Mg.PTtyoBGdj7BDkYi7z5kHHT9ew6NmLmPUtTsUj-acI3og.PNG.cookthedesign/02_A4_4%EB%8B%A8_%EB%B3%91%EC%9B%90_%EC%82%AC%EC%9D%B4%EC%A6%88.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-91201ffe-3b39-4d45-9ab1-ea8cf142ff5b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9c25db9d-e826-4b0c-be94-2e086c2220ed\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-19d5fbd0-99ae-450f-824a-6d7ddbe6745a\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1d102425-9ef3-4489-8ce2-8cc3e7d8691b\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-2ac0ad00-73ea-4332-ae4c-8c313064eca5\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1f98ce4c-e504-4da7-a41c-9d63336259f5\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-0ced4c3b-3888-481f-9b9f-c740e7ba94a3\" style=\"color:#555555;background-color:#ffffff;\">사이즈는 동일하게 100mm씩 줬습니다. 병풍접지는 속으로 접히는 부분이 없기 때문에 4영역을 동일하게 작업을 해도 무방합니다. 세로는 국전지 조판(하리꼬미)상 200으로 작업해서 6판걸이를 했습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-3fd02a24-9833-4619-abb5-e29a58d26d12\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-3fd02a24-9833-4619-abb5-e29a58d26d12\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMDNfMjc1/MDAxNjY3NDczOTU5OTg2.UFDis5BGMmaoKDuibhCfrpq7YIicvOKHcsnD8-ECYrQg.ewvH5bUsyw8L8nB-0M_pbqaXnCbnSTuRiAE9vnf-2ZUg.PNG.cookthedesign/02_A4_4%EB%8B%A8_%EB%B3%91%EC%9B%90_%EC%A1%B0%ED%8C%90.png\", \"originalWidth\" : \"3254\", \"originalHeight\" : \"2433\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMDNfMjc1/MDAxNjY3NDczOTU5OTg2.UFDis5BGMmaoKDuibhCfrpq7YIicvOKHcsnD8-ECYrQg.ewvH5bUsyw8L8nB-0M_pbqaXnCbnSTuRiAE9vnf-2ZUg.PNG.cookthedesign/02_A4_4%EB%8B%A8_%EB%B3%91%EC%9B%90_%EC%A1%B0%ED%8C%90.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-4a92d063-f00f-4540-bc68-3f996633155e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b8e6c345-a254-400e-96be-2a95b8ee943b\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-1cb6f421-db1d-4ea7-a93b-0c2d794c59b3\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-50871976-5038-4ab8-816b-bb77dd720ce1\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-37432f4b-14a3-4d6f-b816-733601ac60ff\" style=\"color:#555555;background-color:#ffffff;\">보통 별사이즈 이건은 기본 수량이 3,000매입니다. 일반적인 아트지/스노우지 종이에 양면인쇄 후 4단접지하고 오시까지해서 잘 접히게 하면서 3,000매 제작하는것이 가장 일반적입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-36af17bf-c423-48a4-9129-a20778b8b2da\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-27cd1edd-a7c5-478f-b76e-b396e7d77e1e\" style=\"color:#555555;background-color:#ffffff;\">리플렛 디자인과 깔끔한 인쇄를 믿고 맡겨 주세요. 고맙습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-726ecad3-78db-4c8d-b089-3beb49044f96\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-6406a1cd-9ce1-4e2a-b1d8-3c7a4cbac8ab\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-a741f4ca-d927-4557-8097-db5112837cfc\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align- se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;ref=htt