NG.cookthedesign/%EA%B8%88%EB%B0%952.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f08ac18f-73cb-460c-8b6c-af58f88dcf5e\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-baf5d91f-1b48-4dfa-914a-a432c12c87ab\" style=\"\">형압/금박 목업</span></p></div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-35f38186-51b9-40d0-867c-5dd5c17ae20d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1d5d31d7-612e-44af-8806-2afb73b2dbe7\" style=\"\"><span class=\"se-fs-fs16 se-ff-\" id=\"SE-bd207be4-d676-45cc-a857-1003f6db4306\" style=\"color:#555555;\">위의 사진처럼 형압으로 누르거나 금박으로 커버를 처리하는 경우가 일반적입니다. 형압과 금박은 다음 링크를 참고해 주세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fe7916ea-fbf4-4fad-825e-db4220671326\" style=\"\"><span class=\"se-fs-fs16 se-ff-\" id=\"SE-8b7e1dd5-7157-4bf4-b885-c6dd8be681d1\" style=\"color:#555555;\"><a class=\"se-link\" href=\"https://blog.naver.com/cookthedesign/222897613505\" target=\"_blank\">https://blog.naver.com/(주)파파스컴퍼니/222897613505</a></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>  <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-0a1079c1-0d0f-48bd-b0d8-fcca8c7004d2\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-3a7ef35c-68b6-40a0-b6f9-467b2567ed37\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-62e676e6-ef48-487e-81f8-d34483da853b\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-59673eee-1f4e-4252-a1f9-616e8da4a0d0\" style=\"color:#555555;background-color:#ffffff;\"><b>무선제본 (Adhesive Binding)</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-f4ccb194-0e06-4c30-8f95-d7a24842b869\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-f4ccb194-0e06-4c30-8f95-d7a24842b869\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDNfMTk5/MDAxNjcyNzM5MzU5MTg2.Xz7O_FcJZw39IlWqjEsE1BeJy21XSjvhPlBzW45ADYMg.C0dDQJV7TJ3An1vxfua8E7qJAZcKcM4o7kFkF-99MhIg.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png\", \"originalWidth\" : \"1411\", \"originalHeight\" : \"1058\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDNfMTk5/MDAxNjcyNzM5MzU5MTg2.Xz7O_FcJZw39IlWqjEsE1BeJy21XSjvhPlBzW45ADYMg.C0dDQJV7TJ3An1vxfua8E7qJAZcKcM4o7kFkF-99MhIg.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-fcb75d0a-d939-4ef0-9258-aba036eae68e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b19847d6-a1b6-422d-9a00-2f3ca897bb09\" style=\"\"><span class=\"se-fs-fs16 se-ff-\" id=\"SE-257687c3-cdb0-444d-89ca-370c56003e72\" style=\"color:#555555;\">제가 5년동안 활동했던 모임의 가이드 북입니다. 고주파로 수첩처럼 만들지는 않았고 무선제책 인쇄물로 제작하였습니다. 회원의 정보를 나눠서 페이지로 만들었고 모든 페이지를 디자인하여 제작하였습니다. 하지만 저렴하게 제작했기 때문에 템플릿화 하여 디자인을 했으며 50여명이 정보를 주는데 다소 시간이 걸려 완성까지는 한달이 넘게 소요되었던 작업입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ac903bb4-b2de-431d-a703-89622ab11ec4\" style=\"\"><span class=\"se-fs-fs16 se-ff-\" id=\"SE-6abd312c-bd5c-4744-a61e-b1578556e61a\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-0f1f63e2-7247-448a-a5d7-4c7e675bad10\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-0f1f63e2-7247-448a-a5d7-4c7e675bad10\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDNfMjE3/MDAxNjcyNzM5Njg0MDcx._vDQJyBANkYGHWY6WQ5HVbyIjX7Cm7kvFiQirC7wd2Ag.tDwaijoATo77QPr6m6BUuNoL41_o-UsETz_lRURho2Ug.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png\", \"originalWidth\" : \"1411\", \"originalHeight\" : \"1058\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDNfMjE3/MDAxNjcyNzM5Njg0MDcx._vDQJyBANkYGHWY6WQ5HVbyIjX7Cm7kvFiQirC7wd2Ag.tDwaijoATo77QPr6m6BUuNoL41_o-UsETz_lRURho2Ug.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-line5\" id=\"SE-e99d31ba-d1af-4a1e-b427-bd5ecd69ea75\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line5 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-2027008c-bf00-4349-9613-c267c1a03ca4\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-dbbb51e5-06d6-4c1f-af5a-e15848d19bf3\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-4e3a873c-03ef-4c5e-9ea4-74fe04652695\" style=\"color:#555555;background-color:#ffffff;\"><b>디자인</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-left\" id=\"SE-dd0eb0ac-1c32-4514-ba35-002444c7d943\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-1a522afc-357e-4672-a3ad-5c9dcac1ea28\" style=\"color:#555555;background-color:#ffffff;\">원고 : 각 멤버가 각자의 정보를 제공해 주셨습니다. 다만 템플릿을 만들고 여기에 맞게 정보를 달라고 요청했습니다. 템플릿으로 작업을 해야 단가와 납기를 맞출 수 있으며 디자인 일관성도 유지할 수 있습니다. 이러한 작업을 통해 약 3주간(디자인 작업만) 작업을 해서 완성하였습니다. 또한 이 작업을 발판으로 프로필명함 사업을 시작하게 되었습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-8adaa2e0-fdec-4c0d-871a-85fefff519ee\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-left\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-8adaa2e0-fdec-4c0d-871a-85fefff519ee\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDNfMjM2/MDAxNjcyNzM5OTkyMTg5.qMSWVJI5IOx5KrgkswHeinF-YYacdReFkiXsptXAOF0g.E88mNPS7Z_hwZijVpE7URdCTbH-5YJ_ckEBDp5H-Dmsg.PNG.cookthedesign/SE-8adaa2e0-fdec-4c0d-871a-85fefff519ee.png\", \"originalWidth\" : \"1820\", \"originalHeight\" : \"2552\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDNfMjM2/MDAxNjcyNzM5OTkyMTg5.qMSWVJI5IOx5KrgkswHeinF-YYacdReFkiXsptXAOF0g.E88mNPS7Z_hwZijVpE7URdCTbH-5YJ_ckEBDp5H-Dmsg.PNG.cookthedesign/SE-8adaa2e0-fdec-4c0d-871a-85fefff519ee.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-83cbd3a2-0bf6-4056-a1e0-3327847fca18\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-57a8984c-15d1-408d-9aa1-6663bfe55f9d\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-a1421b7a-c0f3-45c3-b791-ab8b2f009451\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9f166808-3ae6-4b31-a509-b4fe3ac55a16\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-2b70e21d-772f-47ca-b16c-6337238a37c0\" style=\"color:#555555;background-color:#ffffff;\">저희 블로그의 프로필명함 파트도 많이 방문해 주시기 바랍니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b64725c5-8e3d-4eff-8936-30213a2188cf\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-44163bac-4e1a-40df-878b-40aca16a0681\" style=\"color:#555555;background-color:#ffffff;\"><a class=\"se-link\" href=\"https://blog.naver.com/cookthedesign/222963013175\" target=\"_blank\">https://blog.naver.com/(주)파파스컴퍼니/222963013175</a></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>  <div class=\"se-component se-text se-l-default\" id=\"SE-659517e2-7534-4cdf-97f1-54900168e3bc\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-left\" id=\"SE-5ce8c28a-a3e7-4f41-8784-470cb489eb84\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-6b847a9c-50a6-409d-bc70-f329c2496485\" style=\"color:#555555;background-color:#ffffff;\">(주)파파스컴퍼니은 고객의 수정요청을 최대한 맞춰 작업을 해드리고 있습니다. 다만 납기와 연관되는 부분이 있어서 최소한의 납기날짜를 고민해서 수정을 최대한 도와드리고 있습니다. 납기가 급하고 교정이나 수정에 불만이 있으신 고객님은 언제든지 문의주시기 바랍니다.~</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-307686f7-ef29-4082-8caa-183ee4f1e61b\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-98b746d2-2c98-49c9-87df-4bfcc62f1e46\" style=\"color:#555555;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-38bf3e5f-8acd-4e56-84ad-49d3b6d9c9bc\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-e4db6945-f483-4f51-a203-43f61a706506\" style=\"color:#555555;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d13770e6-f7cf-47f2-b241-863165f7651f\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-95b887a9-76bb-4f01-a77c-22fbbdfd3af5\" style=\"color:#555555;background-color:#ffffff;\"><b>종이</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-left\" id=\"SE-baf3b58f-075b-4bc6-8106-19a388766bbc\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-072dc288-6e4e-4508-af6f-23840a2f79c9\" style=\"color:#555555;background-color:#ffffff;\">표지 : 아르떼 내추럴 230g</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-left\" id=\"SE-04df6898-20d6-4291-a868-1fd19bc52832\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-we