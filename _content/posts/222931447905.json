4f-ffdfe1c67fe6\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-51db49a1-6660-4f7f-9b4f-ffdfe1c67fe6\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTdfMTU5/MDAxNjY4Njg0MzA5MTU1.Wk7BLGCea_BUOE1PwRtn9lfp3M8ATzlFWLcxZJSdDUwg.aiAcTdl2EtJYTje1qsxMbQH2kkN_5L77-3EHCNF6gMUg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png\", \"originalWidth\" : \"3105\", \"originalHeight\" : \"2396\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTdfMTU5/MDAxNjY4Njg0MzA5MTU1.Wk7BLGCea_BUOE1PwRtn9lfp3M8ATzlFWLcxZJSdDUwg.aiAcTdl2EtJYTje1qsxMbQH2kkN_5L77-3EHCNF6gMUg.PNG.cookthedesign/01_CI_%EC%9D%B4%EC%9D%8C%EA%B1%B4%EC%84%A4.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-bc2c3be9-cd5e-469c-8529-56c7db2b9d86\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-e96f5b55-b318-4a1c-b43a-7a628bc2cde7\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9d8cfe11-4424-4598-8409-7acee0ab4dc6\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-style-unset\" id=\"SE-514f2d7e-8703-4af0-b652-f5d38a7404ec\" style=\"color:#555555;background-color:#ffffff;\"><b>컬러는 컨셉, 로고스타일, 서체타입과 더불어 CI를 이루는 4대 요소입니다. 결국 CI작업이란 컨셉을 잡고 로고스타일을 정하며 서체와 컬러 매칭을 통해 완성한다고 보면 됩니다. 이 작업은 많은 자료와 미팅의 결과물이기에 기업 CI작업은 많은 비용과 시간이 발생될 수 있습니다.  그렇지만 한번 정해진 컨셉과 스타일은 기업이 망할때까지(?) 지속되므로 초반에 작업을 잘 해놓으면 영구히 활용하는 도구로 쓰실 수 있습니다. 다음 테마는 그에 따른 활용입니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-aff91245-9725-4239-a810-8f70e3ed3226\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-style-unset\" id=\"SE-f61f51d6-eb7c-4736-861f-f19e8fa58783\" style=\"color:#555555;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9b25b379-bc4d-4184-a1ce-fd3b9cb8339c\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-style-unset\" id=\"SE-08186082-703c-4192-b09d-aa135ab47c46\" style=\"color:#555555;\"><b>​</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-bed7fd8a-4948-4f66-bdab-56b62705fb6e\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-bed7fd8a-4948-4f66-bdab-56b62705fb6e\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTdfNjAg/MDAxNjY4Njg0NzAxMjU3.Dzql5lilF6odsImIh_GufLCfEDPyC18zJhK52dwVtWQg.1PJ9XVmtdiR-QRzaXp7K9WVfo6Sz16z0QDqnfVyDGbcg.PNG.cookthedesign/4.png\", \"originalWidth\" : \"2364\", \"originalHeight\" : \"237\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjExMTdfNjAg/MDAxNjY4Njg0NzAxMjU3.Dzql5lilF6odsImIh_GufLCfEDPyC18zJhK52dwVtWQg.1PJ9XVmtdiR-QRzaXp7K9WVfo6Sz16z0QDqnfVyDGbcg.PNG.cookthedesign/4.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-c0a2