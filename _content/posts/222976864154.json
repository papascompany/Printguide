ge se-l-default\" id=\"SE-5d05a3e5-5243-4998-a9ea-3e1bd5f5479c\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-5d05a3e5-5243-4998-a9ea-3e1bd5f5479c\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfODgg/MDAxNjcyOTg0NDI4ODk5.ABXzl3i4vs3pL8OFVkMQtYRkcBbNw4M69E3nzA6aeTIg.dO_MWwVH6oanhyFGQY7Glrp868WsaLc0NFrcO0B7ff4g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png\", \"originalWidth\" : \"2949\", \"originalHeight\" : \"238\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfODgg/MDAxNjcyOTg0NDI4ODk5.ABXzl3i4vs3pL8OFVkMQtYRkcBbNw4M69E3nzA6aeTIg.dO_MWwVH6oanhyFGQY7Glrp868WsaLc0NFrcO0B7ff4g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-0398f49c-6e7b-4d3f-a441-2500a903b442\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-632cfb17-d83f-4fcc-9f67-676ad51c44ab\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-d930d5f7-7661-4f24-b80f-4dd65aad5207\" style=\"color:#555555;background-color:#ffffff;\"><b>1. 종이</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-7545575d-db7a-42fc-8b61-4eee27148ab4\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-7545575d-db7a-42fc-8b61-4eee27148ab4\", \"src\" : \"https://www.insper.co.kr/upload/paper/PR000000015/PC_PR000000015_1280_1.jpg\", \"originalWidth\" : \"1280\", \"originalHeight\" : \"600\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://www.insper.co.kr/upload/paper/PR000000015/PC_PR000000015_1280_1.jpg\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-78f3af34-e03d-4b70-82de-2355070fa9ee\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-d8df7c36-e8ee-40a0-a80d-12f3e486654c\" style=\"\">사진출처 : 한솔제지</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-e8607b17-53ed-40a4-94c4-30b59ee4639e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8d1fefa8-422f-4d20-a088-012feaaedc3b\" style=\"\"><span class=\"se-fs-fs13 se-ff-nanumgothic se-style-unset\" id=\"SE-38a44f4c-e0a2-4e41-9842-7fabc7ce0fc8\" style=\"color:#ffffff;background-color:#000000;\"><b>무늬지</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a90d65a1-0e1b-403f-be10-9f8c04e92efe\" style=\"line-height:1.3333333333333333;\"><span class=\"se-fs-fs30 se-ff-nanumsquare se-style-unset\" id=\"SE-38b6e966-c34c-40d2-b8ee-e19497936450\" style=\"color:#000000;background-color:#ffffff;\"><b>매직패브릭</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-eb889435-7490-45dd-b51c-d6d3b564dea9\" style=\"line-height:1.5625;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-style-unset\" id=\"SE-1362f8f0-af49-43e5-94af-0d38d738ede7\" style=\"color:#000000;background-color:#ffffff;\"><b>직물 느낌의 고급스러운 무늬지</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-deae2c34-209d-4ebc-86ee-223c3e2b9a13\" style=\"line-height:1.6666666666666667;\"><span class=\"se-fs-fs15 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-749adfd5-bbb4-442e-916c-a354f44fbca2\" style=\"color:#666666;background-color:#ffffff;\">매직패브릭은 베틀로 짠듯한 린넨 직물 질감이 특징인 그래픽용 무늬지입니다. 촘촘한 패턴과 독특한 인쇄 질감으로 자연적인 느낌으로 그래픽하기에 적합합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-d29fb603-37ee-4e1d-97ee-159cb0d526ea\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-d29fb603-37ee-4e1d-97ee-159cb0d526ea\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMjAx/MDAxNjcyOTg2MDM4OTcz.aK8q5ZllirViSnN6UsPR1Btb1u4kweiodp5cOPFT3hsg.0KIM___C4ufu2T1KP8s-TrMr7yXeY5rer-gw2RsAjGgg.PNG.cookthedesign/image.png\", \"originalWidth\" : \"1262\", \"originalHeight\" : \"193\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMjAx/MDAxNjcyOTg2MDM4OTcz.aK8q5ZllirViSnN6UsPR1Btb1u4kweiodp5cOPFT3hsg.0KIM___C4ufu2T1KP8s-TrMr7yXeY5rer-gw2RsAjGgg.PNG.cookthedesign/image.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-77823207-ba64-445c-a01d-9bffbb689e24\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-615b5114-bc96-4750-b70f-caa3d2c812a5\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-e9c75fb9-db88-4c33-bf3b-ac3f88ecafbc\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-58f73313-8238-476c-87ea-f362a2b64b26\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-6e24d56c-96eb-41b4-836f-ec7bf1214e8d\" style=\"color:#555555;background-color:#ffffff;\">종이는 한솔제지 인스퍼에서 나오는 매직패브릭지를 사용하였습니다. 쇼핑백용으로 평량이 두꺼운것도 다양하게 출시되고 있습니다. 다만 격자모양이 깔려 있으므로 인쇄하시기 보다는 박이나 형압 또는 엠보싱등의 후공정으로 작업을 많이 하고 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-28cf335c-5292-4ada-b70e-c75397d28a01\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-28cf335c-5292-4ada-b70e-c75397d28a01\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMjU4/MDAxNjcyOTg2MjMxMjM3.MtrZkuT9BxWsz-3VR6mZMfaQsuLzAddi-9CwuopJK2Mg.DIS-zBQ200AR2HS-KGoEFIH4SdLr2_eRY8I61L3CFEgg.JPEG.cookthedesign/KakaoTalk_20230106_141444382_05.jpg\", \"originalWidth\" : \"1411\", \"originalHeight\" : \"1058\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMjU4/MDAxNjcyOTg2MjMxMjM3.MtrZkuT9BxWsz-3VR6mZMfaQsuLzAddi-9CwuopJK2Mg.DIS-zBQ200AR2HS-KGoEFIH4SdLr2_eRY8I61L3CFEgg.JPEG.cookthedesign/KakaoTalk_20230106_141444382_05.jpg?type=w966\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-93664316-619d-4127-810d-ef5aa8b0bb1a\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-50181a73-ce31-4845-bccd-80be774d673b\" style=\"\">금박 10배  확대사진</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-image se-l-default\" id=\"SE-fb62ae6b-1b97-4c6d-b11d-01811d091edb\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-fb62ae6b-1b97-4c6d-b11d-01811d091edb\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfNTMg/MDAxNjcyOTg2MjMxMjQw.N3iSHlxZprycAfDU5uTs4dofYhVEbx09jpCWWNEqXG8g.sPRvyD2ob767-a8nvsaXJjKeXBCmOr2nIA13nVTSWS0g.JPEG.cookthedesign/KakaoTalk_20230106_141444382_06.jpg\", \"originalWidth\" : \"1411\", \"originalHeight\" : \"1058\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfNTMg/MDAxNjcyOTg2MjMxMjQw.N3iSHlxZprycAfDU5uTs4dofYhVEbx09jpCWWNEqXG8g.sPRvyD2ob767-a8nvsaXJjKeXBCmOr2nIA13nVTSWS0g.JPEG.cookthedesign/KakaoTalk_20230106_141444382_06.jpg?type=w966\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bbf9e721-e529-45f6-b428-a178f918f1c6\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-6953c42a-6f81-46ba-9bf8-cbcccbb51b12\" style=\"\">10배 확대한 사진입니다.</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-f60134e6-cda5-4953-b454-2bcced9897ee\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-c7224169-a958-488b-8be0-314cb3202e95\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-0aec802f-fa10-4567-833c-8ffb75003243\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-0d990d34-3cca-40ff-b85b-e8f07cbeb617\" style=\"color:#555555;background-color:#ffffff;\"><b>2. 후공정</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9a4b1b21-25da-471a-ac96-db5f229bdf22\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-bbc1f690-c8ad-40dd-8a9b-2a16075b4467\" style=\"color:#555555;background-color:#ffffff;\">쇼핑백은 로고나 기본 이미지만으로 인쇄를 진행하는 경우가 많습니다. 앞, 뒷면에 로고를 동일하게 넣고 사이드쪽에 간단한 정보를 넣는 경우가 많습니다. 아래는 4도인쇄를 하고 찢어지지 않도록 코팅처리를 한 쇼핑백입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-e402c9b4-e719-4141-bf5f-3fae6ba7248e\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-e402c9b4-e719-4141-bf5f-3fae6ba7248e\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMTY1/MDAxNjcyOTkyMDI3NjIy.koBc7FSVP-wYkKVTqy5JwM8rS0RTIWv2T-4hZnvefN4g.1kmhSr0w1etZzxwK9NemeM6Uo4Bm15fL_WufiavSc-Ag.PNG.cookthedesign/SE-e402c9b4-e719-4141-bf5f-3fae6ba7248e.png\", \"originalWidth\" : \"1366\", \"originalHeight\" : \"695\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMTY1/MDAxNjcyOTkyMDI3NjIy.koBc7FSVP-wYkKVTqy5JwM8rS0RTIWv2T-4hZnvefN4g.1kmhSr0w1etZzxwK9NemeM6Uo4Bm15fL_WufiavSc-Ag.PNG.cookthedesign/SE-e402c9b4-e719-4141-bf5f-3fae6ba7248e.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-666004b6-cacf-4bda-8e5d-ee0a8bd3abd9\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b9059e7f-d3c6-4408-bdea-2bd02bbb09f1\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-a3b4b64d-5e71-4937-ab85-d8904dc6d8e7\" style=\"color:#555555;background-color:#ffffff;\">위의 쇼핑백은 사이드에 브랜드를 넣고 홈페이지 정보를 삽입했습니다. 사이즈는 펼친면과 붙임공간을 고려한 사이즈여야 합니다. 아래에 접착면과 옆쪽에 붙임면을 고려한 사이즈여야하고 종이 사이즈에 잘 맞춰야 버리는 종이가 없이 낭비되지 않습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-50a90434-ca89-4b94-b844-eaf449fb3755\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-feaadfb2-ab98-4741-825f-715637287428\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-feaadfb2-ab98-4741-825f-715637287428\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMTAg/MDAxNjcyOTkyNzI0Njcx.aLzspk5fBo81hss3nhWresL4IsBncx2Hp4jF8hXmzsog.pLN7Q3CAZZLEk_wYEjEnU-RE-WtKTXRpRhaktpsurA8g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png\", \"originalWidth\" : \"1867\", \"originalHeight\" : \"1477\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMTAg/MDAxNjcyOTkyNzI0Njcx.aLzspk5fBo81hss3nhWresL4IsBncx2Hp4jF8hXmzsog.pLN7Q3CAZZLEk_wYEjEnU-RE-WtKTXRpRhaktpsurA8g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-7c3dcd9c-414b-440b-97bf-4ade2c1558c2\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-192e0a3d-45fd-4c6f-878f-f5dca208b63a\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-ff60cc63-5a8b-4d68-858e-28170dd5803e\" style=\"color:#555555;background-color:#ffffff;\">하단에 접착면이 터지지않고 제품을 담았을 때 균형을 맞추기 위해 두꺼운 마분용지를 삽입하여 마감을 합니다. 마닐라지는 쇼핑백과 제품 보호를 위해 삽입한다는 뜻입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-4db1cf72-3e2e-489a-8eba-7c13b27085cf\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-66a8da30-b491-4ea5-912d-1e37c9afa746\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-66a8da30-b491-4ea5-912d-1e37c9afa746\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMjkz/MDAxNjcyOTkyODQxNjIz.S2RyvzaQjDsW6jpxm_rU-M78625ib-kwlqGxGZBObjog.TsYxQB57gnxkK3SUZwxFxpjrTr0iTXpBR_6qSE5diN4g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png\", \"originalWidth\" : \"1867\", \"originalHeight\" : \"1477\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfMjkz/MDAxNjcyOTkyODQxNjIz.S2RyvzaQjDsW6jpxm_rU-M78625ib-kwlqGxGZBObjog.TsYxQB57gnxkK3SUZwxFxpjrTr0iTXpBR_6qSE5diN4g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-f21096b9-226f-429e-82fc-ff727980b213\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ea5b2c05-7abf-4115-b70a-1c90b7047ffc\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-3c5496ee-dcfb-46cd-8358-29c5caca19d3\" style=\"color:#555555;background-color:#ffffff;\">철핀을 끼우는 이유는 끈이 떨어지지 않게 하고 마감을 더 고급스럽게 하기 위함입니다. 기본적으로 철핀없이 묶어서 마감하는것이 일반적이지만 철핀에 아일렛까지 장착하면 더욱 고풍스럽게 끈 부분을 마감할 수 있습니다. 물론 접히는 타공 부분에 위의 마분지를 넣어서 보호하는것이 기본입니다. 지금 가지고 계신 쇼핑백의 끈 타공부분을 뜯어 보시면 안쪽에 마분지로 마감되어 튼튼하게 처리된것을 보실 수 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-508a6dd3-1e0c-492e-ad3c-ced32e7869ab\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-6c88fa31-1c02-4020-b620-25b65443de23\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-6c88fa31-1c02-4020-b620-25b65443de23\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfNTUg/MDAxNjcyOTkzMjA4MTc3.53whKMfA6pW5mbHkPNw-eSn5TD9SRW_kWXjgtIc9_cwg.HGxJMSp10hVkBJi6zFH0fttyeBXDfTxG5XCjuxheBw8g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png\", \"originalWidth\" : \"1867\", \"originalHeight\" : \"1477\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMzAxMDZfNTUg/MDAxNjcyOTkzMjA4MTc3.53whKMfA6pW5mbHkPNw-eSn5TD9SRW_kWXjgtIc9_cwg.HGxJMSp10hVkBJi6zFH0fttyeBXDfTxG5XCjuxheBw8g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-77a109b9-4ba8-429a-a32d-829b319991cb\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-cec2d7b7-409e-4c64-aa65-d6a66d2a8430\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f1d8d4ba-bbbc-4912-9311-44dd38586838\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-cfe01d95-7826-4c27-a860-abaabe0c2636\" style=\"color:#555555;background-color:#ffffff;\">쇼핑백은 고객을 향한 회사의 이미지입니다. 기본적인 용도로는 물건을 담는 용도지만 회사의 제품을 담아 회사의 이미지를 전달하는 홍보상품이기도 합니다. 여기에 돈을 투자하는것은 물론 고객의 판단입니다. 가장 저렴한 종이를 사용할 수 도 있지만 화장품, 쥬얼리등의 고급스러운 제품을 취급하는 회사는 쇼핑백도 화려하고 고급스럽게 제작하는 추세입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7c38ca15-6033-47ea-8568-834bdb5b4645\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-31b39427-21c6-4e54-847d-4385ce86caf0\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-122b947f-c726-43c8-9e86-5bd8c0ed95ff\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align- se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;ref=https%3A%2F%2Fm.blog.naver.com%2Fcookthedesign%2F222976864154#nafullscreen\" onclick=\"sendClickNlog('pst.talktalk', '');\">\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n</a>\n</div>\n</div>\n</div>",
