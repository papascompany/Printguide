f0dbcf7\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-20c5e3a2-8398-4373-ab65-22a1f7d9cc52\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-b3768e8f-f91b-41f6-bb69-8f94f0295f5b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-c8b81bba-cc9b-4ab7-8fe0-a0d6edc05952\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-5d05a3e5-5243-4998-a9ea-3e1bd5f5479c\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-5d05a3e5-5243-4998-a9ea-3e1bd5f5479c\", \"src\" : \"https://blogfiles.pstatic.net/MjAyMzAxMDZfODgg/MDAxNjcyOTg0NDI4ODk5.ABXzl3i4vs3pL8OFVkMQtYRkcBbNw4M69E3nzA6aeTIg.dO_MWwVH6oanhyFGQY7Glrp868WsaLc0NFrcO0B7ff4g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w1\", \"originalWidth\" : \"2949\", \"originalHeight\" : \"238\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://blogfiles.pstatic.net/MjAyMzAxMDZfODgg/MDAxNjcyOTg0NDI4ODk5.ABXzl3i4vs3pL8OFVkMQtYRkcBbNw4M69E3nzA6aeTIg.dO_MWwVH6oanhyFGQY7Glrp868WsaLc0NFrcO0B7ff4g.PNG.cookthedesign/30_%EC%82%AC%EC%9D%B4%ED%8A%B8%EC%84%A4%EB%AA%85_221112.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-1177255f-8216-4ce3-b39d-3bb9fb2305ae\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-02f89510-4817-417b-b720-5399ee1af999\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-style-unset\" id=\"SE-4749b8a4-cf58-42b3-a83b-e77888599414\" style=\"color:#555555;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ef205514-ed2c-47ab-8401-3e294b1dd967\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-style-unset\" id=\"SE-00f224c5-b4e5-4343-8581-81e634380038\" style=\"color:#555555;background-color:#ffffff;\"><b>1. 견적서 표지</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e5b00ff4-6d3b-42d6-8680-b187b20e836f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-6c430bad-31f5-4027-8c4d-8cd02d8698d7\" style=\"color:#555555;background-color:#ffffff;\">예시 이미지로 올렸던 견적서 표지를 디자인합니다. 디자인이 컨펌되면 인쇄물로 제작합니다. 인쇄물은 고객과 상의해서 종이와 수량을 정해서 별도로 제작됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fd004d22-d582-47ad-9bd1-bb474d04ac8c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-293e50a2-e51a-4325-bb7b-2816d235a952\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9352a6a3-bc6a-4856-9407-5e37b0c9b40d\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-style-unset\" id=\"SE-cb6118c0-c60c-4858-9aba-d6d79f89caef\" style=\"color:#555555;background-color:#ffffff;\"><b>2. 동봉 리플렛</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3b611bb1-d4c2-4cf2-9eb0-6b70fffd9320\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-702fd0e6-1ee8-4a3d-b762-f4edff07945a\" style=\"color:#555555;background-color:#ffffff;\">견적서나 지명원을 제출할 때 함께 동봉하는 양면 리플렛을 제작해 드립니다. 종이를 조금은 고급스럽게 제작할 수 있고 저렴하게 제작해서 수량을 많이 제작할 수 도 있습니다. 요즘은 디지털인쇄의 발달로 소량인쇄도 가능합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8843d4f5-869e-4bef-a8a8-0f98e762091b\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-7d52805c-22b3-4f26-a4c1-987e910f2acc\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4b15fbf2-9bf5-4f78-ba5d-2a958a97826b\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanumsquare se-style-unset\" id=\"SE-1a952876-e406-465a-a260-9cd187939874\" style=\"color:#555555;background-color:#ffffff;\"><b>3. 지명원</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d8a251db-874b-41b6-bf83-c966379590d2\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-f3396bff-2b68-46e5-8a35-f0e1303bf9b2\" style=\"color:#555555;background-color:#ffffff;\">건축에서 턴키로 작업되는 지명원은 회사의 정보를 고객에게 제출하여 비딩경쟁을 하기 위한 자료입니다. 이 지명원 작업이 전문입니다. 이 지명원은 다음에 기회를 보고 연재하도록 하겠습니다.~</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bc3d473c-79a4-4d95-8cf8-dcc0be56616c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-bf0dbc24-6c7a-4800-94e3-a902e47691ec\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-6a31e37f-ee20-44cd-a395-4846ec13b3ff\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align- se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;ref=https%3A%2F%2Fm.blog.naver.com%2Fcookthedesign%2F222985838512#nafullscreen\" onclick=\"sendClickNlog('pst.talktalk', '');\">\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n</a>\n</div>\n</div>\n</div>",
