3-43a0-8a75-5af970da3147\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-50ed9aaf-24a3-43a0-8a75-5af970da3147\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTA2MTVfMjMg/MDAxNzQ5OTU0NjUzNDI3.aQgXZRUDtT3lzJTMduuTxtAbNFd6ZS3Hk_1k4iJhp2Yg.XQArAoVXey9xv3XpNnUcG746ZOGzRy7atgLHi8D8w6sg.PNG/2.png\", \"originalWidth\" : \"1575\", \"originalHeight\" : \"1181\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTA2MTVfMjMg/MDAxNzQ5OTU0NjUzNDI3.aQgXZRUDtT3lzJTMduuTxtAbNFd6ZS3Hk_1k4iJhp2Yg.XQArAoVXey9xv3XpNnUcG746ZOGzRy7atgLHi8D8w6sg.PNG/2.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-d7a24026-5bb4-403f-ad51-ae109dedf70b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-78a5ba10-3c17-4380-92a0-171a7dc18289\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7976c978-5c11-471b-bf91-7b294e5ec7ba\" style=\"color:#555555;\">슬리브 트레이 박스는 트레이(Tray)를 감싸서 보호하고 많은 정보를 디자인하여 담을 수 있습니다. 여기에 이미지나 사양, 고객센터 등의 정보를 인쇄하여 포장 용기로서의 하나의 부자재로 활용할 목적으로 제작됩니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-a755393f-3add-465e-9da7-0db74167b29b\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-a755393f-3add-465e-9da7-0db74167b29b\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTA2MTVfODMg/MDAxNzQ5OTU1OTAxODUx.G6BksqZL2NpVLCl2xM7fvB_tqxB6wXyHFhv5UcTU2Igg._MChUjmrRRfpukhuF8uo7Vda3CoZdWdvazEpVmJY8VAg.PNG/1.png\", \"originalWidth\" : \"1183\", \"originalHeight\" : \"828\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTA2MTVfODMg/MDAxNzQ5OTU1OTAxODUx.G6BksqZL2NpVLCl2xM7fvB_tqxB6wXyHFhv5UcTU2Igg._MChUjmrRRfpukhuF8uo7Vda3CoZdWdvazEpVmJY8VAg.PNG/1.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-2314ec50-b031-4d22-b434-7ae0da7300e8\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3559974a-81fb-495d-bc5c-84d255619d71\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-5ec0fb69-7b08-43b5-8a15-5d765c9b82d3\" style=\"color:#555555;\">위 이미지처럼 기본으로 오시가 5줄 삽입되고 하단에 접착면이 있어 접착을 하게 됩니다. 이때 중요한 것은 크레이에 딱 맞게 제작되는 것입니다. 이를 위해 반드시 본사로 트레이를 보내주십시오. 이 트레이를 보고 맞춤 목형을 제작해 드립니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d1325d6f-651d-4fee-8200-032f6b7e1306\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-cdbe4d3b-930a-44fc-bcf1-288a7f272f5a\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9ef87702-33a3-4f60-ae73-2293ba688a8b\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b520e15f-0550-4abf-830e-563909d428c5\" style=\"color:#555555;background-color:#fdd5f5;\">길이를 정확히 측정하거나 기존에 제작했던 폭과 길이를 알려주시면 좋습니다. 신규 제작이시면 반드시 트레이를 보내주십시오.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a5fe23c6-3a93-40a3-a1ad-a3384ec44384\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-358e6d8c-d31a-4f91-bceb-a8d824a7d2d8\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f860c74f-ae40-44fd-ba5a-a882640cc9d6\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-f8ada5db-bd11-46cf-a3f4-71e99d235290\" style=\"color:#555555;\">높이를 측정하실 때 약간의 오차로 인해 슬리브가 헐겁거나 빡빡하게 제작될 수 있습니다. 또한 종이의 두께에 따라 달라질 수 있기 때문에 반드시 디지털 샘플을 미리 만들고 본 작업을 하시기를 추천드립니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-870b5aa1-56b3-462e-8a9a-3506312260e0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8de60092-81be-4824-a0d9-bb6a1fccdbc6\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-123eff6a-c360-4070-ab7d-b9c46a477fc8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-92f08389-aff4-49c9-b711-bba3f2e301a2\" style=\"color:#555555;background-color:#bdfbfa;\">(주)파파스컴퍼니은 본 작업 발주가 체결되면 사전에 디지털 인쇄로 샘플을 만들어 트레이에 맞춰봅니다. 만약 요청하시면 디지털로 제작하여 샘플을 만들어 직접 맞춰 보면서 본 작업 전에 확인하는 것을 진행해 드립니다. 참고하세요.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-bf332c35-4b40-4c4f-9d50-924eebbb7be0\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-cd66de87-80e9-407f-b3de-67610df16e4d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5c36a60a-174e-4481-9301-8f31a0331c31\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-6e2500d8-cbb2-49a5-95f8-12ff47072081\" style=\"color:#007aa6;\"><b>슬리브 띠지</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-022c17d4-655d-457a-a267-3d9db6cae32d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-d2afc663-079f-4048-b23d-0f21fa5b7f72\" style=\"color:#007aa6;\"><b>​</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-5364f15e-37f7-4c37-8412-45cc258e1f4d\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-5364f15e-37f7-4c37-8412-45cc258e1f4d\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTA2MTVfMjYx/MDAxNzQ5OTU2NzQ2ODM1.iqHNQbDn-M07GIfhDVrhrB0iS7Q5YzLAeyORKmHeR0og.tRymTVBTNKR1xfzSqHP52wpdhWfbSAsWo2al7eA3wCQg.PNG/4.png\", \"originalWidth\" : \"1575\", \"originalHeight\" : \"1181\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTA2MTVfMjYx/MDAxNzQ5OTU2NzQ2ODM1.iqHNQbDn-M07GIfhDVrhrB0iS7Q5YzLAeyORKmHeR0og.tRymTVBTNKR1xfzSqHP52wpdhWfbSAsWo2al7eA3wCQg.PNG/4.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-744da896-1930-47e6-8c0f-ff98d607cd6d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7c4bf118-9818-4282-8642-d8b3b37912b0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-395db3c6-903a-4c46-9186-ccd49426b3b7\" style=\"color:#555555;\">띠지는 윗면과 특히 측면을 많이 감싸지 않습니다. 띠모양으로 연결하는 것이 역할이므로 측면 쪽에 디자인이 삽입되지 않는 경우가 많습니다. 손목 띠지처럼 트레이를 감싸는 용도라고 보시면 됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-0d12383b-6b19-416d-a0d0-619e9c405a14\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8bcdabe3-1a9b-4c08-85c1-1ec78ccbb022\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bbb82837-ab5d-4f92-913f-800607a31d56\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-afbef2d9-0246-43ee-adfd-d12f21f0c91d\" style=\"color:#555555;\">이런 이유로 윗면에 원형이나 타원 또는 특별한 모양으로 도무송(톰슨)작업을 하는 경우가 많습니다. 특히 원형으로 제작되어 모양을 살리는 경우가 많습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-ea4f7f43-abf6-4241-a78e-304c7ab3692c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bba62a6e-ad59-4ca5-a807-401a65f6ae0f\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-3d56a22b-1dc4-4fe4-9f77-7b0ca8462a82\" style=\"\">기본 사양</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-06f2817c-95c0-48e5-b90c-9526e70f576c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-40e7c809-edda-448d-9789-34cda59b4bfd\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-d0be93d2-6ed8-42bd-8f26-8ab104cfddc1\" style=\"color:#555555;\"><b>종이</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-bd1eae15-b0da-414d-a836-680d7f45d376\" style=\"color:#555555;\"> : 일반지나 고급지 또는 크라프트지 등 다양합니다. 종이 제약은 없습니다. 다만 평량은 너무 얇지 않은 250g 이상의 종이 평량을 많이 선호합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3773b878-4b5f-48dc-8144-a86871718f93\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2cd5b094-f307-4517-b4e5-d37b8da84dfa\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-06bcddfc-8caf-4c47-95ce-111f544c561c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-1f15c9a7-16d5-4246-88be-3a65f59b442e\" style=\"color:#555555;\"><b>인쇄</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c22a5168-33ea-4790-9130-1b0b116e5d85\" style=\"color:#555555;\"> : 인쇄는 오프셋이 기본입니다. 그러므로 CMYK 기본 인쇄와 별색인쇄도 가능합니다. 다만 디지털 샘플 제작 시에는 제약사항이 발생합니다. 참고하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f8d09c7b-613e-44eb-af32-9b92b036c6e2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a281a96a-0a2b-442f-b0e4-c32a8ead8120\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b885b4a7-3f24-4475-a083-70735230d0cc\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-e6e6551f-b8db-4905-b593-29dcb92b2051\" style=\"color:#555555;\"><b>후공정</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-9259c94d-554f-4d61-92d4-d66c665cfa76\" style=\"color:#555555;\"> : 코팅이나 톰슨은 선택이자 기본입니다. 통상 누름선을 넣기 때문에 뜯김이 발생되지 않으려면 코팅처리가 기본입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2d94dfda-fa2a-499d-a2c6-89f62c0c1287\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6c470218-11a1-4344-b86d-e4378d10eb98\" style=\"color:#555555;\">또한 소량 샘플용이 아니면 목형 +  도무송작업이 기본입니다. 재주문 시에는 목형비가 차감되므로 참고하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1398a91b-2861-4f5d-beca-432d4fc8cb35\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-1628c21d-fbe9-4738-8545-93c8c902e135\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-354ebb1a-d988-4265-929f-73d1035740d4\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-73b26fb1-d477-4d7e-af60-06f7fa1313f0\" style=\"color:#555555;\"><b>수량</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-47eaa140-2701-4a25-ac1a-89e7dd6217ec\" style=\"color:#555555;\"> : 수량은 50개에서 5,000개까지 다양합니다. 50개는 디지털로 제작됩니다. 개당 단가는 올라갈 수 있으니 참고하시기 바랍니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1e27798f-80f8-494f-8a6e-7f7d6c78b7a3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-35df9d0b-0fab-46ce-92f6-a2ffbe562117\" style=\"color:#555555;\">200개 이상 주문시에는 오프셋으로 제작될 수 있습니다. 오프셋 제작이 컨펌되면 사이즈와 종이, 또는 인쇄 등의 제약 사항이 없으므로 자유롭게 제작할 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9081b713-884e-4c7e-9c58-23bdbdb53698\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-bfc2f350-48cf-4793-9aca-c20da2b8f95d\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-420100f2-4f84-4bb5-9659-5179a8dc8dee\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-9050e285-1713-467c-8ef7-dc55ff4dfb88\" style=\"color:#555555;\"><b>용도</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7d4c4848-8ed1-4275-8e0a-7a3980812095\" style=\"color:#555555;\"> : 슬리브나 띠지의 용도는 도시락이나 밀키트 판매용으로 제작됩니다. 소량 생산도 가능하므로 반드시 경험 있는 업체와 상의하여 제작하시기 바랍니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-87f4cf3c-2a06-4079-9fd8-c77d91779652\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d3941d6e-85a1-43ca-abac-7f44e208a6b1\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-000312b8-59bf-4a68-83fb-57c96b7536b6\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-4ab9653d-427b-4100-8ad9-38806d71f207\" style=\"color:#555555;\">□ 도시락</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-73452eba-3d6e-40ad-b3df-ae15d9368b3f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-43b70de9-c840-4385-8dec-37572098313f\" style=\"color:#555555;\">□ 밀키트</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-dfab38b5-1fd3-4ca8-9cc0-1b98ef06256f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-f36fc9f5-ade6-44f7-b605-ed35dfdbecb5\" style=\"color:#555555;\">□ 정육/생선/과일</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7bea7cd4-99d8-4ec8-bb43-7e636e7a5daa\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-15adf80a-8b16-4957-8d1f-86faea908879\" style=\"color:#555555;\">□ 선물용</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6b8d7076-25ec-456d-b904-080230c6466e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-f5d2e2d0-bb1f-4460-8c21-4f7e7deb2ba1\" style=\"color:#555555;\">□ 명품 등</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6b6494cc-6dc8-4a99-9061-effc77e0d318\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-108b3568-1c24-4c94-b22a-050117f63d22\" style=\"color:#555555;\">□ 쇼핑몰 소량 판매</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-18d1353d-9203-474d-9dc3-5821a152f9b2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c0375fc2-c50a-4caf-bf55-d0f08ac6051e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-bf418dfb-8b00-427f-bb49-dd7a666dcc91\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-52d289ac-8dd2-430d-b4f5-76c0e492e56c\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-c4d25a55-69b2-41a4-a2fb-339b4da8bffc\" style=\"\">디자인을 대행하여 드립니다.</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-c2ba72aa-7426-4e31-9b91-d050e49ce3db\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d3b3a226-c256-4c62-953f-7778d2270981\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-50ae1f99-ecca-49bf-a896-a28035d9e1c4\" style=\"color:#555555;\">(주)파파스컴퍼니은 다양한 경험을 가진 디자이너가 제품에 맞는 디자인을 대행 제작하여 드립니다. 디자이너가 없으신 신규 쇼핑몰 업체는 디자인까지 문의하시면 상담해 드립니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-dba825ca-f564-40ec-abe5-96bbb80c4401\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e524b644-c6b5-458f-9584-435d93aa9399\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-84a52edf-1cd9-45c3-8f95-6102e947473a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-54bb0eeb-e95c-4bc6-9f64-6692f11ff56f\" style=\"color:#555555;\">가장 합리적인 디자인 비용을 제안 드립니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8a893e5f-0a6c-4c83-8232-f6b4afa6e3e9\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-339ab71d-0559-49e5-8a3d-620d0642b02e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-53910440-e932-4d17-80ef-bd87a85f4fb8\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align-center se-l-default\">\n<a class=\"se-module 