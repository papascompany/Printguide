be-bba5fe4edc3e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-99e893dc-6bb2-424c-9cb2-b3a4a4afcfd6\" style=\"color:#555555;\">아크릴로 간판이나 안내판을</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-c8af708c-ac3c-4a16-9e7d-5aa4f3dd5c54\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-1b8c58c8-2d7d-43e2-b238-3242a5f97677\" style=\"color:#555555;\">제작할 때 다음 사항을 주의하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-7572c721-11a9-4427-b55e-68cc57bdc426\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6727e613-838f-4055-b911-c99fab65a269\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2411fd92-2022-47a5-8da8-d4b4b66d5eb2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-345b30b5-7bf9-4fd6-a8f0-c68349c425d7\" style=\"color:#555555;\"><b>아크릴 바탕색</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-90f1c96c-339d-4ce4-b0b0-1afd405877c0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8aa469aa-3ebe-42c7-a503-a3a43ca2eb4a\" style=\"color:#555555;\">아크릴 바탕이 되는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-ae6995f3-a4da-472e-977f-2154148b5004\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e1ad93ec-7eff-4330-9a95-46b0db4c9f95\" style=\"color:#555555;\">본체(?)는 색상이 제한되어 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-6149e89a-ca82-43c8-9e49-dc33c79e5e2b\" style=\"lin