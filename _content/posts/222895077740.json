94361ddd91d\" style=\"color:#666666;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2f01cdab-4f09-43c0-983e-7941d3a1647e\" style=\"line-height:1.5384615384615385;\"><span class=\"se-fs-fs13 se-ff-system se-style-unset\" id=\"SE-8bcd7dc7-cf32-42b7-9901-d27c2dd2b4bf\" style=\"color:#000000;background-color:#ffffff;\"><b>3. </b></span><span class=\"se-fs-fs13 se-ff-system se-style-unset\" id=\"SE-d8a010b7-e67e-47c7-8a05-76bfabef36f2\" style=\"color:#888888;background-color:#ffffff;\"><b>정보·통신</b></span><span class=\"se-fs-fs13 se-ff-system se-style-unset\" id=\"SE-aa49d01c-6c12-4360-94e3-355ad41a488e\" style=\"color:#000000;background-color:#ffffff;\"><b> 표시 화면상에서 나타나는 한 화면 분량의 데이터.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-4c86ea9e-49ac-4876-84fc-708129177ed2\" style=\"line-height:1.5384615384615385;\"><span class=\"se-fs-fs13 se-ff-system se-style-unset\" id=\"SE-d9ee96b4-9e54-4954-a20c-c002f3811269\" style=\"color:#000000;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-f4d1d558-dfc8-498c-a478-ae284eddcb25\" style=\"line-height:1.5384615384615385;\"><span class=\"se-fs-fs13 se-ff-system se-style-unset\" id=\"SE-8e706cf0-ca20-45e0-a010-f610cb0761a5\" style=\"color:#000000;\"><b>​</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-10a9bf74-3f79-4b34-bf13-8109b442fbca\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-10a9bf74-3f79-4b34-bf13-8109b442fbca\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMjE3/MDAxNjY1MjA2MTAxMDIy.rQMwX-FvAswWAFhu7U4xke2iljURYDW8Qzz7tSd9NOog.uXLsLmMVW84sYO-lHo_ocwBIk0UB_Nmg2WWz-Zu1pqQg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png\", \"originalWidth\" : \"1536\", \"originalHeight\" : \"946\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMjE3/MDAxNjY1MjA2MTAxMDIy.rQMwX-FvAswWAFhu7U4xke2iljURYDW8Qzz7tSd9NOog.uXLsLmMVW84sYO-lHo_ocwBIk0UB_Nmg2WWz-Zu1pqQg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-39147fdc-eb38-4069-a698-23e7a0af9426\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-90ed8b83-a202-40ab-b907-68b7cbd41e86\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-b1b7704d-b328-4804-bee7-5870a1d10b5a\" style=\"color:#000000;background-color:#ffffff;\">종이는 양면으로 구성된 제품으로 33페이지라는 홀수 카다로그란 없습니다. 책자나 모든 인쇄물은 짝수로 페이지가 구성되며 그를 꾸미는 방법은 한장의 종이를 재단으로 사이즈를 맞추는 방법과 여러장의 종이를 홋대서 중철이나 무선등으로 제본을 하는 책자형태가 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-9b8ff2e3-8cc2-4da7-a29b-4f64ab5c44fd\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-f9131610-7043-4b97-859a-6a9e77c6c8d1\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-f680c0fd-3a64-4129-ab30-4d3652ec2327\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-138e42ef-8f34-4d33-b8b2-518aaa2c7638\" style=\"color:#000000;background-color:#ffffff;\">(주)파파스컴퍼니은 낱장형 인쇄물과 책자형 인쇄물로 구분하겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-7eb375bb-c91c-4dc3-ba7b-7fdab299d8a4\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-46615499-b8fa-498a-bb7f-a3385a9487af\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line2\" id=\"SE-61e09b5a-7b65-4be5-b0ec-a94053fb9a2c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line2 se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-4da0799a-fbdb-4eae-8f2d-2d03b5c226cb\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-51a6a92a-673c-42ac-a5e2-29cf5e988255\" style=\"line-height:1.8;\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-a07b87c8-6b3b-4f14-88cc-e31b2d8ab1c8\" style=\"color:#000000;background-color:#ffffff;\"><b>낱장형 인쇄물</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-900a3102-3f36-4694-b29d-9acc9d5591fd\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-954f19a9-f543-4897-bd06-ee4687a73cff\" style=\"color:#000000;background-color:#ffffff;\">낱장형 인쇄물은 한장의 종이를 짜르거나 접거나 따거나 하는 방법으로 모양을 꾸미는 인쇄물을 말합니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-03161819-fdd4-46a6-83e2-92e1d70eb224\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-0960a5e6-93a5-4e6a-a79f-36a97516b6ae\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-a2601f1b-7856-4c44-b7a1-1056eac588d7\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-a2601f1b-7856-4c44-b7a1-1056eac588d7\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMTQw/MDAxNjY1MjA5Nzg2MjI0.9XZgyVyt3gA9RHto7whY6NgmUfqDB7gay3iidK4CpNMg.3SiP5cCuAnS0aQMgqSdwVS0_6k2hynvHVLmcukus8zwg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png\", \"originalWidth\" : \"4135\", \"originalHeight\" : \"1832\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMTQw/MDAxNjY1MjA5Nzg2MjI0.9XZgyVyt3gA9RHto7whY6NgmUfqDB7gay3iidK4CpNMg.3SiP5cCuAnS0aQMgqSdwVS0_6k2hynvHVLmcukus8zwg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-4ab25767-5986-4842-be2a-a269eda4c85a\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-a078848d-2205-47c7-ae03-8512535c5f87\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-79f0a199-30b3-47c7-accb-1c4513cb96e2\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-0c44548e-4bdf-4b30-99e0-7827bccef023\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-9d4c7051-8ae6-4144-8a07-3fcc2b069a32\" style=\"color:#000000;background-color:#ffffff;\">한장의 종이를 변형해서 만드는 인쇄물입니다. 변형의 방법은 여러가지가 있습니다. 그냥 재단할 수도 있고 접을 수도 있고 도무송(톰슨)으로 모양을 딸 수도 있습니다. 이 변형의 방법은 후가공 설명 페이지에서 자세하게 설명하겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-4a0d68e8-e8c5-4985-90e4-3f51b35d6bfb\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-f20d4579-0da0-42ea-b42c-5da2935f8bad\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-ee7272e9-f535-410d-8b29-f0d7b7b2f933\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-fe8f1bc7-cffb-4129-be9e-9a3cd120a98b\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line2\" id=\"SE-208433c0-89ed-4ed3-88c8-3af0b6447f6b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line2 se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-c06224d5-69a2-4d2e-8582-fd8ebd67112b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-eac38700-b4b4-44b7-9154-10bd90286512\" style=\"line-height:1.8;\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-b2dbf77e-2d4b-4fc5-bdc5-f77dc4971c69\" style=\"color:#000000;background-color:#ffffff;\"><b>책자형 인쇄물</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-42df52c3-0414-4626-a23e-499e9eba6be5\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-2b627d14-0440-4403-9f66-c87cc6256e18\" style=\"color:#000000;background-color:#ffffff;\">책자형 인쇄물은 여러장의 종이를 겹쳐서 묶어 꾸미는 인쇄물을 말합니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-f0527a87-b397-4e82-b8f7-809a1778c69c\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-a9364a8b-759e-4b35-b1fd-552badb5f50c\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-87a37f15-c79c-4d69-b279-eac79c20f63d\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-87a37f15-c79c-4d69-b279-eac79c20f63d\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMTY3/MDAxNjY1MjEzMDU4NDY5.q85WvzUyMTxL-iplkMT6_nD0MuDNkvKe_kINIQIOFgAg.ArGheCqN85kxNabM6E2052_GnQ0a3Iz9Dv49g6er9ssg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png\", \"originalWidth\" : \"4135\", \"originalHeight\" : \"1832\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMTY3/MDAxNjY1MjEzMDU4NDY5.q85WvzUyMTxL-iplkMT6_nD0MuDNkvKe_kINIQIOFgAg.ArGheCqN85kxNabM6E2052_GnQ0a3Iz9Dv49g6er9ssg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-34142627-952e-4062-9355-bbd7f2ed8e22\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-29f092fb-8abe-45fe-8cf6-19bc913a27a7\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-7562f6a2-c9fe-44a3-b574-918fee6e3a4e\" style=\"color:#000000;background-color:#ffffff;\">책자형인쇄물은  여러장의  종이를 홋대서(겹쳐서) 만드는 인쇄물입니다. 이 변형의 방법 또한 여러가지가 있습니다. 중철제본, 무선제본, 양장제본등으로 구별할 수 있으며 우리가 흔히 보는 책들의 상품을 말합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-715da84b-3640-4fa1-82f6-8bf89ca2fefc\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-1bccbba9-6e26-4142-8098-a79f58be266d\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-be5511f1-2005-47eb-b0d4-7eea6a4985e0\" style=\"\"><span class=\"se-fs-fs24 se-ff- se-style-unset\" id=\"SE-273e8b6b-247f-42ef-aa65-eae26bbe58ea\" style=\"color:#555555;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a9294912-fc3f-4e7b-8d16-f41a552be883\" style=\"\"><span class=\"se-fs-fs24 se-ff- se-style-unset\" id=\"SE-a674fe7e-f95c-41e7-ab28-ae0e406c4966\" style=\"color:#555555;\"><b>​</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-9a4f8a95-ce2c-4b64-a791-cb49cae33913\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_line\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ceba6ac3-508e-4fe1-8348-64814dfb8f6b\" style=\"\"><span class=\"se-fs-fs24 se-ff- se-style-unset\" id=\"SE-e678bcd6-62e3-40d2-84e8-f606944a8df7\" style=\"color:#555555;\"><b>사이즈에 대한 설명</b></span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-94ae06d6-5b31-4a8e-8e97-6ee6e9e96d96\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-da8c8ec0-ed0c-471a-b5a2-1d1b9ac577a5\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-857c21b4-ee8e-4d53-a01d-bb9e91b4f58b\" style=\"color:#000000;background-color:#ffffff;\">사이즈는 규격을 말합니다. 우리가 흔히 말하는 가로, 세로의 범위를 말합니다. 인쇄물에서는 가로 × 세로로 구성되지만 박스 같은 경우 가로 × 세로 × 높이로 구성될 수도 있습니다. 하지만 하나 분명한 것은 종이는 2차원으로 가로, 세로로만 존재하는 구성입니다. 우리는 일단 가로 × 세로에 집중하겠습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-ef0a0959-b016-4ce8-892d-3dfbb529d50a\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-ec7df5c1-3f2a-4ced-a66c-14089c398d27\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-87237304-b2b2-4600-94ab-8e4cb81eeec3\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-bae91f2f-3f2a-42b0-b485-a40f08c95fc6\" style=\"color:#555555;background-color:#ffffff;\"><b>사이즈</b></span></p><ul class=\"se-text-list se-text-list-type-bullet-disc\"><li class=\"se-text-list-item\"><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-31d63b9f-bc52-457e-b46b-cad006ed704e\" style=\"\"><span class=\"se-fs-fs15 se-ff- se-weight-unset se-style-unset\" id=\"SE-b5538008-8a83-4857-ba96-6f9352df4284\" style=\"color:#000000;background-color:#ffffff;\">size, measurement</span></p></li><li class=\"se-text-list-item\"><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-d74acf7c-e179-44a2-995e-993dfc30392b\" style=\"line-height:1.5384615384615385;\"><span class=\"se-fs-fs13 se-ff- se-style-unset\" id=\"SE-b5a5516c-778d-4212-a71e-72489e0697e5\" style=\"color:#666666;background-color:#ffffff;\"><b>사이즈</b></span><span class=\"se-fs-fs13 se-ff- se-weight-unset se-style-unset\" id=\"SE-6eab71b7-78a9-4689-ae75-1fad53401f19\" style=\"color:#666666;background-color:#ffffff;\">를 재다</span></p></li><li class=\"se-text-list-item\"><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-2980ff0c-7cfe-4d3d-b561-7ac2548e18d5\" style=\"\"><span class=\"se-fs-fs13 se-ff- se-weight-unset se-style-unset\" id=\"SE-3ba1c322-6bb5-4aa8-9008-eed6d96be4be\" style=\"color:#666666;background-color:#ffffff;\">take[measure] the size (of)</span></p></li></ul><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line2\" id=\"SE-935a68d7-b236-4234-bf8d-616cfd19f2e5\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line2 se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-bc45f1fb-a97c-46c6-8257-3e607ef4c2cc\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-a2fb2186-a3e1-44d0-a511-97262cbc6b59\" style=\"line-height:1.8;\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-0a5b75b7-2067-4552-9c35-f948d814bcc3\" style=\"color:#000000;background-color:#ffffff;\"><b>A4 2단접지 리플렛으로 사이즈를 설명</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-8b2a1bf2-9eb1-42e2-867e-97d29fea0668\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-2f1d326c-9b7b-4c78-925b-78ff512075a0\" style=\"color:#000000;background-color:#ffffff;\">A4 2단접지 리플렛이라면 여러분은 어떤 형태로 생각하시나요? A4를 반접어서 만든 리플렛일까요? 아니면 A3를 반적어서 A4사이즈로 만든 리플렛일까요? 결론적으로 말하자면 둘다 맞습니다. A4 2단접지 리플렛이란 말 자체가 모호한 사이즈를 의미합니다. 그러나 통상적으로 A4 2단접지 리플렛이라면 A4를 반접어서 만든 접었을 때 A5사이즈 리플렛이라고 설명드릴 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-a54745fa-cd73-46ba-9ece-9dba2c19b15a\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-76c2754f-1e95-45d3-99a1-67e8633ae394\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-7609354c-ed01-42d6-b2f6-c08ac15655bf\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-5637f54c-ca93-4445-b700-9f72324c2b7b\" style=\"color:#000000;background-color:#ffffff;\">이 부분을 잘 설명하기 위해 우리는 가이드북에 </span><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-4e3dcd07-e859-4bb8-a142-02896c0a3a26\" style=\"color:#000000;background-color:#ffffff;\"><b>접었을 때</b></span><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-d1f507e1-33b2-4743-b80c-d1da6022cdc9\" style=\"color:#000000;background-color:#ffffff;\"> 라는 말을 추가하겠습니다. 다음과 같이 정확하게 표현하겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-83d84d59-6c6d-43ea-ab14-d67c911c1a83\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-3ebec3de-6a6b-45b8-96a1-ccc69dd09384\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-2903c40a-352f-4839-9208-7f99e81da191\" style=\"line-height:1.8;\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-4f5b0aac-605b-4cf9-8eb0-91dc512304a0\" style=\"color:#000000;background-color:#ffffff;\"><b>A4 2단접지 리플렛(접었을 때 A5)</b></span><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-91f354d9-c8bc-42e9-a499-e0838609ade1\" style=\"color:#000000;background-color:#ffffff;\"> 이렇게 표현하겠습니다. 즉, 사이트에서 (주)파파스컴퍼니의 사이즈는 모양을 변형하기 전의 사이즈로 통일해서 상품을 구성하겠습니다. A4를 접어서 A5로 만들어도 우리는 상품명이 A4라고 표시되는 겁니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-0b186cd8-0338-48d4-8cbd-584fd3ceec48\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-4006f0b8-64de-44a1-9bb2-a2d27e1d13bd\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-15c7df85-d9dc-4234-a3c8-cdfaca1a97d0\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-30717eaa-2c98-41a0-8cc1-4088f90f15c5\" style=\"color:#000000;background-color:#ffffff;\">하지만 책자형에서는 다른 의미로 상품명이 A4 32page 카다로그로 한다면 우리는 가공해서 만든 일반적인 모양을 연상하므로 가공된 형태가 A4로 사이즈를 이해하겠습니다. 즉, 결론은 사이즈를 정확하게 표현하고 우리가 사이트에서 만들려는 템플릿에 정확한 사이즈의 부분을 알려주기로 결정합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-667f5945-3e48-4d83-91fa-2bccd4afa546\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-667f5945-3e48-4d83-91fa-2bccd4afa546\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMzkg/MDAxNjY1MjE2MjcxNzk1.KZHspXhF0juZvglQqs2gr7XGwYw1Gxzq3zzSGfN3wXIg.J-59nz5VsMmGg7rMyZFHjLXmEcp1XTTjMoLt9dIV9f8g.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png\", \"originalWidth\" : \"1300\", \"originalHeight\" : \"710\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMzkg/MDAxNjY1MjE2MjcxNzk1.KZHspXhF0juZvglQqs2gr7XGwYw1Gxzq3zzSGfN3wXIg.J-59nz5VsMmGg7rMyZFHjLXmEcp1XTTjMoLt9dIV9f8g.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png?type=w966\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bf81654a-5915-4091-8c1c-e5fa6cb03199\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-031763ca-05e6-4a91-9909-4e0ded3caedd\" style=\"\">A4 2단접지 리플렛 (접었을 때 A5)</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-5fae63ef-cc21-4836-b600-df3bef1abdf3\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-521292d5-525c-4abd-828f-29711c9d76ba\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-428aba0c-c469-431c-bbeb-4cbf777127fa\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-2980be45-fd54-44a0-9b83-a08fdef72985\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-a9d6a8e7-3941-43af-abad-e123848b4056\" style=\"color:#000000;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line2\" id=\"SE-fb5ee45c-2567-462a-802c-b6358f6afcb7\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line2 se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-a15da144-0e6b-48d6-abf9-a6881105a360\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-f37a1c35-c25d-4822-a900-fcabfbcfc58c\" style=\"line-height:1.8;\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-84938c38-5428-4ddf-95ec-d91ae05b9bf8\" style=\"color:#000000;background-color:#ffffff;\"><b>편집사이즈, 재단사이즈, 여백</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-03c0938b-d7ae-4d0a-b636-6d44b48aed67\" style=\"line-height:1.8;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-b5ec0d09-519d-414e-9316-e2b6f67c152e\" style=\"color:#000000;background-color:#ffffff;\">인쇄사이즈의 기본에 대한 용어를 설명합니다. (주)파파스컴퍼니 사이즈는 템플릿으로 정의되지만 다음과 같은 부분은 참고적으로 이해하고 계십시요. 이 사이즈 정의를 이해해야 오차없이 인쇄물을 주문, 발주하실 수 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-6bba791b-ffa8-49ef-b324-2ddb6930b3f7\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-6bba791b-ffa8-49ef-b324-2ddb6930b3f7\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMTE2/MDAxNjY1MjE3NDI0NTMw.unwHoVlmGNqDpWJwlS5JWe7SNJyau4efpN90i_o9hdIg.Py8GMzyRa4xuMxrODWCFII67uWhbbZdayJ5ETTnUo2gg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png\", \"originalWidth\" : \"1300\", \"originalHeight\" : \"1064\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMTE2/MDAxNjY1MjE3NDI0NTMw.unwHoVlmGNqDpWJwlS5JWe7SNJyau4efpN90i_o9hdIg.Py8GMzyRa4xuMxrODWCFII67uWhbbZdayJ5ETTnUo2gg.PNG.cookthedesign/%EC%9A%94%EC%86%8C_%EC%84%A4%EB%AA%85_221005.png?type=w966\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a016fefc-e58d-49c3-9f82-b872dbd946a4\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-6afbc710-0d72-421b-a8fc-9385258ca9f1\" style=\"\">편집사이즈/재단사이즈/여백</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-55201d8a-ff56-4384-89e8-7636c841b4b1\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-53a3d69c-49ba-4ad0-b9c7-993e36c62128\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-9bc28a89-0964-4c4b-b4ec-db4f8cd1f24c\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-850b8688-d60d-40af-ac32-e464da8939e8\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-850b8688-d60d-40af-ac32-e464da8939e8\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMjMz/MDAxNjY1MjE3NzMyMDEy.guiwwg0QNcsXaTTtV5ClDlTB3sjL0V5RMeb-Pg3iNFwg.Bq7EiiFY-HQcGE1a6ePNhZl17xjwSzwW14z7MEDme-8g.PNG.cookthedesign/KakaoTalk_20220824_135711085.png\", \"originalWidth\" : \"1975\", \"originalHeight\" : \"20004\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyMjEwMDhfMjMz/MDAxNjY1MjE3NzMyMDEy.guiwwg0QNcsXaTTtV5ClDlTB3sjL0V5RMeb-Pg3iNFwg.Bq7EiiFY-HQcGE1a6ePNhZl17xjwSzwW14z7MEDme-8g.PNG.cookthedesign/KakaoTalk_20220824_135711085.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-7dff9397-0519-4919-a4ec-f3a87b6885b8\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-22f22327-721c-42e3-92eb-af94bb7b4168\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-7a8805ae-a0ad-4f70-a812-98a399141f52\" style=\"color:#000000;background-color:#ffffff;\">다음은 제가 전산개발에 참여할 때의 사이즈 정의를 정리한 엑셀입니다. 추후 (주)파파스컴퍼니의 기획문서 엑셀에 포함해서 다시 정리할 예정입니다. 본 엑셀은 추후 자료실에 전부 업로드하겠습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-aaac64a9-706f-40ea-ad72-6f517683da25\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_line\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-07fa5843-a5fc-480f-b721-78255bd0d092\" style=\"\"><span class=\"se-fs-fs24 se-ff-\" id=\"SE-7360d1c1-46fb-494d-8032-5f4ccfc91143\" style=\"color:#555555;\"><b>다음 글의 내용</b></span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-1b6e7014-dd15-42a7-9ce2-412905ff12b7\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-6968e5bd-be48-41c0-b4ae-5327fd74aae6\" style=\"line-height:1.5;\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-46b987ec-3f3d-4dde-a186-3ad5441a40fe\" style=\"color:#ff5f45;background-color:#ffffff;\"><b>[자료] 요소 분석 [색상(컬러)]</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-ddec386d-68ff-4108-a929-65b5356b6906\" style=\"line-height:1.5;\"><span class=\"se-fs-fs19 se-ff-nanumgothic se-style-unset\" id=\"SE-a55b186b-5cef-4049-bb14-7792848e7c0b\" style=\"color:#ff5f45;background-color:#ffffff;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-c5227fa3-652e-43ce-90ed-c51a698994a4\" style=\"line-height:1.5;\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-style-unset\" id=\"SE-8759f268-2556-4ea8-ad60-a20696488b44\" style=\"color:#555555;background-color:#ffffff;\"><b>인쇄는 색쟁이(?)들의 작업이라고 생각합니다. 지면에 내가 원하는 색깔을 처리하는것이 컬러입니다.</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>",
