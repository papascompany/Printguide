-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:574px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-f5e6393c-3830-42da-ac7b-e4b3928bfeac\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTA1MjBfNDIg/MDAxNzQ3NzUwODMxMDcy.eCN37EOydz_e_OMzLrIGV0gpeAcgxUz8RufRhJP_8S8g.izcLSh3-8aXDY7lnmObfPXSQFOAxsPjHiikeCo1-_Mcg.PNG/SE-f5e6393c-3830-42da-ac7b-e4b3928bfeac.png\", \"originalWidth\" : \"574\", \"originalHeight\" : \"731\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTA1MjBfNDIg/MDAxNzQ3NzUwODMxMDcy.eCN37EOydz_e_OMzLrIGV0gpeAcgxUz8RufRhJP_8S8g.izcLSh3-8aXDY7lnmObfPXSQFOAxsPjHiikeCo1-_Mcg.PNG/SE-f5e6393c-3830-42da-ac7b-e4b3928bfeac.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-3f989a66-1f07-4323-80b9-a66cd9574e8a\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-aabc035a-842f-4b14-b35c-bad4c3c1423c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c124aec7-a7e3-46a7-a49d-0d779b4e7536\" style=\"color:#555555;\">제품은 월요일 오후 배송을 통해 택배로 출고되었습니다. 3단 접지를 오시 후 단 하루 만에 출고해 드렸습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1660ec08-8603-4bea-9591-00d4ea981378\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7608ec54-245b-46e6-9fe4-c620707c0639\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d7e69c01-7cef-49ae-a660-ef18b8b2d904\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-9862624c-1e11-4de8-92d5-08572e03ee01\" style=\"color:#555555;background-color:#fdd5f5;\">물론 모든 인쇄물이 익일 출고되는 것은 아닙니다. 공장의 상황과 물량 또는 후공정 여부에 따라 지연될 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bcdd089c-6eca-4ee2-bd7d-a11001ae7791\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-382aba42-b2f7-48ac-8fe9-5cf1d7a6d365\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2b2c6de5-1f2a-4163-8c35-83895620e612\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ae720042-a64a-405f-b24b-217490872ea2\" style=\"color:#555555;\">하지만 웬만한 인쇄물에 대해서는 익일 출고를 원칙으로 하고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f816a763-af91-40b4-97ee-39fce444e6cc\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-20c64831-c57b-4a95-b341-52842975e622\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-4f46a126-96bc-49bd-ab19-d815c83916b1\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6381392a-9067-4f91-90c4-79ba127d721b\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-9fc49f25-fca4-4f71-a55a-c053d41a3011\" style=\"\">(주)파파스컴퍼니이 찾는 고객</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-40f2bff4-86b2-4c2e-8d7b-62aa2f6aa98e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6682b736-0ff2-49a2-88c5-c1b56b0426a0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d39882cb-b57c-41dd-82ff-94943a3914ed\" style=\"color:#555555;\">1. 급한 행사를 앞두고 인쇄물이 필요한 분</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-657fd78b-627d-47db-b6e8-14812ddeca37\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-3cb43b25-1b56-4730-8725-c772588dff89\" style=\"color:#555555;\">2. 소량을 자주 발주하여 최대한 빠른 소통을 원하는 고객</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-c0d853c5-de03-4a37-9b50-c2ec16fb987a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-bcf6affa-3a16-4fff-9514-1dc70a5ce4f1\" style=\"color:#555555;\">3. 디자인을 못해서 파일 문서를 꼼꼼히 봐주는 업체</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-07563272-4cdf-4fc6-8fa0-34a227fc1182\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c75c1bf6-d5e1-4cfc-bca3-9f5fa850fa1b\" style=\"color:#555555;\">4. 합리적인 가격에 지속적으로 거래를 하고 싶은 업체</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7fb5d917-c129-469e-9cae-e2968b2b6a62\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e401a9e3-2c58-4255-9d63-137daf59fc74\" style=\"color:#555555;\">5. 빠른 견적과 납기를 원하는 업체</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a065fadf-8b8d-48bb-838a-f3bee3a2177c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7952f06b-624b-4986-9e48-7785bff2a1b9\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-1418b90c-befd-4fc1-8b9e-69500b0bf9bc\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align-center se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;ref=https%3A%2F%2Fm.blog.naver.com%2Fcookthedesign%2F223872303606#nafullscreen\" onclick=\"sendClickNlog('pst.talktalk', '');\">\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n</a>\n</div>\n</div>\n</div>",
