eef\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-783aed9a-4970-4ea4-a700-0752a920eb5b\" style=\"color:#555555;background-color:#fff8b2;\">pg사 연결이 되고 있지 않습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-f83ac9da-347e-4ab4-acf8-011b2b1b1758\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0a667e47-55d0-4a99-b51e-09ffe43fa5fc\" style=\"color:#555555;\">죄송합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2d0ac4a4-6485-4808-8cf3-7418be3c3d15\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a873fe07-d9d9-4fcb-b823-3a403ac220b0\" style=\"color:#555555;\">pg연결이 아직은 미개발이라</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-5211f73c-9efd-4850-8170-d72e118dd3cd\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-400e347e-3597-4685-9e05-f3778a46813e\" style=\"color:#555555;\">통장 입금과 계산서 발행이</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-b84ecff2-aef4-46ce-81b5-35005f6a914f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-05fca70a-a693-452d-8722-4093ed7d0125\" style=\"color:#555555;\">기본 거래 사항입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-53c9dcf0-a692-4e7c-8393-d647f0a4780a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-14599c45-2d3d-4e8c-bab5-87791e9124ca\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2bd0135d-6cef-4fa6-ab72-0f78ac9af318\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7fc283ec-b02f-445c-84f9-eee8c78a927c\" style=\"color:#555555;\">앞으로 더 노력하여 카드 결제를 위해</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-3ac52750-6f5c-4602-bd70-35f2616c6c70\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e22c5362-090b-409a-afa1-89e51b6a4ad2\" style=\"color:#555555;\">pg연결과 사이트에</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-e3f7531f-173c-4822-a639-10539b0b8443\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-1757779f-57bb-4143-ab87-a0e07845983b\" style=\"color:#555555;\">연동을 진행하도록 하겠습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-f1b0fa35-2f1d-4c1c-9b58-8e71cdf32db1\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-center\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-54d7c911-2dd9-4748-a03b-333c9071e74c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9b0be3d9-269d-42bc-884e-6052a98a5932\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e2263a23-a373-4af3-96ac-6ab65a3fcf68\" style=\"color:#555555;background-color:#fff8b2;\">또한 정확한 견적 요청을 위해</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-0ea6b315-fd91-4f96-ad67-99076c762a1a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0f88ae82-9fa6-4764-be64-551e17ca2040\" style=\"color:#555555;background-color:#fff8b2;\">반드시 통화를 요청드리고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-5a35146a-5644-4949-bca9-4df99f74f375\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2b7653b9-d1d0-448c-adfc-01b87bed70eb\" style=\"color:#555555;\">통화로 궁금한 사항을 여쭤보고</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-360c8712-54eb-469b-9a9f-3b6b0a284a8f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ce78db53-fb40-4386-a9bb-13ad0f6dc003\" style=\"color:#555555;\">정확한 견적을 드리도록</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-217ad7e3-3d81-4de1-a004-dd8cb38b20a2\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-bbd57158-6d8a-4cf4-8ecb-6f6f27d0b810\" style=\"color:#555555;\">노력하고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-82d65131-a3fe-4af5-9902-6f0f5cd80aba\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8103a45c-5618-4fb5-87da-5d86105c3616\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-c9cfaf87-a329-4b1e-a3c8-d44598c169f6\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7755cdb2-926c-47fb-9da0-042468bea986\" style=\"color:#555555;\">만약 통화를 원하지 않으시다면</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-eaf135c1-aad8-4807-85da-85ba2278b203\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-307a578b-ba07-4641-b621-1a3e369c7221\" style=\"color:#555555;\">문자나 기타 방법으로만 가견적을</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-4a1c6440-3ec6-4f6b-ad2e-fc4e42c71472\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7c8606f5-99eb-48b5-9334-7162255a8502\" style=\"color:#555555;\">보내드리고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-b61e4558-8c4e-4a88-b699-a35b14c3321f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-13f3065c-ce21-4fc2-9b83-39368bd7cb58\" style=\"color:#555555;\">가견적은 부정확할 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-4cb4c1e6-29c8-407d-b588-a9bac431f041\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a8fd9615-d9c1-464e-bd0b-71cac00596f4\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-3e0641f4-4451-431b-aaa6-30708693ff9b\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ac26f2a9-c7f1-4a1c-8731-e491db389299\" style=\"color:#555555;\">반드시 자세한 상담을 통해</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-b8d3d072-0879-4f17-b43a-44c48af81459\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7afaf94a-8c8e-4527-a544-f5b9b066e7af\" style=\"color:#555555;\">정확한 견적을 드리도록 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-facc093c-8b9e-4db9-96bd-42ea0729075a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-dd01fb92-bb67-4bfe-9427-68dd04b6659c\" style=\"color:#555555;\">노력하겠습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n\n</div>",
