 \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMjkx/MDAxNzQwODAzNTg2OTEx.GgJsUAHBcnMn4u0mPiQ2-G0wXcWzrw0h-etoofWmMXgg._uEblX-oZxFA1P-8K7eun5jE_AJOZ_QfU1oovC_5CX0g.PNG/KakaoTalk_20250227_104341098.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-imageGroup-navigation\">\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-prev\" type=\"button\"><span class=\"se-blind\">Previous image</span></button>\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-next\" type=\"button\"><span class=\"se-blind\">Next image</span></button>\n</div>\n<div class=\"se-imageGroup-progress\"><div class=\"se-imageGroup-thumb\"></div></div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-941ea7d3-2abf-40f6-af4c-6fc06a7a1ca1\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-941ea7d3-2abf-40f6-af4c-6fc06a7a1ca1\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMTk0/MDAxNzQwODAyNjc3MjU1.AUhQlakL6ghWmr9lpC8cfVAfWTwfG17YFqeoUURmu_gg.ZQIQArJfSQ3mu7PHmRhpAhxqSX6GmkLcElRYWUPdbu8g.PNG/1.png\", \"originalWidth\" : \"5050\", \"originalHeight\" : \"3456\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMTk0/MDAxNzQwODAyNjc3MjU1.AUhQlakL6ghWmr9lpC8cfVAfWTwfG17YFqeoUURmu_gg.ZQIQArJfSQ3mu7PHmRhpAhxqSX6GmkLcElRYWUPdbu8g.PNG/1.png?type=w966\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5b1ee797-b250-406a-92c1-9637280c7353\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-e99a282d-06d5-11f0-af68-eb5eeeb302d6\" style=\"\">본 디자인의 블로그 작성을 허락해 주신 관계자분께 감사드립니다.</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-62371c62-a394-4630-9aec-46483965a14a\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-cf32719a-9b24-4b82-9a1d-c29491d081b8\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-e99a4f3e-06d5-11f0-af68-cbbd7b5e0fc2\" style=\"\">제작 일지</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-8e6e45ad-4ec0-4b30-aaef-eace95796392\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-de22869c-a7f2-4120-8432-da2bfe2ff4fa\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a4f3f-06d5-11f0-af68-ebc8f2e6fa98\" style=\"color:#333333;\">오늘은 </span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e99a4f40-06d5-11f0-af68-f96747949ba5\" style=\"color:#333333;\"><b>단상자 소량 샘플 제작</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a4f41-06d5-11f0-af68-451c447cb811\" style=\"color:#333333;\">에 대한 </span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e99a4f42-06d5-11f0-af68-ef62f97b40f1\" style=\"color:#333333;\"><b>진행 일지</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a4f43-06d5-11f0-af68-231362ebc01d\" style=\"color:#333333;\">를 소개하려고 합니다. (주)파파스컴퍼니은 고객의 시간을 가장 소중하게 생각합니다. 이날의 주문은 단 4시간 10여 분 만에 납품했습니다. 첫 통화에서 납품까지 걸린 시간은 더 짧습니다. 가장 빠르게 진행된 사례로 소개해 드리고 싶습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-93d44776-5d4d-4452-89d3-f7f609152154\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e99a4f44-06d5-11f0-af68-3f2aaadc4789\" style=\"color:#ff0010;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e4cd49bf-eec4-487f-a824-6d530e9dec4b\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e99a4f45-06d5-11f0-af68-bdfecb706ab8\" style=\"color:#ff0010;\"><b>첫 통화</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-619ca141-6553-4156-9bbb-e508397024d3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e99a4f46-06d5-11f0-af68-a9804a5d6c45\" style=\"color:#ff0010;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-baf180a2-642d-465e-969d-c25da3dc23c7\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a4f47-06d5-11f0-af68-6fbd5dc37408\" style=\"color:#555555;\">단상자, 소량 생산에 진심인 (주)파파스컴퍼니입니다. 고객님으로부터 오전에 급한 전화가 왔습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-0b6056ec-4d2d-478b-b38d-259c74ab41c5\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:648px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-0b6056ec-4d2d-478b-b38d-259c74ab41c5\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfNzQg/MDAxNzQwODA0NTAwOTM4.mYa2g7wQzYJCuwlgsM4H5wezsKrGAqbZCASAvKNTDdYg.Fx5laDtzYZBXPQHgp5A9JtL9h9sDJ2mst9LYwz9e2dog.JPEG/SE-0b6056ec-4d2d-478b-b38d-259c74ab41c5.jpg\", \"originalWidth\" : \"648\", \"originalHeight\" : \"1390\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfNzQg/MDAxNzQwODA0NTAwOTM4.mYa2g7wQzYJCuwlgsM4H5wezsKrGAqbZCASAvKNTDdYg.Fx5laDtzYZBXPQHgp5A9JtL9h9sDJ2mst9LYwz9e2dog.JPEG/SE-0b6056ec-4d2d-478b-b38d-259c74ab41c5.jpg?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-4f002398-2785-4afc-8990-a49ca00e82fb\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-98e1e11e-3d1c-455a-9457-7a7cdec4b69d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a4f48-06d5-11f0-af68-e5645c16f090\" style=\"color:#555555;\">오전 9시 58분 첫 통화였습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-da2b15d7-879d-40b3-b81a-f8cc217cd585\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a7659-06d5-11f0-af68-b3f261bf3c87\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-85ee8441-3c73-4e5f-8633-53bfc32bffe0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a765a-06d5-11f0-af68-bbfc167de2eb\" style=\"color:#555555;background-color:#fff8b2;\">요지는 </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-e99a765b-06d5-11f0-af68-658f7ead3229\" style=\"color:#555555;background-color:#fff8b2;\"><b>오늘 4시</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a765c-06d5-11f0-af68-8fc650f523c4\" style=\"color:#555555;background-color:#fff8b2;\">까지 단상자 샘플 3개를 받을 수 있을지에 대한 문의였습니다. 시간이 약 6시간밖에 없었습니다. 자료도 없고 내용도 없는 상태에서 제작이 거의 불가능한 상황이었으며 고객님께서는 오늘 올*** 시연 브리핑을 위한 </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-e99a765d-06d5-11f0-af68-cd150476888c\" style=\"color:#555555;background-color:#fff8b2;\"><b>박스 샘플이</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a765e-06d5-11f0-af68-6f053c90da74\" style=\"color:#555555;background-color:#fff8b2;\"> 꼭 필요하시다는 요청이셨습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9958ac8b-e041-4a4b-9bcf-83b65937bac0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a765f-06d5-11f0-af68-c3d0f5afbcd3\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-010f1600-dd30-499d-93c6-2bb873598689\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a7660-06d5-11f0-af68-63c937d0a56e\" style=\"color:#555555;\">하지만 6시간의 제약뿐 아니라 디지털에 맞는 사이즈인지 가격은 적합한지 또는 택배도 아닌 퀵으로의 납품이라 여러 가지 제약사항이 있었습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8aec8338-4701-4c00-b3b3-8780dbd12ec7\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a7661-06d5-11f0-af68-e191220d0e15\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-73e6acdf-ce45-4a99-8ba3-7dab7130ff34\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a7662-06d5-11f0-af68-df6dda32732d\" style=\"color:#555555;\">일단 통화 후 데이터를 카톡으로 받고 디지털에 맞는 사이즈인지 와 견적을 제출한다고 하고 상담을 마무리했습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8ed93fae-ce48-4726-b81e-3cb10b7412a2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a7663-06d5-11f0-af68-293d589c164d\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4e7d1a1b-f9b9-48c1-841e-23ee8181e1dd\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a7664-06d5-11f0-af68-f50c969a042a\" style=\"color:#555555;\">저희가 진행한 가장 첫 번째는 고객님의 정보 습득입니다. 정보가 부정확하여 소통이나 기타 사고가 날 확률을 줄이기 위한 조치입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-be133674-d300-4a7f-8a59-301eb67d11fa\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:648px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-be133674-d300-4a7f-8a59-301eb67d11fa\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMTUw/MDAxNzQwODA0NzgyNTYx.4wZxMIA7W84eL3tBBzaeKL6KYBH68q2yj5RzSNXvdnEg.wsGKN7Zwc7fFmufJgeH-Lt3ySjNQsOvuT5EKGQcr2yYg.JPEG/SE-be133674-d300-4a7f-8a59-301eb67d11fa.jpg\", \"originalWidth\" : \"648\", \"originalHeight\" : \"1390\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMTUw/MDAxNzQwODA0NzgyNTYx.4wZxMIA7W84eL3tBBzaeKL6KYBH68q2yj5RzSNXvdnEg.wsGKN7Zwc7fFmufJgeH-Lt3ySjNQsOvuT5EKGQcr2yYg.JPEG/SE-be133674-d300-4a7f-8a59-301eb67d11fa.jpg?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-a89d7495-c5e9-4221-83be-5fbf7938c2e9\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2eec5d10-f284-416a-be35-b77fad978de3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a9c75-06d5-11f0-af68-8b1532685ede\" style=\"color:#555555;\">고객님의 명함과 고객님의 정보를 전달받으면 디지털에 맞는 사이즈와 적합한지를 보고 진행을 해보겠다고 하고 데이터 접수를 위해 카톡을 오픈했습니다. 이때까지의 상담 소요시간은 고작 10분입니다. </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-e99a9c76-06d5-11f0-af68-979e5dc34409\" style=\"color:#555555;background-color:#fff8b2;\"><b>그만큼 (주)파파스컴퍼니은 빠른 대처를 자랑합니다.</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-5e214fdf-7b1e-400f-a32d-7c66b192c517\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-97ddd92f-0a70-47a2-a727-291189f6c549\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-35c27757-5d89-4396-9a4d-03f44dae232a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e99a9c77-06d5-11f0-af68-e9c0ee703a6c\" style=\"color:#ff0010;\"><b>데이터 검증</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-92be0994-2e38-4357-bf67-5fab8251538e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e99a9c78-06d5-11f0-af68-dbbdf8328f93\" style=\"color:#ff0010;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-0982172f-9617-4d47-aa13-13d842c683b8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a9c79-06d5-11f0-af68-754e630be194\" style=\"color:#555555;\">일단 인쇄가 되고 납품이 되려면 데이터가 가장 중요합니다. 일단 적합한 인쇄 데이터인지의 확인 절차가 필수입니다. (주)파파스컴퍼니은 데이터 검증까지도 꼼꼼히 챙겨드립니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-ec7a6174-5ce9-4039-b3f4-c54889745f50\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:648px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-ec7a6174-5ce9-4039-b3f4-c54889745f50\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMjIx/MDAxNzQwODA1MDg4OTU5.ipvTPczpr8XWM_0i9vMjFh2axDemLisLiiu4nG6YdCAg.M1PcLMgOd3tbAw7aliRRqkN8ebHCg1_L8_3H4Pta5uUg.JPEG/SE-ec7a6174-5ce9-4039-b3f4-c54889745f50.jpg\", \"originalWidth\" : \"648\", \"originalHeight\" : \"1390\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMjIx/MDAxNzQwODA1MDg4OTU5.ipvTPczpr8XWM_0i9vMjFh2axDemLisLiiu4nG6YdCAg.M1PcLMgOd3tbAw7aliRRqkN8ebHCg1_L8_3H4Pta5uUg.JPEG/SE-ec7a6174-5ce9-4039-b3f4-c54889745f50.jpg?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-5512e9f4-208d-42f0-9899-a91d02ab5cd5\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7161f0d1-7c58-4323-a85d-f185cdcb2b94\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a9c7a-06d5-11f0-af68-13f8bc25ad2f\" style=\"color:#555555;\">다행히 인쇄 파일은 전문가답게 이상이 없었습니다. 다만 칼선이 일반적이지 않아 확인 작업을 진행했습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-8dca45c0-0fa0-489b-972b-2810ee023298\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:440px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-8dca45c0-0fa0-489b-972b-2810ee023298\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMTI5/MDAxNzQwODA1MTgyMTkx.xhbgIiMkDImESRo8eboqCVIMVJl0V2LRPvdH_BZHcMEg.tGlBinmD0olVC134pMCt7EhDVM-HLyhDHJkhe7g5wbMg.PNG/image.png\", \"originalWidth\" : \"440\", \"originalHeight\" : \"320\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMDFfMTI5/MDAxNzQwODA1MTgyMTkx.xhbgIiMkDImESRo8eboqCVIMVJl0V2LRPvdH_BZHcMEg.tGlBinmD0olVC134pMCt7EhDVM-HLyhDHJkhe7g5wbMg.PNG/image.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-874e184c-3b94-4946-a204-6fccfc5e66e4\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-91165159-9a92-4127-b41c-2aa54d83945e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e99a9c7b-06d5-11f0-af68-2bd4dcd7ced0\" style=\"color:#555555;\">디지털에서 다음 사이즈가 벗어나면 하루 만에 출고는 불가능합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-724