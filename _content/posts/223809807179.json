  "content_html": "<div class=\"se-component se-text se-l-default\" id=\"SE-1a0c8643-f2ac-4326-8871-035b7c77878d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-fa5ae9e1-d693-42c2-bce3-a744295fc511\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-3fd6c261-483b-46ae-bd10-db63c8603536\" style=\"color:#555555;\">안녕하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-165bddbe-4289-4aed-925b-8a7ca33d4f4a\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-cbb8fb2b-b07f-445d-b4f5-61b343037edc\" style=\"color:#555555;\"><b>패키지 소량 전문</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-bb4fb7cc-ee2c-4484-8479-39f6c071a7d8\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-6ab8b9eb-69f4-4286-b1ab-5b37599e4c75\" style=\"color:#555555;\"><b>공장직영 맞춤 제작</b></span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-5dc28254-abcd-44d7-8714-d5fcead9b113\" style=\"color:#555555;\"> 전문</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9b7d2f29-973b-4a52-8b9f-e9f17f028773\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-8174a932-b6a7-402e-9545-7e73638293e0\" style=\"color:#ff0010;\"><b>(주)파파스컴퍼니</b></span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-ba12b1e6-f886-434e-929d-311e7e5682eb\" style=\"color:#555555;\">입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-imageGroup se-l-slide\">\n<div class=\"se-component-content se-component-content-extend\">\n<div class=\"se-section se-section-imageGroup se-l-slide\" id=\"SE-1eedf2e9-3b1e-466c-a210-784202bb7af6\">\n<div class=\"se-imageGroup-viewer\">\n<div class=\"se-imageGroup-container\">\n<div class=\"se-imageGroup-item\">\n<div class=\"se-module se-module-image\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-8391905a-4dc5-4b2b-9aa6-73792c3db76f\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfMTY1/MDAxNzQyOTEwMDU3MTUx.OeiWweD3NJz64iGBICuka2ETucIrLHCLR6JrFJ0fWb0g.SLayFin1-uMxcTC1ou68CuEnDCerF6fbLMDkB0BXvu8g.PNG/05.png\", \"originalWidth\" : \"5460\", \"originalHeight\" : \"3642\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfMTY1/MDAxNzQyOTEwMDU3MTUx.OeiWweD3NJz64iGBICuka2ETucIrLHCLR6JrFJ0fWb0g.SLayFin1-uMxcTC1ou68CuEnDCerF6fbLMDkB0BXvu8g.PNG/05.png?type=w966\"/>\n</a>\n</div>\n</div>\n<div class=\"se-imageGroup-item\">\n<div class=\"se-module se-module-image\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-b6c12bd2-3ca4-4718-91b2-cd83eb302418\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfMjEg/MDAxNzQyOTEwMDU3NDcw.Zx1SR9bVHTdOwGq7sG5tgjOdSsmz65_X6rLiFS8TJt0g.IOZRukADsM-yX6aABXlxfdMQCE9h9Hed6kOU8YvjETIg.PNG/02.png\", \"originalWidth\" : \"5460\", \"originalHeight\" : \"3642\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfMjEg/MDAxNzQyOTEwMDU3NDcw.Zx1SR9bVHTdOwGq7sG5tgjOdSsmz65_X6rLiFS8TJt0g.IOZRukADsM-yX6aABXlxfdMQCE9h9Hed6kOU8YvjETIg.PNG/02.png?type=w966\"/>\n</a>\n</div>\n</div>\n<div class=\"se-imageGroup-item\">\n<div class=\"se-module se-module-image\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-ff1bc3a8-5cff-4284-8e7c-2cd105439167\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfNzIg/MDAxNzQyOTEwMDU3NjI5._ov44I6y3iKRV8antsmQ5-MjmtoSMJcHmr6p9oOM6Xgg.6YWD2gTNYcGjEh9bfRh27Q0u2hX4kJST4Ke9yBZw5Xkg.PNG/03.png\", \"originalWidth\" : \"5460\", \"originalHeight\" : \"3642\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfNzIg/MDAxNzQyOTEwMDU3NjI5._ov44I6y3iKRV8antsmQ5-MjmtoSMJcHmr6p9oOM6Xgg.6YWD2gTNYcGjEh9bfRh27Q0u2hX4kJST4Ke9yBZw5Xkg.PNG/03.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-imageGroup-navigation\">\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-prev\" type=\"button\"><span class=\"se-blind\">Previous image</span></button>\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-next\" type=\"button\"><span class=\"se-blind\">Next image</span></button>\n</div>\n<div class=\"se-imageGroup-progress\"><div class=\"se-imageGroup-thumb\"></div></div>\n</div>\n</div>\n\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-927cd1e0-3d87-414e-84bc-2a433fd231bf\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-45747823-1c0b-474a-ae95-f48f3ad38a13\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-1051a891-5ec2-4e57-9a00-63d877eba46f\" style=\"\">결론 먼저</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-c4d6d146-f9a4-4f73-866c-2b837156c906\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-a4cfaa1f-a895-426d-beea-f34923777f30\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-52e85b15-9970-429f-8ac6-7ccd6072207a\" style=\"color:#555555;background-color:#bdfbfa;\">싸바리 박스도 샘플 제작이 가능하지만 단상자는 단 2일이면 생산이 가능합니다. 만약 여러분이 100개 미만의 소량 생산이나 샘플 5~10개를 원하신다면 지금 바로 문의하세요.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-f4e29d66-1a2d-4ec2-ab27-fccb6b554003\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-2875f976-90b5-4cd3-928b-9500ebf637b1\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-95551cab-171f-4f30-a53c-e5183efacabe\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-174daad1-4f9f-45c7-a7d0-019db96e454e\" style=\"color:#555555;\"><b>단상자</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-56975966-e76b-418a-b5f5-8cd1aef9395c\" style=\"color:#555555;\">는 합지를 하지 않고 보통 300g 이상의 종이를 사용하는 박스 형태를 말합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-b96510b2-2d0f-45bf-8952-199c95edd09d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0605a831-b1e3-4a08-879d-f77dec127e42\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-3408f953-9132-41c5-b65c-e46ace9608af\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-9533567b-354d-4c3a-8c20-ed8cf9d7b60d\" style=\"color:#555555;\">일단 합지를 하지 않기 때문에 하나의 종이를 인쇄 가공하여 제작하게 됩니다. (주)파파스컴퍼니은 소량 전문 생산 업체답게 단상자 익일 출고를 목표로 생산체계를 갖추려 노력하고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-3397141a-9ea7-4c72-9e89-5dc1843275c1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6febd827-9a1c-4e2e-9369-a61be5ce2916\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-865dbc99-de24-4595-af16-ee7f707c3dd8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c195b941-1ff2-4f25-a494-c2ee4b5693a5\" style=\"color:#555555;\">다음은 실제 촬영 스케줄 때문에 10개의 단상자를 주문한 생산 일지입니다. 이 프로세스와 블로그 디자인 글을 허락해 주신 대표님께 감사의 말씀 전합니다. 이제 그 생산에 대한 작업 일지를 시작합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-fc3912ef-5d04-4eae-a7b9-4044b0dea21a\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\" style=\"max-width:550px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-fc3912ef-5d04-4eae-a7b9-4044b0dea21a\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfMiAg/MDAxNzQyOTEwNzM5MTIy.GcpZCFYS30FE8tdoXqapwAcdRJQirF4B9UaQVjTv0SIg.GpXbJGaAHUNQq3b-TETUWfl_aEZ2MRH8wQJtV7aVbt4g.PNG/SE-fc3912ef-5d04-4eae-a7b9-4044b0dea21a.png\", \"originalWidth\" : \"550\", \"originalHeight\" : \"722\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfMiAg/MDAxNzQyOTEwNzM5MTIy.GcpZCFYS30FE8tdoXqapwAcdRJQirF4B9UaQVjTv0SIg.GpXbJGaAHUNQq3b-TETUWfl_aEZ2MRH8wQJtV7aVbt4g.PNG/SE-fc3912ef-5d04-4eae-a7b9-4044b0dea21a.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-bb188049-f26a-44d6-9ff7-a91cdfdbf85c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-4b581647-f633-4f29-8110-82d0f3971f7c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-4048d382-75ef-44fb-85f0-97b2aa5e7e08\" style=\"color:#555555;\">3월 19일 수요일 아침에 급하게 전화를 주셨고 단 5일 뒤에 촬영 스케줄이 있어 샘플로 10개 주문을 요청하셨습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-e01ac675-4b88-43ca-84ff-8daf4433760a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-4a80c4cb-9b75-4501-8cad-87a407578a26\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-f500510a-c42e-47f5-ac8d-21f5d295eda0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-433e793b-0208-43fb-abd1-21208b3b76f1\" style=\"color:#555555;\">수요일 오전에 주문하시고 그 다음 주 월요일 영상 촬영이라 금요일까지는 납품을 받아야 하는 상황이었습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-8af9cf90-07ae-493b-ad90-2e4006405f98\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8a8bf2d0-7dc4-494f-9721-a4860d7e8770\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-885f422c-a7e9-44e3-9e84-c3330f0b3ff4\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\" style=\"max-width:557px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-885f422c-a7e9-44e3-9e84-c3330f0b3ff4\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfOTMg/MDAxNzQyOTEwOTA0NzU5.ve1NvylAoSXFzOZhEQ0ONK9SkaWooKlk7OzAQsnz84Qg.0asEogy7w6txvw6lIDfYDPWlUqdqCFQgANwcVYhbKTwg.PNG/SE-885f422c-a7e9-44e3-9e84-c3330f0b3ff4.png\", \"originalWidth\" : \"557\", \"originalHeight\" : \"726\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfOTMg/MDAxNzQyOTEwOTA0NzU5.ve1NvylAoSXFzOZhEQ0ONK9SkaWooKlk7OzAQsnz84Qg.0asEogy7w6txvw6lIDfYDPWlUqdqCFQgANwcVYhbKTwg.PNG/SE-885f422c-a7e9-44e3-9e84-c3330f0b3ff4.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-8dee98a5-060a-4030-be03-1068a3cf38f8\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-48d290a0-8410-47e7-b69b-a93793016678\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-42911c65-9014-4817-b2b6-8c248a4d15c3\" style=\"color:#555555;\">입금을 완료하여 빠르게 생산에 들어갔습니다. 그리고 데이터에서 약간의 트렌드에 맞는 작업 방법을 상의드렸습니다. 특히 디지털 샘플의 경우 위 뚜껑의 스톱바는 작업을 하지 않는 추세입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-1fd45687-aa76-49d9-a03a-e942265dd034\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linkdata='{\"id\" : \"SE-1fd45687-aa76-49d9-a03a-e942265dd034\", \"src\" : \"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfMTAw/MDAxNzQyOTExMDI0NzE4.hDa8QAZYHR1T3Sw4AFjAAM9DHoG_P-Gj6CD7bk532XIg.eDfv7z7Bn-ey57M1EXm4BplcyiC1xOCg2a-xZIS2VcYg.PNG/image.png\", \"originalWidth\" : \"1222\", \"originalHeight\" : \"375\", \"linkUse\" : \"false\", \"link\" : \"\"}' data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://mblogthumb-phinf.pstatic.net/MjAyNTAzMjVfMTAw/MDAxNzQyOTExMDI0NzE4.hDa8QAZYHR1T3Sw4AFjAAM9DHoG_P-Gj6CD7bk532XIg.eDfv7z7Bn-ey57M1EXm4BplcyiC1xOCg2a-xZIS2VcYg.PNG/image.png?type=w966\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-bd1a0c30-0033-4255-8369-156a65005d25\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-d49e7240-ab7e-40a7-ac52-9778015485d7\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6d75cccc-24e2-4d80-95e2-5da9ebe12fae\" style=\"color:#555555;\">각설하고,</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-7f15ea7d-b7e9-467e-8e88-ae6fe2232d2e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-25a9a490-7868-4819-804e-a167c1af39da\" style=\"color:#555555;\">다음에 주문하신 데이터는 인쇄에 적합하게 잘 전송되었습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-b20af837-bf40-4579-890c-ee2ac5a1eae3\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\" style=\"max-width:819px;\">\n<div class=\"se-module se-mod