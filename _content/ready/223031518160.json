dn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223031518160/004.png\"/>\n</a>\n</div>\n</div>\n</div>\n<div class=\"se-component-slot\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-58d9f552-2c76-4bd2-8a44-7cbf7afc2b09\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi se-style-unset\" id=\"SE-589fefb0-f7a9-49b1-b2d3-79e3e4461825\" style=\"color:#555555;background-color:#ffffff;\"><b>홍보 책자</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-41f8dcd1-bed8-49c5-b63d-ed146c6237ab\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset se-style-unset\" id=\"SE-b54116a0-8888-43a3-8be6-71eebb11b843\" style=\"color:#555555;background-color:#ffffff;\">홍보 책자는 여러 형태가 있습니다. 홍보 마케팅용이 있을 수도 있고 프로그램 안내용으로 제작될 수도 있습니다. 팸플릿이든 책자이든 이 행사의 주요 내용을 담고 있어야 합니다. </span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-imageGroup se-l-slide\">\n<div class=\"se-component-content se-component-content-extend\">\n<div class=\"se-section se-section-imageGroup se-l-slide\" id=\"SE-f6b3eded-e97f-4979-b94f-550e68060ac9\">\n<div class=\"se-imageGroup-viewer\">\n<div class=\"se-imageGroup-container\">\n<div class=\"se-imageGroup-item\">\n<div class=\"se-module se-module-image\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223031518160/005.png\"/>\n</a>\n</div>\n</div>\n<div class=\"se-imageGroup-item\">\n<div class=\"se-module se-module-image\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se