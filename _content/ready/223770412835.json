  "source_url": "https://m.blog.naver.com/cookthedesign/223770412835",
  "content_html": "<div class=\"se-component se-text se-l-default\" id=\"SE-1a0c8643-f2ac-4326-8871-035b7c77878d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-fa5ae9e1-d693-42c2-bce3-a744295fc511\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-3fd6c261-483b-46ae-bd10-db63c8603536\" style=\"color:#555555;\">안녕하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-165bddbe-4289-4aed-925b-8a7ca33d4f4a\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-cbb8fb2b-b07f-445d-b4f5-61b343037edc\" style=\"color:#555555;\"><b>전산개발 전문 솔루션 회사</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-41c46d2b-11e3-45d2-88f2-154ab8ae6952\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-88f8d10c-a985-40ea-9779-073524d3f7f1\" style=\"color:#007aa6;\"><b>데버</b></span><span class=\"se-fs-fs19 se-ff-nanummaruburi se-weight-unset\" id=\"SE-1579d041-c29f-41b7-a2ba-446d31068f1e\" style=\"color:#555555;\">와</span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-11774918-b26a-49cd-bddb-ec851e2c4766\" style=\"color:#555555;\"><b> 파트너사</b></span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-5dc28254-abcd-44d7-8714-d5fcead9b113\" style=\"color:#555555;\">인</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9b7d2f29-973b-4a52-8b9f-e9f17f028773\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-8174a932-b6a7-402e-9545-7e73638293e0\" style=\"color:#ff0010;\"><b>(주)파파스컴퍼니</b></span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-ba12b1e6-f886-434e-929d-311e7e5682eb\" style=\"color:#555555;\">입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-f4da3a38-7004-4cef-a170-0ed6e524f521\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223770412835/000.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-946f82e9-d1b6-4350-a4b0-9c02ce36c285\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9b27979e-ba14-4275-aef2-74890e981faa\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e26e5ac9-e4a2-476f-a9d0-6beccc93c5a6\" style=\"color:#555555;\"><a class=\"se-link __se_link\" data-linktype=\"text\" href=\"https://www.devercorp.com/\" target=\"_blank\">https://www.devercorp.com/</a></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-3235cddf-7830-4970-be28-3484b2836b38\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-center\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-9925e8f6-e14f-4b03-8710-55fcb1e485e9\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-97f4c65f-0421-4f03-b690-7f8375db29e2\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-5d5aaac1-d6f5-40d7-8e28-b2ac61a8b875\" style=\"color:#555555;\">오늘은 파트너사 소개가 있는 날입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-b3cd7e9d-5854-4452-9757-b501da8223a9\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-4cb0a81e-206b-4fd0-a35e-c93524fd7d62\" style=\"color:#555555;\">이제 </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-eb3dc1d4-b334-44aa-89d2-a76bacf475ca\" style=\"color:#555555;\"><b>매주 월요일 또는 수요일</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-1c97f693-89bd-4f50-a68e-838d4d339d0b\" style=\"color:#555555;\">에는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-8dcdf3f7-f933-4ce2-a993-a1f9167c179f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-bfc12d9a-a616-45c1-8590-4d780ec0e925\" style=\"color:#555555;\">파트너사 소개로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-7d757549-8483-4732-a844-92d21f862cc6\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-66f7da75-c55a-413b-92fd-b08b93e7a568\" style=\"color:#555555;\">블로그를 작성할 예정입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-99ee7e57-9920-4989-a6ae-927d426b71cb\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-8a8dac9d-d273-437f-b3e7-e00d0271b04c\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-c8b593ba-31b8-48b7-9a7d-f4166ac6f710\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-47e2f607-5275-4e10-96c1-7afb826f37e8\" style=\"color:#555555;\"><b>오늘은 협회사이트를 가장 잘 만드는</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-34972965-b323-4c2e-9d23-4a3d30384503\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-cd0a73f0-4c1a-4311-9d4f-ac58fbae4061\" style=\"color:#555555;\"><b>글로 시작하겠습니다.</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-7ae614dd-7017-43d9-b17a-7fe13dc33611\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\" style=\"max-width:861px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223770412835/001.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-76b83922-6bda-4808-9094-a71899140852\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_line\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6098aef2-09c8-4078-b22a-681da75cc0c4\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-f8134e3f-8dca-47c3-ac9c-bed90ec5db6e\" style=\"\">학회나 협회사이트는 뭐가 중요할까?</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-8f88d4b3-760f-46f5-8f2f-9775fb578dec\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8f3210e3-528a-4380-a595-57177a2e473e\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-350d92a8-d668-42b1-a66c-9ed62daff616\" style=\"color:#555555;\">협회나 학회가 사이트를 만들려고 합니다. 어떤 기능이나 목적이 충족돼야 의뢰할 수 있을까요? 오늘은 학회사이트에서 가장 중요한 점을 서술해 보겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-cb8b629c-497d-4de0-ad08-478400b9271c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-c1fbec40-d9e7-49d1-91bf-80a3afbe279b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1f73f5cf-c4f3-471b-bec1-30c78425b056\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-23eedb52-abf6-4d86-a7c8-bf8cd2d5edc9\" style=\"color:#555555;\">학회사이트에서 키워드를 이미지로 만들어 보았습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-32d17b9f-8555-4d85-9f85-b4a5cf1664ee\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223770412835/002.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-6028d7bf-9ce1-4599-a9a2-17842fd0fc4b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6b977975-db03-4c31-b42d-359e688d177a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-2f552889-fe6f-4648-b066-6f97b80388f4\" style=\"color:#555555;\">학회사이트는 여러 가지를 검토할 사항이 있겠지만 키워드상에서는 몇 가지를 중점적으로 검토해서 기획해야 합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-589b6d96-47b2-4d90-9093-713f119edc3e\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-49ff5530-5c8b-497f-b6e1-c1ba2938cb9b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7966915a-fbb7-46e5-bd07-4c93d810837f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-0d4ea1e8-768e-48ac-9ca0-bc4233754fc6\" style=\"color:#555555;\">----------</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5dddba54-264d-4401-9649-8982dd6e9bc7\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-13491700-3fd6-4628-903b-6aa1e2b52107\" style=\"color:#007aa6;\"><b>회원</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-531979e3-481c-4e7f-9e1e-b70ce0b6b096\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-73c053f8-f04e-4ced-b0c4-f109ce24c74b\" style=\"color:#555555;\">----------</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d07ab613-808e-481c-979c-5807099d44e1\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-fa4ed0d3-492b-4fd9-a6b9-e398ecb59c3f\" style=\"color:#555555;\">학회든 모임이든 가장 핵심은 회원입니다. 회원이 존재해야 협회가 구성됩니다. 그렇다면 회원은 어떤 관리를 받아야 편하게 사이트를 이용할까요?</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-dc4c8e4c-fb01-4eea-a4ac-a0047cb22d8f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-c646de2f-9d8b-4496-a359-69bc1530c80e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-79a9b554-c113-432d-9559-38cab64663d4\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-cf1eefa1-1505-4e93-bcb2-e72d82b26518\" style=\"color:#555555;\"><b>하나, 관리받는 활동과 자유로운 활동이 구별돼야 합니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a1bd0cc0-e5c3-43b8-80ca-926881df7e0b\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-11ecb3c8-c638-42a7-a9d9-b12dbccb35b8\" style=\"color:#555555;\">관리받는 활동은 학회 관리자에게 요청, 승인 등의 결정을 따라야 하지만 개인적인 발표나 개별 모임은 자유롭게 마이페이지에서 활동해야 합니다. 모든 협회가 무너지는 이유는 개인 활동의 너무 엄격한 규제에서 출발합니다. 개별 활동이 자유롭고 편리해야 사이트를 자유롭게 이용할 수 있습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f7d495aa-b798-4fd9-a415-88d5318c0ee7\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-ec15adb3-7424-4174-818f-189ca13f5718\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7cbf11be-6f5f-4ea2-8038-2690be064b74\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-3398ca04-4d7c-4a1d-9485-210806a51da2\" style=\"color:#555555;\">즉, 개인 마이페이지에서 회비 관련, 모임 활동비 내역, 발표 내역, 구독 내역 등을 확인할 수 있어야 합니다. 이런 활동이 이메일이나 개인 알림을 통해 정확하게 안내되어야 합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-411601f0-749c-45de-81df-e628159bfe53\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-93a6cf13-bb4e-4251-96ff-c0bd626f7830\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-42d86e9a-3958-4485-ae3f-8eab1f986109\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-63ce4c8c-51a0-4093-a581-463f0108ea4c\" style=\"color:#555555;\"><b>둘, 행사 내역이나 개인 홍보행사 등은 이 사이트에서 관리되어야 적극적 회원이 됩니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4bc889b9-6b01-4637-a4e1-1bd12883da0c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-3075a029-cbd3-4290-923b-97334486d9c0\" style=\"color:#555555;\">학술회가 있을 때 초청장, 입금 내용, 이벤트 상황, 목적, 취지, 결과, 사진자료 등이 본 사이트에서 관리되어야 합니다. 이런 자유로운 자료가 각 회원들끼리 공유되고 추천되어야 협회사이트가 살아있게 됩니다. 이런 기능을 막는 순간 협회사이트는 그냥 공지사이트로 전락합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-10eea0f4-971c-47ff-b55b-e742faac4c0f\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223770412835/003.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-20826a8b-a038-40e7-b00e-425636c16f3d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-c66ed94c-c70f-4099-9bbe-74c8665d0837\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-2b594961-404a-4916-a9af-ec736e2d772b\" style=\"color:#555555;\">----------</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-169b8bce-0d8c-4c5e-a189-b63e0c4822b9\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-dec26822-102a-4688-b421-dd5230d00147\" style=\"color:#007aa6;\"><b>협회 직원</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-dcd2edd4-bb80-4dbf-a7eb-798bff034fb7\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-91e1247a-9589-4bd1-a89c-be2926004fc3\" style=\"color:#555555;\">----------</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8b031e0e-907f-4d57-91a8-28bba1521b3e\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-f2aa42a9-86b4-4555-80f8-4fedbf4fc8cc\" style=\"color:#555555;\">하지만 협회사이트를 움직이고 관리하는 곳은 결국 협회 사무국입니다. 협회 사무국 직원이 관리하기 불편하다면 이 사이트를 잘못 개발한 것입니다. 사무국 직원의 니즈(Needs)가 뭔지를 가장 잘 파악하고 관리되는 사이트가 돼야 제대로 된 사이트가 될 것입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e798599f-3df8-465b-a533-cdcaaa498621\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-7ba2c867-71b1-4dde-b0f3-6f85a65d3997\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a764cfae-f853-4770-8ced-75ca477510a5\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-67276294-b04a-4ebb-a7d0-6f2b09684149\" style=\"color:#555555;\">그럼 협회 직원이 하는 관리자 페이지 기능은 무엇일까?</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2051780d-0d70-405b-94a2-47225fdef4ae\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-5b13c745-20a4-48e7-b37a-166be74373a7\" style=\"color:#007aa6;\">1. 기본적인 회원관리</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-42258e62-4ab0-477c-9617-123a9d3a6d5b\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-29d2b372-37b0-4191-8fe1-809b46f8336e\" style=\"color:#007aa6;\">2. 행사 등록 및 안내</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1857bfad-a0f7-4ea5-8a99-41b2a709a27f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-8b3bddb2-e79d-44d1-a6cc-91dab5d759af\" style=\"color:#007aa6;\">3. 회비나 후원비 관리 메뉴</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-14a48b2c-c804-4f5f-8a6d-f5d5dd7197c1\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-a9cdebc4-85ea-4dea-8c37-c0768c1d8e2e\" style=\"color:#007aa6;\">4. 조직도 구성</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e89c9717-b42e-48cf-9231-f3a3b9b7310d\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-9eab0e10-9dbc-48cb-b026-15e62816be9a\" style=\"color:#007aa6;\">5. 단체 알림이나 이메일 메시지 관리 시스템</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-62abc8f2-a8d1-4699-8d48-1bc5af8b7c62\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-972a29f5-8f1c-4011-af74-b1ab3dd8c760\" style=\"color:#007aa6;\">6. 게시판, 배너 관리 시스템</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-14a81685-a2af-44c4-96be-b370ce16479a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-734fc153-61e3-4c51-87bc-73604f008f43\" style=\"color:#007aa6;\">7. 승인 설정 및 오류 수정</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e5f65bca-17e8-4a2a-a362-a58ade960aa7\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-be27f0e0-a846-4caf-9f13-e81bdc16d750\" style=\"color:#007aa6;\">8. 다국어 등 글로벌 네트워크</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-405e00e4-9e37-426e-8d53-55ff69032bee\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:862px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223770412835/004.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-813ed75a-b5af-4ede-8fa8-d64d0b350c1e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3e98445d-397e-4b1f-8fc1-cdf4205dee66\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-b4980af6-03bf-4917-bbcf-7693e62e309d\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1ebcf579-5cea-4787-8c15-de195c7b5599\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-eceabb9a-a239-4346-b7b5-96f972adb6a3\" style=\"color:#555555;\">----------</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-be239ceb-7c11-4f64-ac74-d4598f5af37f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-1238a6df-d82c-4993-b655-9ee7d41d7c10\" style=\"color:#007aa6;\"><b>협회 임원</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e9102f7c-a498-45bf-a24b-251f8a579a71\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-26de7bc1-1223-49b6-8cb0-e52213380ed7\" style=\"color:#555555;\">----------</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1ed1e636-b1ad-4fce-a913-471c30f72db6\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-ac01e5cd-70c7-4e20-93fd-abd42543b0a0\" style=\"color:#555555;\">협회에서 임원만이 볼 수 있는 페이지는 따로 있습니다. 실시간으로 일어나는 변동 사항을 체크하고 리포트를 전달받을 수 있어야 합니다. 또한 권한의 이전이나 설정 기능은 무엇보다 중요합니다. 대부분의 사이트들이 권한 이양에 대해 로직이 확실치 않아 사이트가 흐지부지되는 부분이 많습니다. 신임 회장의 취임이 꼭 사이트의 단절이나 리뉴얼의 대상이 되는 것은 서글픈 일입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-63680f32-96d9-4454-a1ef-9bcefed6247f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-27061df0-5253-4622-b3c0-64492100719f\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-78da4ed8-c001-485a-a092-7bcc3c7d89bc\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-cbac183c-8c24-4d2a-9a55-cacfe8745882\" style=\"color:#007aa6;\">1. 회원 통계 및 동향 분석</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-15bd81e7-ec89-4315-8e8d-587b1f294786\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-180177a4-5a27-42e0-a919-8ae9e77a4118\" style=\"color:#007aa6;\">2. 행사에 대한 결과물 자료</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-0763c93e-eaac-4124-9425-b312df4462c5\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-7c8a0b89-8b41-4aa6-815e-1bca9e758eab\" style=\"color:#007aa6;\">3. 각종 약관이나 문서에 대한 업데이트</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-21c3d366-9558-483e-8bd0-889ee70d2a8a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-c6f7346d-0791-4121-bdcf-b81abaa40ec9\" style=\"color:#007aa6;\">4. 학술 문서나 보고서에 대한 디비 구성</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-b0cbd225-3201-4d08-8665-a4af29030d9f\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:862px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223770412835/005.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-5a7cc5b6-9c8b-43f5-a202-f7d182950526\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-75a01415-2df0-4549-a85a-26ccbee24489\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-bd9c845b-f761-4750-ad83-159f6d48d98a\" style=\"color:#555555;\">이제는 협회사이트 전문 </span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-aa14ddbd-295c-4ba3-a799-8cdf3a35d538\" style=\"color:#007aa6;\"><b>데버</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-b2b69fc3-7c8b-4733-bc09-0d17df87d174\" style=\"color:#555555;\">와 함께하세요</span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-dde3677b-1f08-414a-9895-be87946006f9\" style=\"color:#007aa6;\">.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6d814055-eb0f-4e1c-842c-541df9b56214\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-d0a75144-ca16-4cd4-8dcf-b53f4f932b2f\" style=\"color:#007aa6;\">가장 잘 만들 수 있고 관리가 중요한 협회사이트를 개발해 드리겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-c2dcfecf-571a-4847-97ae-f89abbe0d983\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-f8dfcebe-d0c6-4315-b128-c6b28b78b104\" style=\"color:#007aa6;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-1418b90c-befd-4fc1-8b9e-69500b0bf9bc\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align-center se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;ref=https%3A%2F%2Fm.blog.naver.com%2Fcookthedesign%2F223770412835#nafullscreen\" onclick=\"sendClickNlog('pst.talktalk', '');\">\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n</a>\n</div>\n</div>\n</div>"
}