efault se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223852204154/000.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-b58ae846-7353-4a89-b930-438da93f1558\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f41d5a7a-7a6e-4cf9-8eb1-225f1042b74c\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-764ef64d-8365-427b-9130-91eea51de848\" style=\"\">제작 사양</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-fa2bb5fc-67ce-45fb-8eca-b29f4a4e8042\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-c4a86ec8-2ac8-4857-82f6-ab0ffb1f7b0d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-c6b9deb7-40b4-4085-9e52-ba8753ac2ec2\" style=\"color:#555555;\"><b>종이 : </b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-24775ee0-ad73-4887-9d4a-8aa348fa4a86\" style=\"color:#555555;\">반누브 화이트 250g</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fa160e06-aa7f-4140-8121-00b1bfc06fd7\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-4b1f63c6-b6bf-4549-a0dc-dddeba369a8a\" style=\"color:#555555;\"><b>사이즈 : </b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-553da1f9-5783-47f6-b179-407a7410369f\" style=\"color:#555555;\">A3, A4, 60mm × 85mm 3종</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7a37f9a0-21a4-4d10-ab0e-c3a505298e8b\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-4128e60b-b8ce-47f7-829c-f8fa7e29ab11\" style=\"color:#555555;\"><b>인쇄</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8b7e02ec-35c1-4a44-8896-79056c49cfa9\" style=\"color:#555555;\"> : 단면 인쇄 2종 / 양면 인쇄 3종</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3ca54727-5434-4ca0-be89-1eb3f3e911b8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-186d8598-6c2e-447b-96fd-0295bf395c44\" style=\"color:#555555;\"><b>후공정</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-04f9d6d0-6ee6-435a-a2a1-01f7b8731193\" style=\"color:#555555;\"> : 없음</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-932f2589-48c3-43a1-b606-fe3ec3775348\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-d5996533-96a6-489e-a96f-54e053c9ff9e\" style=\"color:#555555;\"><b>수량</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-414c4c82-dee2-412b-907b-7cc9fd1450b5\" style=\"color:#555555;\"> : 각 1장 / 3종은 50장씩</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-16bb69b2-d293-4fcf-993f-16afe153d1c4\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-3f5691da-cf13-4d00-8316-e17b21d466e1\" style=\"color:#555555;background-color:#fff8b2;\"><b>납기</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8f601621-9ea3-4d90-a148-173889f082ab\" style=\"color:#555555;background-color:#fff8b2;\"> : 당일</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-29975e48-499d-4c46-9809-07d8bf568b42\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2974c03d-0fea-4be9-aef0-121503a3f721\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-38e32953-e206-41fc-a660-4cae33483130\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b1fb85f4-10d2-4ebc-9b9f-9c099d682123\" style=\"color:#555555;\">급한 고객분의 요구사항은 매우 단순합니다. 종이나 수량, 후공정의 내용보다는 납기가 가장 중요할 수 있습니다. 고객의 \"급함\"을 진심으로 이해하고 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-20843880-e35c-431b-9e25-51bd1c791608\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\" style=\"max-width:830px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223852204154/001.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-ab1a38e6-310b-4ffa-89c5-60b3c04894b2\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-abeb9f6c-ffcb-43ef-8f20-c39250f7057c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d2346f8c-d03f-42e2-8721-78915a67ab08\" style=\"color:#555555;\">디자인 데이터는 너무 이뻐서 이미지로 공유해 드립니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-b27c9df6-0884-4541-93ad-985b923ae0a7\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223852204154/002.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-image se-l-default\" id=\"SE-c06fed27-98b0-4527-a33c-f7d1222c3ae7\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223852204154/003.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-050d5d80-8d0c-446d-b428-7887618a68cd\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-8348d51c-577c-49cc-b13f-dba3372ebe5e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b3ed3942-b1f6-46fb-a7d3-98f82a12c908\" style=\"color:#555555;\">카페의 이미지에 맞게 파스텔톤의 오렌지와 박하 그린으로 잘 표현된 디자인이었습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-632282b7-fad2-41d5-9b38-0512b27dd968\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223852204154/004.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-image se-l-default\" id=\"SE-09d8fbfc-cf8a-4adc-998e-e48c1f1fd8e6\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223852204154/005.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-image se-l-default\" id=\"SE-2030b801-deae-42f6-b697-3baeb7ecd43f\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\" style=\"max-width:823px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223852204154/006.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\