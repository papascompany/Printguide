d58b294f3de28c0892f4733cfb9fb9cec62/223695253093/004.png\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-362f0c5b-bfe7-4543-9603-717e8f3815d5\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-99744783-f37b-431e-a5cd-5b57b5caf80b\" style=\"\">네이버 어학사전 출처</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-d7ed2edd-4dd0-4df2-a1d2-23fa5221a987\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-bac9994c-3fb1-410c-b4cb-682a57e05dc6\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-1062b869-3b6e-4fd1-b398-f7d889b1776e\" style=\"color:#555555;\">이 말은 일반적인 용어가 아니라</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-019100a6-3233-412c-8aed-adfcc3f96b6a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-eed11ef0-9568-4d88-83b6-5a25b617b05a\" style=\"color:#555555;\">인쇄소나 주문자가 사용되는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-dcf2b0ca-ccd2-41b2-bd38-d35a7738d2c1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ee3d6bea-dae0-4ec7-858d-2342092f5769\" style=\"color:#555555;\">통상 용어로 풀이됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9790e3ba-acee-4845-a30a-db24d584441e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-05471051-7f51-4c7b-a212-0358c9da116d\" style=\"color:#555555;\">기본적으로 패키지, 박스, 상자 등을</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-00fff557-12d5-4f9f-8729-54d22c7cb4c1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-bc5870e7-4c50-4d1a-8605-a010fcf919a0\" style=\"color:#555555;\">구별할 때는 단상자, 싸바리, 합지 등의</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-7881c26a-0006-4c2d-a8da-924f433c2eb1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8240a466-83c2-415a-b058-ed952e252faa\" style=\"color:#555555;\">용어 등이 용도에 따라</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-5879f1df-c4a7-4175-8efe-b82915fcd515\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-44c7fa6d-7f2b-4892-a813-550dcfaa458f\" style=\"color:#555555;\">사용되는 경우가 많습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-53981cd8-bf86-48f4-a33c-148b25582768\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a5259c69-cb79-4cf2-964b-95ebff2a7888\" style=\"color:#555555;\">이 용어 또한 인쇄업체의</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-c00c2374-e58c-4398-b0cf-9bab0f018cf3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-42d25d4f-9108-4975-8577-c43109a3945e\" style=\"color:#555555;\">일반적인 구분일 뿐</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-8617b06a-a718-4efb-8aac-99c8c922302f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2bd23e78-293a-4ea0-8474-5a3508c0b54f\" style=\"color:#555555;\">전문적으로 확정된 용어가</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-6cc70232-c756-43de-aae3-9c46e8fab6ef\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-96f7d96c-2b01-42db-b65b-19eb58ef9c8b\" style=\"color:#555555;\">아닙니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-c9adae40-3f11-4953-94a5-2c02bdc60940\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6791f1b3-8031-45ef-9d22-52eb0b6fcdd1\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-558665e5-4f6c-4891-8d9f-9cbccc8b4abd\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6248b4ef-aea4-4521-9837-d699c0fbf794\" style=\"color:#555555;\">하지만 일반적으로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-a4d15e54-5411-4ff5-90aa-ca979b6cf74d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-80aa1ae6-606a-445f-a6f2-6853f044e6dd\" style=\"color:#555555;\">단상자는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-e5fee0ed-790b-489b-aab4-6117bd46ac01\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-725e51fe-f8f6-49e8-8123-b6452539a91e\" style=\"color:#555555;\">합지나 싸바리처럼 뭔가</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2499dc3d-5418-4914-a863-35eb585ce46e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-9ba7eb01-a810-41c2-9ba1-cc50458c699c\" style=\"color:#555555;\">합쳐지지 않고</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-6e5bf5c6-a5de-4366-a07f-2b9ee40db0ec\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-fc6a8a65-c8ff-4f50-9230-2962029066cc\" style=\"color:#555555;\">하나의 종이가 포장지 그대로의</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-fae573aa-e3f5-4d76-8723-96bde945454e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-3f21255c-1337-428a-b347-48a23a1af17d\" style=\"color:#555555;\">역할을 하는 상자라는 의미를</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-af34796e-db67-4ce0-99f2-ee1d9cb6a505\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-fe770f81-62d2-4b44-8c05-c6c01207689c\" style=\"color:#555555;\">내포하고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-1201270f-6b54-479a-b667-46a7cd549b30\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0b2b4b9a-141e-42f0-93e6-f442fd920a5d\" style=\"color:#555555;\">이건 두꺼운 종이 하나로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2e9cede7-e12b-482a-b47f-e41da5757c57\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a141e3be-0a21-402e-87ea-746df4339cb8\" style=\"color:#555555;\">제품을 보호하는 포장재로써</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-8a57022c-f279-46a6-9023-94d5944cdadc\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-19394b91-31a6-46b4-816b-bf07734a46a1\" style=\"color:#555555;\">역할을 함과 동시에</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-3cdf9d2d-386f-4df9-aed2-23b1ce89c664\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-528118f6-0101-4bc9-9183-b42ab4f9e8a1\" style=\"color:#555555;\">단가나 생산성면에서</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-e99a4963-f256-47c8-aece-62361ae8cc4d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-90516f61-b799-4ae6-a141-65e2a8a3f58c\" style=\"color:#555555;\">합리적으로 진행할 수 있음을</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-ce20d8de-995e-4bdb-a2c4-161bef18848e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-fa202c21-316f-4cd6-b8b9-164f4ea7acc8\" style=\"color:#555555;\">뜻합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-6dec7131-11a4-4d45-a680-08d6f8f0eb6f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-273e2dc3-d796-4962-8e59-637561c9d9cc\" style=\"color:#555555;\">이런 이유로 단상자는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-62e2b1de-3f42-4761-b637-a9d039387d63\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-475bff09-11b2-45d0-b6d5-d9c9a14d3961\" style=\"color:#555555;\">다음 유형에 적합하다고</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-917af3cc-5339-460d-a111-9f33b1cf5e41\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-09651a22-d2b3-4a71-ab7a-f53ff1ee0f21\" style=\"color:#555555;\">할 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9b3bc2d4-318f-4475-9677-298296f8cc06\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2469d462-f55b-40f8-97c1-072f3f893330\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-6eebf883-0269-4d06-8559-3cb4ca518a11\" style=\"line-height:2.0;\"><span class=\"se-fs-fs24 se-ff-nanummaruburi\" id=\"SE-b4021a42-ac3f-4341-a68c-2064f093bd1f\" style=\"color:#555555;\"><b>1. 화장품 케이스 등</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-e67c7306-8709-4c89-9a7b-62801d2e7f15\" style=\"line-height:2.0;\"><span class=\"se-fs-fs24 se-ff-nanummaruburi\" id=\"SE-0027293b-3075-4006-87f1-fff4dd9752e2\" style=\"color:#555555;\"><b>포장재가 단가에</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-78e6a203-ceac-4889-912c-2f0a886287c2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs24 se-ff-nanummaruburi\" id=\"SE-fceb735b-4bac-4092-a515-599ce9ff1759\" style=\"color:#555555;\"><b>포함되는 경우</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-6693f833-5c59-4cf0-9432-4bab705b8af4\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c8a3510f-ca33-4df7-83fa-81ef2f346c78\" style=\"color:#555555;\">이 말의 뜻은 과대포장되지 않으면서</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-a04b9e8c-be47-4ef5-964e-631b3d89571a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8cd9f448-52a5-43c5-8a4b-edcc7f9b5182\" style=\"color:#555555;\">단가를 가장 최소화하여 제작할 수 있고</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-da18baad-e123-4e99-bc2f-77683303b6b8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ca3078f9-e7a5-4fe1-a096-7cdef5bd81e1\" style=\"color:#555555;\">다른 싸바리나 기타 박스에 비해</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-f52bad98-497e-48a8-b844-b71d6dc0c6f3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-3c73ce45-471c-4d2b-95ee-b2cb91baf732\" style=\"color:#555555;\">비교적 공정이 단순하여</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-994dd00d-6bf9-426d-a2f7-da4cd0ca7049\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-75aab144-88fe-4e9d-8726-a79620fbbb3e\" style=\"color:#555555;\">제품의 단가를 합리적으로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-35c22e0a-43a8-44ae-8606-498f699c927a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-3a46af3f-bf2c-4dd0-a791-6caf00359c86\" style=\"color:#555555;\">줄일 수 있다는 뜻입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-8c43fe35-a5ca-4553-9549-f2be981d3155\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-center\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-5ff554ed-eaa6-4bc3-a20b-94768fc2dac0\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-d23415b3-986f-41bf-ba53-d057f4c7b8d3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs24 se-ff-nanummaruburi\" id=\"SE-fc8e2c38-7d4c-4302-b3b8-dc587009a037\" style=\"color:#555555;\"><b>2. 제품이 비교적 가벼워서</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2219b54b-d659-4624-9aa6-c19e42f87f23\" style=\"line-height:2.0;\"><span class=\"se-fs-fs24 se-ff-nanummaruburi\" id=\"SE-372e59ff-ab33-4f6d-920b-e277199f8509\" style=\"color:#555555;\"><b>포장재로서의 기능이</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9bcc7d4a-b00c-41d6-83e4-a81f3b9f8e66\" style=\"line-height:2.0;\"><span class=\"se-fs-fs24 se-ff-nanummaruburi\" id=\"SE-28f2ac81-09ad-4302-b76a-0ad7c99db1b2\" style=\"color:#555555;\"><b>운반이나 보호용이 아닌 경우</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-412a8bca-03ed-463c-b252-3f8787f63dd2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-394c51c0-e69a-403a-82f8-0159d9c940ee\" style=\"color:#555555;\">포장은 기본적으로 물건을 보호하는데</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-32d88915-118b-40fb-a493-d00fc9bc7d38\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-fa774772-4d47-4ccb-b2b0-f653a4f22897\" style=\"color:#555555;\">1차적인 기능이 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-1810442d-92d3-4533-bdfd-8b4d6e91ef35\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-91a2e31a-f346-448b-bbf1-c74779769dbb\" style=\"color:#555555;\">다만 가벼운 제품의 경우에는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2b0263f1-27d1-44b8-8d72-4323282e04be\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-9f10a007-694f-4055-aff6-d823026c9bd6\" style=\"color:#555555;\">보호보다는 선전이나 홍보</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-3b2ffbf0-95a8-405f-af4a-8185a4acf23d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-818932a1-47f8-4d4d-92df-d97158ae6e9e\" style=\"color:#555555;\">또는 제품의 품격을 높이는데</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-1d9ca6ad-40e7-45a6-acad-e8bd12be4de2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0917fae5-b479-4431-a4df-e66b6e55ac32\" style=\"color:#555555;\">활용되기도 합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-fbe39c60-2293-4394-b89d-8c0453b08e11\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-de312a48-e9a5-4507-9748-16fc009bcadf\" style=\"color:#555555;\">특히 화장품의 경우</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-64fe72bf-1e07-4c62-8900-427ba62391de\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b56f84ef-60c8-41e9-8e02-4b276a6dead0\" style=\"color:#555555;\">내용물이 가벼울 뿐 아니라</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-6a7b23dd-f2d5-48e7-8f8a-4d3b613cb730\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-aca8b50d-7567-4697-87f0-0eb5fdaa9827\" style=\"color:#555555;\">그 안의 제품이 보호보다는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-8e19d3c2-a14a-467d-9b23-4066a3e9a5db\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-664ee296-dd86-4540-80fb-ac68c8dd1987\" style=\"color:#555555;\">사양 설명이나 사진 등으로</span><