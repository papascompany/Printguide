  "content_html": "<div class=\"se-component se-text se-l-default\" id=\"SE-1a0c8643-f2ac-4326-8871-035b7c77878d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-fa5ae9e1-d693-42c2-bce3-a744295fc511\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-3fd6c261-483b-46ae-bd10-db63c8603536\" style=\"color:#555555;\">안녕하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-165bddbe-4289-4aed-925b-8a7ca33d4f4a\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-cbb8fb2b-b07f-445d-b4f5-61b343037edc\" style=\"color:#54b800;\"><b>인쇄물 전문 제작</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9b7d2f29-973b-4a52-8b9f-e9f17f028773\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-8174a932-b6a7-402e-9545-7e73638293e0\" style=\"color:#ff0010;\"><b>(주)파파스컴퍼니</b></span><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-ba12b1e6-f886-434e-929d-311e7e5682eb\" style=\"color:#555555;\">입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-imageGroup se-l-slide\">\n<div class=\"se-component-content se-component-content-extend\">\n<div class=\"se-section se-section-imageGroup se-l-slide\" id=\"SE-0dda875c-1f88-4f25-8cf1-4bb3ac052e8b\">\n<div class=\"se-imageGroup-viewer\">\n<div class=\"se-imageGroup-container\">\n<div class=\"se-imageGroup-item\">\n<div class=\"se-module se-module-image\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/000.jpg\"/>\n</a>\n</div>\n</div>\n<div class=\"se-imageGroup-item\">\n<div class=\"se-module se-module-image\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/001.jpg\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-imageGroup-navigation\">\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-prev\" type=\"button\"><span class=\"se-blind\">Previous image</span></button>\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-next\" type=\"button\"><span class=\"se-blind\">Next image</span></button>\n</div>\n<div class=\"se-imageGroup-progress\"><div class=\"se-imageGroup-thumb\"></div></div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-a639e795-010c-406c-a8e1-aa2f69272207\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-de916473-4cae-4dc9-86ef-11bb63dbdc98\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-c07387d7-f7a1-4efb-80c5-6fcdf918b246\" style=\"color:#555555;\">요즘은 3D 금박이 유행입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-e36df789-83c4-4f88-a51f-d1d17a60b070\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\" style=\"max-width:677px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/002.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-647c086e-510b-40cd-afef-12250184914f\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-c9eec298-b516-428a-9434-6f42a3ccd1e6\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-0ebb72c8-30cc-4e51-b917-2eab19300786\" style=\"color:#555555;\">3D 금박은 박인쇄를</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-31a11332-1518-422e-8c64-c2b786cf7ce2\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-1a086980-c3fb-41a4-87de-4ccebd7d1727\" style=\"color:#555555;\">조금 더 도드라지고 튀어나오도록</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-c14c0fad-9b04-4e81-9340-09aac85b1875\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-94afe91f-1f97-4275-b165-2698a041cb42\" style=\"color:#555555;\">제작할 수 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-4101916d-9615-4780-8684-4e967e96a31e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-156e84ba-4ae8-4562-ac8a-0b0c2d8c4089\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-81bb8efa-d230-4ee9-ad8d-dc33e90d7d5d\" style=\"\">최고급 막걸리 병에 접착하는 스티커</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-4a517379-6f78-4d94-bbed-54412ba82167\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-359d4892-16be-4c35-a2f0-7bab0af91df5\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8d164e70-6b19-4f4f-98dd-ebd534cc0118\" style=\"color:#555555;\">와인이나 술병에 부착하는 스티커는 여러 종류가 있습니다. 이 스티커는 단가가 중요할 수 있고 또한 퀄리티가 매우 좋아야 할 수도 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1b8ac634-35cd-4795-9768-0a6cd15ab938\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-3087f054-b1f8-4e9c-ac3d-8e3546d6c2f7\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8d47dab5-a67a-4f1c-bbc5-a2f4d64d77a3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-984a3d28-f7be-4212-bd40-19c471597698\" style=\"color:#555555;\">오늘은 가장 고급스럽게 만들 수 있는 스티커를 소개하겠습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-6cfd3a7f-3ede-4929-ab6e-44f37924aa86\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:675px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/003.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-31b1fcb8-b84c-4ec2-8fda-d9a72ec89f6c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2e7c56bd-72a9-4c13-85ef-34bf01b8435b\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-39216a99-c864-47b0-b979-2baa5f9a9ad0\" style=\"\">박인쇄 + 형압시 주의점</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-a1e7d44c-19b2-44cf-ac00-22e6fd66d1d2\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-379f7a06-8471-4533-b5d4-e5e94cbf4edf\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-667b2777-796c-43d7-85ad-69f192611e3b\" style=\"color:#555555;\">박인쇄와 형압을 함께하면 돌출되어 보이고 너무나 돋보이게 만들 수 있습니다. 이런 작업 시 중요한 점이 몇 가지 있습니다. 한번 알아보겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-43054a6a-25ca-4e8d-a347-0e788fce94b2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6a87ab63-06b8-4f87-b2c6-812e2080adc2\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6d3a775d-12de-4967-ba1b-71ddd73f1fc8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-316a9e9c-92ce-4b19-b1f8-71e45d5cc079\" style=\"color:#007aa6;\"><b>1. 위치가 정확해야 합니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-81574c11-dfaa-443f-b4f8-76e4aab6f060\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0500b05a-70db-40d2-ad0c-b39652eb871c\" style=\"color:#555555;\">금박인쇄와 형압의 위치가 같다면 그 위치가 정확하게 맞아야 합니다. 이 위치는 정말 맞추기 쉽지 않습니다. 특히 스티커의 경우는 더 심합니다. 스티커는 끈끈이가 있을 뿐 아니라 장력이 강하고 특히나 코팅을 하게 된다면 그 위치는 약간의 틀어짐이 발생될 수 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-8471a958-da93-472f-8631-e9adddaa0921\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/004.jpg\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-e5ee5888-7645-41e4-88d6-7496ea788d29\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d8cf7700-7ea1-49a3-8d38-4fc35a7f94c7\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b995e7f4-011b-4648-818b-e2d2ac246e12\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-69ba123f-6624-4e59-8b91-0db7b5a99976\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-8d38dcf6-abd6-47ed-8b96-6752f2108b91\" style=\"color:#007aa6;\"><b>2. 박, 형압의 종류도 많습니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5d0997ea-f2ca-4eea-8a7c-b9f93d3c9868\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-63220e91-e522-42be-9a48-ed0d2e755324\" style=\"color:#555555;\">금박인쇄는 밝은색 어두운색으로도 나뉘며 황금, 적금, 브라운 금등 색상도 아주 다양합니다. 또한 형압도 돌출과 오목으로 나뉘지만 스티커의 경우는 돌출로 보통 작업이 됩니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-81e526d9-8e8d-44d2-836f-f1c73f78bd1e\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/005.jpg\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-926754df-f170-4d6a-b994-bdcef53ceb6d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7373922e-a596-43ff-8451-c448731bfcf9\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-cfb11ba9-3a0a-4ac4-93fc-90b47650f125\" style=\"color:#555555;\">박인쇄의 종류도 고르면서 형압도 선택하는 것이 중요하면서 그 위치까지 맞아야 하니 정말로 어려운 작업입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-b202f051-ec33-4900-be45-a7cc906b8716\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:669px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/006.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-4927434c-54e1-4e85-b5df-182c842c6b1c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fdfd1671-e44a-446d-aaf3-19f0c0c12bd0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-56dcdb2f-e190-4393-b91a-f1fc2180b479\" style=\"color:#007aa6;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5ae29905-aa4c-49fc-8f90-be6132ed2438\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-a2852c59-5d12-4e0c-ba91-f1e2f6b9adc2\" style=\"color:#007aa6;\"><b>3. 박을 하는 개체는 얇으면 안 됩니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-18948534-d1a5-4171-9a52-847a076cf062\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-02c195fb-0339-4771-a687-c2ae1d814d05\" style=\"color:#555555;\">금박인쇄나 형압을 하는 디자인 개체는 얇으면 표현이 안됩니다. 반드시 어느 정도 구현할 수 있는 얇지 않는 개체여야 합니다. 작거나 얇으면 인쇄처럼 절대 구현되지 않습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-dc133e8a-2c4e-491b-8ff7-ded9623cbab6\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/007.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-image se-l-default\" id=\"SE-88870ddb-0382-4503-b4df-2c1a875c43c1\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:775px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223869465323/008.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-9d02bf15-2985-4f17-854a-ced81de1f84e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d220e217-9b35-4ca2-b374-0336ca9597e4\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-86e5e520-6050-43ae-b7fa-ff9e929189b6\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-84b4235f-16cd-47e2-92b5-906681a8eae3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8f120924-685a-4934-ae8c-502252ab5bb3\" style=\"color:#555555;\">이런 얇은 부분은 금박이 잘 표현되지 않으니 조심하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8d815b3d-bf70-406c-86f9-fda1b659f5f9\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c45659c9-76cb-48e9-bf0c-0853c09e4ab1\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f594b64c-8db5-4ca1-b6a2-059ea07463ba\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-34ae6c28-6f54-47be-879b-92b459e92116\" style=\"color:#555555;background-color:#fdd5f5;\">(주)파파스컴퍼니은 언제나 고객의 입장에서 생각합니다. 거래 유무를 떠나 언제든 문의하세요. 항상 좋은 인쇄물이 나올 수 있도록 노력하겠습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-1418b90c-befd-4fc1-8b9e-69500b0bf9bc\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align-center se-l-default\">\n\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n\n</div>\n</div>\n</div>"
}