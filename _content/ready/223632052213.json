gn-center\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-c682c215-ceb6-4e0e-8bd5-5e847aa4fc2c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-03f51c8e-8528-4979-8715-052e622b2e8e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ec1538aa-951c-4ef9-b943-76576335bbb9\" style=\"color:#555555;\">패키지 솔루션이 궁금하신 인쇄업체는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-c7fab20a-3be7-4591-a9ab-9d4e19599800\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-bd89ac23-629d-4eb7-be2a-df8b67f28d40\" style=\"color:#555555;\">다음 블로그 글을 참고하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-31cb9db4-4b2a-45a2-8c92-541048ff2df0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0905c568-261c-49c7-8033-d4483bfe272c\" style=\"color:#555555;\"><a class=\"se-link\" href=\"https://blog.naver.com/cookthedesign/223478468341\" target=\"_blank\">https://blog.naver.com/(주)파파스컴퍼니/223478468341</a></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-a803b595-429a-445b-a8df-9ed84634f0c8\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-center\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-wrappingParagraph se-l-inner-left\" id=\"SE-c126ca57-ca81-4039-a39b-69c32e07d238\">\n<div class=\"se-component-content\">\n<div class=\"se-component-slot se-component-slot-float\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223632052213/007.png\"/>\n</a>\n</div>\n</div>\n</div>\n<div class=\"se-component-slot\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9774345c-0536-4a7a-b96c-6d3ba3cc5077\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-450f0e6b-b6e2-4adc-8320-a8a15a929f10\" style=\"color:#555555;\"><b>패키지를 잘 만드는 팁!!!</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e1362863-f384-440c-9762-5d8a0215fcd0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-9af3735b-0c9c-46d7-bfce-bbaf43f04e5a\" style=\"color:#555555;\">당신의 패키지를 가장 잘 만드는 방법은 이것만 기억하세요. </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-e1571da7-debf-451b-9e46-8f5218151cab\" style=\"color:#555555;\"><b>첫째</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8f5c4abb-71f4-4fc7-9adb-11949cccb3df\" style=\"color:#555555;\">는 안에 담을 물건을 고려하여 </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-e5c31364-d3d9-4a10-a93a-cd91710fa30b\" style=\"color:#555555;\"><b>스타일을 정하는 것</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-de53c394-6978-4200-b36d-f89e3e0c34c4\" style=\"color:#555555;\">입니다. 이 말은 안에 담을 물건이 무거우면 튼튼한 박스스타일을 선택하셔야 합니다. 튼튼해야 한다면 선대를 선택하거나 패드 등으로 안에 내용을 보강해야 합니다. 두 번째는 </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-323f7f5b-c701-49fb-84e8-e7eb93d22b57\" style=\"color:#555555;\"><b>디자인 방향, 위치</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-f6b64d8e-5405-4e56-a613-5bc93f609c11\" style=\"color:#555555;\">를 잘 판단해야 합니다. 이것은 열어서 보이는 정명의 방향이나 뒷면에 보이는 내용, 사이드에서의 간격 등을 고려하여 작업해야 합니다.  </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-3d1dd082-c942-4818-a4d4-9c8379f268a4\" style=\"color:#555555;\"><b>세 번째는</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-163d688f-baae-4df8-8707-663b1c30d75e\" style=\"color:#555555;\"> </span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-69966b64-aafb-4912-acef-e15c2cf8a862\" style=\"color:#555555;\"><b>단가와 납기</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ca92273a-9971-408e-aa83-7a694b30afac\" style=\"color:#555555;\">입니다. 수량이 많을 경우 반드시 소량 샘플을 제작하십시오. 계약의 사고를 방지하기 위해 가장 비슷한 모양과 종이로 샘플 제작을 추천드립니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a454f8d1-1175-41d3-b16f-ff28ca212eab\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2c612926-a630-4e95-a4d1-c028284e3757\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-wrappingParagraph se-l-inner-left\" id=\"SE-e5020431-0b62-4f97-9055-4fa96df4fff1\">\n<div class=\"se-component-content\">\n<div class=\"se-component-slot se-component-slot-float\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223632052213/008.p