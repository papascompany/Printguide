lt se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223775233547/005.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-a7b16f9d-6152-4b9e-8b9e-f26a0fe68d5f\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a9465a62-307c-4946-8e3e-bb75b752828b\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-62c09856-4d65-405c-99d5-1bd9530548f9\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2ab8ac4b-ad72-484c-a843-e5e7515998e2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-11eb80cd-4c1f-473a-922a-697dffcc7c05\" style=\"color:#555555;\">모양을 자유롭게 하고 싶을 때</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-183cc716-4566-4cdd-892c-a1dc9f05ccd1\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\" style=\"max-width:483px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223775233547/006.png\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f10dd2ba-a885-4565-a2dc-827d748562ef\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-80c8be76-7abb-478a-9a1d-8666e2c19554\" style=\"\">pinterst 발췌</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-21814efb-11ef-4300-a8ea-16c82551acea\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-575edcad-e48f-432e-8420-30f40d946f5e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f2c4533c-ed4e-4974-af12-2c66ccbdf5c8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-3b14e02b-37d3-40e4-8945-4337c37266ed\" style=\"color:#555555;background-color:#fff8b2;\">(주)파파스컴퍼니은 고객의 입장에서 생각합니다. 항상 가장 빠르게 소통하고 품질에 진심이며 합리적인 단가를 제시합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-ca311007-fc70-4720-afcc-f80389225287\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-6667e1de-a842-49f7-afc7-9e24e3dcf371\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1dd85b43-da36-44fb-ab6d-bf7cd3c4ee42\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-35b7711b-e3b2-4f6c-8b59-e81941dd45fd\" style=\"color:#555555;\"><b>(주)파파스컴퍼니이 추천하는 봉투</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a33cb652-bb61-4dac-8758-cf8ed1838f91\" style=\"line-height:2.0;\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-b39fbd9e-4f1b-4f94-a778-cb96cdfdeca8\" style=\"color:#555555;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e3b79bc7-8e72-4503-9bbe-c3c24a893f5a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-ee5b550c-b523-49bf-a72e-c4e8008050f5\" style=\"color:#007aa6;\"><b>양면테이프가 아닌 끼움 형태의 봉투</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2f066c67-7663-4456-92db-1776cc0c5b92\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-3dabdc1d-dc84-4ee8-814d-c461b159649e\" style=\"color:#007aa6;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f53c3294-c146-499a-8022-ad9e9ab13aad\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-29b2d2da-f4f1-48a4-94ec-f90b05dcece3\" style=\"color:#555555;\">일반적으로 규격봉투는 양면테이프로 마무리하여 양면테이프를 떼서 접착하는 경우가 많습니다. 이 방법이 아니면 거의 풀칠이나 스티커 처리가 기본입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-78d2b60d-84fa-4746-a39d-23d2dd617461\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ed52c219-d9fb-42f6-96fb-227ef9a200f9\" style=\"color:#555555;\">이런 방법이 일반적이라면 끼움 봉투는 하단과 겉 뚜껑에 끼움 도무송(톰슨)을 만들어서 끼워 닫을 수 있는 형태를 추천드립니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-679cef55-f0c9-494c-8a38-9b2e14390969\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223775233547/007.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-7fb9dcb6-e21c-43a9-90ba-fa971a85c5ff\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-32c3860e-5401-42b6-91b6-f01bebe53cd7\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c1b35ad5-4960-480c-87d0-77c85965a779\" style=\"color:#555555;\">이미지대로 끼움 형태로 만들면 더욱 안정적으로 속에 제품을 보호할 수 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-56bfa86c-97cc-4303-8e1b-dcc7f1763e52\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-4916f0a4-3ec4-4273-9d82-8ef0c34c922c\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a3c18527-4bf8-4132-bde5-df6b37aadd80\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-23da572a-4f33-4bd4-a56d-4f9f36ee9422\" style=\"color:#007aa6;\"><b>종이를 검은색으로 독특하게 만드세요.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4a5ea354-ad4b-458d-aef9-c1b5829555a2\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-a4b27f5a-c60e-434c-b30e-4290f6f88294\" style=\"color:#007aa6;\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-8a9e7f90-7c9e-4b52-9aac-709e7b6c9fae\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b22efa52-01c0-410e-a146-c893de379f44\" style=\"color:#555555;\">검은색에 백색이나 은별색으로 봉투를 만들면 더 특별해 보일 수 있습니다. 조금 더 고퀄리티의 봉투를 원하시면 색지 종이를 사용해서 제작하세요. 보다 특별함을 느낄 수 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-8c05b65a-1073-445c-8059-7e5a78decc24\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223775233547/008.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-7546656f-b952-4b0b-aa48-7dfbda4801d7\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-18438fa3-8d51-4e30-97a1-1f466e46d085\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-dbe00039-5715-4ff8-90f2-73ad8f2dd83f\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { 