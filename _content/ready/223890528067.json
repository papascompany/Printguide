TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-ca808ce9-675f-4cb1-9b09-3785afa2ff10\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-cdf6cc18-3436-4ca8-843e-b9ae4fcc38c5\" style=\"color:#555555;\">어우러지는 패키지 가능</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-1e0c81aa-9e6b-4e1f-ad3b-4d7e9a43296c\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-d4af7680-f7bf-48e8-84b2-69e012c46017\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-6d5e7aab-e320-4258-8bce-cf8123c3d9cb\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-17e731c5-4f2b-4ba7-8598-2805a9d31aac\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-e968e4cf-8687-4e4c-992b-7dbad1d1112d\" style=\"\">제작 시 유의사항</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-e4a9391d-815d-48aa-bca6-c17f7f87226d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-50e551d6-dd1f-43e5-9dda-1bd50b5b172e\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-8250c8d6-afc1-4d2b-8546-94fba0ac26f1\" style=\"color:#555555;\"><b>최소 수량 확인</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-1e482dff-42d1-45e5-a9c2-15017309c509\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-89f3466f-1776-44a3-b53b-452ac