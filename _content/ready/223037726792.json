se-imageGroup-navigation-button-next\" type=\"button\"><span class=\"se-blind\">Next image</span></button>\n</div>\n<div class=\"se-imageGroup-progress\"><div class=\"se-imageGroup-thumb\"></div></div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bae0cfcf-36d3-460b-9cad-393bd7001e47\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-6a969524-f8ce-4f6f-a64a-b3503107dac1\" style=\"\">이음건설 카탈로그</span></p></div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-cd30341b-cf22-40ac-9f0d-aa57d30519e4\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e54ae061-b31b-44b7-ac91-a337abd9e89d\" style=\"\"><span class=\"se-fs-fs16 se-ff-\" id=\"SE-3595d1a6-beee-4578-b8b0-7cce6db09463\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line3\" id=\"SE-8e47b6d2-b12f-417c-b315-28e1deea9476\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line3 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-607a28ba-91c7-437f-bd12-cb3a8d40df21\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7c57c098-6763-42f1-9c02-c153fdd725f7\" style=\"\"><span class=\"se-fs-fs24 se-ff-nanummaruburi\" id=\"SE-27b2bec1-8593-4277-b4c4-dcfab329e8df\" style=\"color:#555555;\"><b>건설회사 카탈로그와 지명원은 성격이 약간 다릅니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5947eaf8-3a82-4f77-a5ef-ccb17a4399f4\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-bce44410-02a9-4214-afa3-e0f4675a2eb4\" style=\"color:#555555;\">과거 </span><span class=\"se-fs-fs16 se-ff-nanumsquare\" id=\"SE-fee90967-f2fb-4fd1-9aa9-bcff26cf74fe\" style=\"color:#555555;background-color:#badf98;\"><b>턴키 작업</b></span><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-e35adb60-0581-4f37-87c7-74ef1276a805\" style=\"color:#555555;\">이라는 이름으로 건설회사의 인쇄물을 급하게 제작했던 기억이 새록새록 합니다. 입찰이나 공사 수주 시에 반드시 제출했던 지명원이 바로 그것인데요. 비딩(bidding) 응찰 시에 자신의 회사정보를 잘 담아서 출력 후 건설 사주 회사에 전달했던 작업입니다. 항상 급하게 작업하고 도면이나 기간 정보 등도 항상 변경이 돼서 며칠 밤을 새워가며 수정하고 출력했던 기억이 있습니다. 지금은 거의 그런 업무는 없어졌지만 건설회사의 지명원이나 카탈로그는 항상 인쇄분야에서 가장 까다롭고 고퀄리티의 인쇄물이었습니다. 그렇다면 건설 카탈로그와 지명원은 어떤 차이점이 있을까요? 보통 일반인 입장에서는 둘의 차이가 별반 차이 없게 느껴지시지만 건설회사나 인쇄업체 입장에서는 성격이나 디자인 요소 또는 그 내용이 약간 다릅니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d4a27bcd-4a64-4fe8-b612-c41dd3681b59\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-9a42a4c7-16ba-464d-abf5-e6fc45e73062\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e296783c-74c2-4c35-a4e8-35450d3710fe\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-f4e8a129-8452-45f8-892a-1660232f927a\" style=\"color:#555555;\"><b>건설회사 카탈로그</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-cd68633d-a5e1-42e2-bf79-791e56e2af70\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-70986147-7cc1-499b-8a47-0c2aa3906362\" style=\"color:#555555;\">· 원래 </span><span class=\"se-fs-fs16 se-ff-nanumsquare\" id=\"SE-7b019e59-72b9-4505-876a-868ea8a9ca62\" style=\"color:#555555;background-color:#e3fdc8;\"><b>카탈로그는 제품이나 자신의 서비스를 정열 해서 나열하는 인쇄물 이름</b></span><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-3585c70f-bcd2-46d0-a11d-684b56c60227\" style=\"color:#555555;\">입니다. 보통 제품 카탈로그라는 말을 가장 많이 하는 이유이기도 합니다. 그런 이유로 건설회사 카탈로그보다는 브로슈어나 회사소개서라는 말이 더 어울리겠습니다. 아무튼 여기에는 회사의 정보가 담기는 것은 맞고 주력 사업의 제품이나 서비스가 나열되는 것도 맞습니다. 하지만 지명원보다는 디자인이나 회사의 CI에 맞는 컬러링, 또는 조합이 우선시됩니다. 이유는 이 회사소개서는 오로지 홍보용으로 주로 사용되기 때문입니다. DM이나 미팅 시 제출하는 용이 가장 맞는 용도라고 보시면 됩니다. 그렇기 때문에 보기 편한 디자인과 효과(Effect) 등을 가미하여 멋지게 꾸미는 것이 가능합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bbd10695-3228-4c4b-82c8-520c1050a708\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-99020dfc-96f1-49e0-ae72-8a241814501c\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-36167c48-7e4d-4b05-aa9d-582ae32a9b32\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-e1d4ec93-c63c-4767-a8c8-9f8f9d8e762b\" style=\"color:#555555;\"><b>지명원</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-24cb1741-a4ef-4db7-a3d3-2bbf1c753cb8\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-4f54d379-e577-4622-a6d0-7a8d8ae954ce\" style=\"color:#555555;\">· </span><span class=\"se-fs-fs16 se-ff-nanumsquare\" id=\"SE-ab75d38e-7725-4628-af04-a30e41bd6f44\" style=\"color:#555555;background-color:#e3fdc8;\"><b>지명원은 보통 회사의 실적이나 재무회계 등도 포함하여 응찰이나 경쟁 시 우위를 점하는 용도</b></span><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-676c2a67-6e1f-4d3b-afc2-3b43ff825ae7\" style=\"color:#555555;\">로 사용이 되는 경우가 많습니다. 보통의 경우 견적서와 디자인 결을 맞춰 작업이 되며 거의 표나 실적, 또는 공사, 도면 등을 삽입하여 지금까지의 회사 업적을 방대하게 나열하는 용도가 많습니다. 지명원은 인적자원, 특허, 도면의 기술, 실적 소개, 공사 사진 등이 주로 페이지를 구성하는 요소이며 디자인적인 측면보다는 정확성과 신뢰도를 높게 만드는 심플하고 보기 편한 디자인을 선호하게 됩니다. 따라서 홍보용 카탈로그보다는 디자인 효과를 줄이고 최대한 정직하게 작업을 진행하는 경우가 많습니다. 이는 PPT 파일로도 작업을 하는 경우가 많고 프레젠테이션용과 함께 작업이 이루어질 때도 많습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-3095e82d-c90f-4e33-808a-2392b4a127e9\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-50c53190-8b01-44de-a649-26deb85a372d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4352b1e3-7350-4a0d-8c92-7ba9409fe4bd\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-d2c7e07f-bb3a-462b-b0b2-f872d778bcb0\" style=\"color:#555555;\">물론 지금은 두 구분이 경계선이 모호해지고 있습니다. 보통 지명원을 우리는 출력이라고 불렀으며 회사소개서는 카탈로그 책자라고 말했습니다. 그런 이유로 지명원은 두껍고 실적이나 경력이 많은 회사인 경우 수백 페이지에 달하는 출력을 소량으로 인쇄해서 며칠 만에 제본하여 입찰장까지 배달도 가고 그랬었습니다. 또한 디지털 출력기의 가세로 인해 둘을 특별히 나눠 인쇄할 이유도 적어졌고 추세에 맞게 모두 다 소량의 인쇄로 제작하는 경우도 다반사여서 점점 더 구분은 흐릿해질 것입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-142dc575-b117-4002-a1d8-fcc593408a47\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-8ef46541-a94f-4a4e-a9ce-1e6c8fe54b1e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-8c3d834b-b75d-4eb0-a67d-ae375f809fa9\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223037726792/003.png\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-31cbfba2-ad47-4d25-a333-d2c74fa146e2\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-44d8f285-37a0-4a96-aa88-b2f93bf5511d\" style=\"\">건설 카탈로그 목차</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-db6eba8f-afaa-4782-99be-95a1357d01ce\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-bf45c0d5-fc18-4ced-a7e7-d902ef477f98\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-2d7cae7c-9ce8-4cac-81c2-8807de69ba33\" style=\"color:#555555;\">목차에서도 보듯이 카탈로그 형식은 자신의 서비스 설명이 대부분을 차지합니다. 이는 제품이나 공사기법 등을 잘 설명하고 나열하는데 페이지와 디자인이 집중되어 있습니다. 회사의 개요는 거의 4페이지만 할애하고 실적이나 사진 갤러리 부분도 맨 나중에 약 3~4페이지만 넣었습니다. 메인이 되는 내용은 공법이나 성능, 관리에 대한 내용이 전부입니다. 이것은 용도가 다르다는 뜻입니다. 정보와 실적보다는 내 제품의 상세 내용과 서비스 등의 실제적인 내용이 핵심인 카탈로그입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-7cc02378-04e4-48c7-9aea-98bad445bf30\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-4ca484f6-98e3-474b-a926-2df947fe4785\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223037726792/004.png\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-731d2934-a96c-42b6-8c94-e0f3885d7523\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-a27aac5c-0b4c-4cbc-b772-396870e769fa\" style=\"\">공사 지명원</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-6180464c-5af3-47cc-8a61-28428acd6add\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-10f76f57-e6f4-4b6b-8d94-7f09dbd7402a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-103a83d5-55ca-41f2-9f72-d980f70a45cf\" style=\"color:#555555;\">공사 지명원 표지 시안입니다. 이 지명원은 견적서와 한 세트입니다. 비딩이나 입찰 시 또는 거래처에 견적서 + 지명원 사본을 함께 제출하여 수주를 받을 수 있도록 디자인한 결과물입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-c1a8c655-539a-4390-b082-d89146043dd7\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223037726792/005.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-6268c938-ec81-4222-ac9a-34730e53b6dd\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9b839f97-7d6a-4a31-8060-8f47fd668a59\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-4c302f64-2d7a-4c42-8c2a-ae76cfebbf20\" style=\"color:#555555;\">표지 다음 페이지에는 보통 다음과 같은 양식지를 삽입합니다. 이는 제출용이라는 것을 말합니다. 카탈로그에서는 좀처럼 보기 힘든 페이지입니다. 이처럼 지명원은 자료 제출이라는 성격이 강한 제작물입니다. 다만 여기에 디자인을 입혀 조금 더 보기 편하고 읽기 편하게 레이아웃을 잡는 것에 집중합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-6638437b-0a0f-4c6c-b440-ac346a503cbe\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223037726792/006.png\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ecae8dae-c652-4b47-9d7a-5fc4b3afda14\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-1bda4eff-5c3d-49ee-8ed5-1f55c2cfb1f3\" style=\"\">지명원의 목차</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-7e030e95-6874-4067-ace0-109b92c06331\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ce7ac2eb-bf40-478d-8c8b-f47172f0d392\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-f428da66-b7ba-44d6-b084-518d495ac8ae\" style=\"color:#555555;\">카탈로그와는 달리 지명원은 사업분야 보다 기술자, 주요 실적, 장비 보유, 재무 회계보고가 주요 페이지입니다. 거의 대부분 실적에는 공사가 진행된 매출과 기간 또는 업체를 실명으로 제출하여 입찰에 유리하도록 작업하는 경우가 많습니다. 이 숫자와 도면 또는 기술은 정확성이 중요하며 신뢰를 무너뜨릴 수 있는 오타나 오기를 항상 신경 써야 합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-03c0d4d6-dfd0-44c3-a87c-5a42c4ccec01\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-5b63a294-4651-4ec5-a2dc-ced51ed16738\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223037726792/007.png\"/>\n</a>\n</div>\n<div class=\"se-module se-module-text se-caption\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-555cd46e-325d-4b94-90a0-b2070d207f5f\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-28195827-41ec-47c5-a6cb-9bed9485da43\" style=\"\">공사 실적 등이 주입니다.</span></p></div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-40b1cee8-08c4-472e-80d9-b319e4c60e62\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-0af89a22-5d80-4847-8f89-cf02d12f3f9e\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-dd4520a1-fe20-4206-8215-7946e2a1804a\" style=\"color:#555555;\">위 그림처럼 지명원은 실적이나 실적 사진을 표나 그림으로 설명하는 회사가 많습니다. 그런 이유로 디자인도 가독성이 높은 서체와 무난한 색상을 선호하게 됩니다. 이런 작은 표의 정렬이나 가독성이 높은 디자인이 주요 이슈이며 페이지를 얼마나 늘려 작업할 것인가 또는 공사 사진 등을 얼마나 디테일하게 실을 것인가가 중요합니다. 요즘은 실제 공사현장을 가감 없이 그대로 작업하는 경우도 많지만 실제 드론이나 기타 최첨단 장비를 이용하여 공사 구조물 등을 촬영하고 실적 사진에 삽입하는 경우도 많습니다. 또한 영상을 만들어서 공사의 진행과정을 실시간으로 담아 편집하여 더 현장감 있고 리얼하게 제작하는 경우도 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fcba2dab-c10f-4de0-805b-544035008618\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-933d703a-271d-42c2-a8f5-05165a00dc52\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-836f9065-f575-41e1-a535-9f4dbf696578\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumsquare se-weight-unset\" id=\"SE-4cbbd514-b058-423b-88b7-65fef000b72f\" style=\"color:#555555;\">3개월간의 공사를 무인 드론으로 매일 3시간씩 촬영하고 편집하여 제작된 공사 진행 영상은 홈페이지 등이나 기타 제출용으로 다시 각색하여 멋진 신뢰도를 쌓을 수 있는 무기가 될 수 있습니다. 궁금하신 사항은 언제든지 문의하십시오.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-7fc09db8-a2cf-4d47-abbe-abf1871a3b1a\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align- se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;ref=https%3A%2F%2Fm.blog.naver.com%2Fcookthedesign%2F223037726792#nafullscreen\" onclick=\"sendClickNlog('pst.talktalk', '');\">\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n</a>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-1ec29ac0-7fbd-445a-b823-692e6c1e415a\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-231fa4e6-1357-44c3-b9af-a623f4f2338a\" style=\"line-height:1.