e_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223825339733/004.jpg\"/>\n</a>\n</div>\n</div>\n<div class=\"se-imageGroup-item\">\n<div class=\"se-module se-module-image\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223825339733/005.jpg\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-imageGroup-navigation\">\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-prev\" type=\"button\"><span class=\"se-blind\">Previous image</span></button>\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-next\" type=\"button\"><span class=\"se-blind\">Next image</span></button>\n</div>\n<div class=\"se-imageGroup-progress\"><div class=\"se-imageGroup-thumb\"></div></div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-7b73ed98-2a91-474a-949d-15379fb21a75\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-42aa81af-1dd4-4c90-8c25-c3a2c835cd9a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-66328792-87e9-4631-9452-8fd465d7be1a\" style=\"color:#555555;\">홈쇼핑이나 유튜브 또는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-f1bce011-657e-48a9-b483-509a87d893d0\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-9aaef15c-46a6-4fad-87dc-8c160e20023a\" style=\"color:#555555;\">팟 캐스트를 통해 제품을 실시간으로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-5943b292-688e-4ed3-a568-7bc7b08e77f3\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-a440204c-8d09-415a-b733-8f6977951b38\" style=\"color:#555555;\">판매하거나 스트리밍 하는 경우가</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-0246d074-03fd-45f0-95cd-04195cacd08a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-a7343cab-7428-48bd-96d4-279090b6e941\" style=\"color:#555555;\">많이 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2d43a506-9f2f-409e-9195-f1a401183d72\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-3e7c273f-ee29-4c03-98af-a03509d12bcf\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-f8c2603e-5718-4e70-aa5d-2cd3c93a7289\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-529123a9-6ff1-4d38-a14e-09bc41150c11\" style=\"color:#555555;\">이런 경우는 신제품이나 또는</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-1f532bbe-2818-43a9-a513-20184931de25\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-f8b311ce-7cf1-419f-a3a5-4d3c4dd04147\" style=\"color:#555555;\">기존 제품이라도 변형하여</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2db6aa83-4f98-4c78-88d7-edfaf5471713\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-47a758e0-773b-4551-a8d3-9060c9b38cda\" style=\"color:#555555;\">제작하는 경우가 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-f796eb9c-2533-4b6e-b275-6903464ea613\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-ffb16121-08fe-4e41-a1db-bc44fc3d5321\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-a389c3ab-ea15-4d5e-9392-8e866b214ae5\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-bfdf8c6d-a36a-4444-bb36-91be94ff8985\" style=\"color:#555555;background-color:#fff8b2;\">이럴 때 제품의 박스가 없어</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-3cc763a8-0568-407b-bb22-ddc657939b49\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-42c85089-0dd0-4de9-8773-d4f8da6ab687\" style=\"color:#555555;background-color:#fff8b2;\">난감하시다면 지금 바로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-310d1a67-a892-425f-84d8-5ef3f7ee11a6\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-c7816f83-d143-46ca-a1d4-30140f8e436b\" style=\"color:#555555;background-color:#fff8b2;\">(주)파파스컴퍼니에 문의하세요.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-77265e4e-3613-4bd7-b04d-0758bea52dfe\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-49843f19-a229-4cd5-b7d4-17f0b8a2ece4\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-ab4f0ab6-b464-4995-b867-171102c098ad\" style=\"\">쇼핑몰 촬영용 소품</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-adf09764-d931-46b9-8453-81801f011259\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-297dbfb0-eed3-4524-ba7e-7bc31c5d100f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-362ca2a9-ff42-419e-af15-745e674b42f7\" style=\"color:#555555;\">홈쇼핑이나 유튜브에서 사용되는 패키지 소품의 특징은 다음과 같습니다.</span></p><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2e43c216-d6de-45f5-88a5-a9e5f9f5a4df\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-3170c488-9459-4310-96a2-ba57bd2a07da\" style=\"color:#555555;\">​</span></p><ol class=\"se-text-list se-text-list-type-decimal\"><li class=\"se-text-list-item\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-38db39ee-d896-42d3-9837-5634fc8764d1\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-62588b16-bd98-48bc-b8a7-d1a5c8ff3957\" style=\"color:#555555;\"><b>납기가 급합니다.</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-d7ab9e02-9289-4853-80aa-d08605e5e265\" style=\"color:#555555;\"> - 촬영 스케줄이 잡혀있으니 당연히 급합니다. 보통은 2 ~ 3일 안에 수령하기를 원하십니다. 이번 인쇄물은 단 3일 만에 납품하였습니다. 하지만 디지털 인쇄에서 제작되는 급한 패키지의 경우는 제약조건이 여러 가지가 있습니다. 사이즈, 종이, 인쇄 도수 수량 등등입니다. 이 부분은 자세히 설명드리겠습니다.</span></p></li><li class=\"se-text-list-item\"><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fac598ae-0559-4b02-8e89-db5dd3914a49\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-18ba5ef2-5404-420f-9b98-ac082e6fc8fa\" style=\"color:#555555;\"><b>수량이 적습니다.</b></span><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-fe023364-7949-4850-b588-e86ec5e58544\" style=\"color:#555555;\"> - 소품은 최소 2개에서 10개 미만으로 대부분 작업이 됩니다. 물론 100개 이상으로 제작되는 경우도 있습니다. 일반적인 패키지의 경우 최소 수량이 500개입니다. 통상적으로 소품용은 10개 미만으로 제작됩니다.</span></p></li></ol><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-522f5b8d-2c2e-4d36-a69a-46b4dcf0bbea\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-f05961c2-8a0f-4230-9727-3579ac64abeb\" style=\"color:#555555;\">​</span></p><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-772460ba-0b48-4aee-ba4c-0b69ccd8d97a\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-239c7c25-21f9-44be-9ef8-24a842d09d70\" style=\"color:#555555;\">위의 두 가지가 가장 큰 특징입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-6bdc8c89-1200-4376-850e-01743eca87ae\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7e32b1cf-e99a-4043-ac5a-336e5f89bfdc\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-f96f65a8-adde-4a35-b3fe-4fc653b27f80\" style=\"\">소품 패키지의 제약 사양</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-3fe7a6cb-5675-49cb-9fbb-9b563d814c51\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e27168b4-86ff-44d3-a80d-751f0ca42f46\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-583fe77e-21b8-434a-9c0a-133b160dc226\" style=\"color:#555555;\"><b>사이즈 제약</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b5fdc995-ce65-4dfc-9df8-4aaf717f174e\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-58bcd455-0085-4c79-bf5d-55cb9eb2131e\" style=\"color:#555555;\">전개도가 A3 이내면 100% 가장 빠르게 진행될 수 있습니다. 만약에 이보다 크면 1 ~ 2일 더 소요될 수 있고 수량도 5개 미만이어야 가능할 수 있습니다. 이 부분은 반드시 문의하시기 바랍니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-a9f1990d-b13b-4305-a76f-bb9ab9b04d32\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223825339733/006.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-04d99dd8-bf17-4caa-85fd-58950b53ec9d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-257488f0-8146-4032-b4d1-f76c7b167546\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-a4e88322-337e-42e7-8d00-ce99c12e0877\" style=\"color:#555555;\">A4 210mm × 297mm 안에 들어가는 사이즈라면 무난하게  하루 만에 인쇄는 가능합니다. 혹시 급하신 분은 인쇄만 제작도 가능하니 문의하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-569baaa6-bcb7-4429-a4b6-e56b4723cda1\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-58aca55c-e34b-4e06-ab91-72a27be03115\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-be51b9eb-925a-4f6c-bbc2-027f8e278875\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-80c38d3e-c36f-4d56-9790-23816088c034\" style=\"color:#555555;\">이후 프로세스는 코팅을 진행할 수 있습니다. 지난 글에도 언급했듯이 패키지는 오시(누름선)로 이어진 꺾임이 많아서 터짐이 생길 소지가 많습니다. 반드시 코팅으로 표면을 보호하는 것이 좋습니다. 만약 코팅을 처리하시면 1일 정도 시간은 더 소요될 수 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-a9dc3a6f-8b54-4040-a0b9-9137f7a74419\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-6a8067dc-b028-4dee-b734-7717fc427f87\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b116e508-5ac0-4ff2-bfb6-24a2e6cd13ed\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-2c6b0078-a64c-4556-ac64-6b19939ce16a\" style=\"color:#555555;\"><b>종이 제약</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2ab48997-b1ea-4e69-8551-1038fcfa73c4\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-b0ec9c70-e6e7-469c-8975-ccf435ca8d1a\" style=\"color:#555555;\">디지털 종이는 디지털 전용지로 불리는 용지가 따로 있을 만큼 제약사항이 있습니다. 그리고 패키지용 종이라서 기본적으로는 300g 이상의 두께를 추천드립니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ad74a0c5-5da9-4a74-9a46-d88a88e15b6f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-84d18a27-2845-407b-b75d-6fee0756f8ad\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a4a7764a-a36a-4a8f-9550-8d8722396b6d\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-7cc2442d-6a56-44b7-8a64-a8b72cbd0652\" style=\"color:#007aa6;\">슈퍼파인 324g 백색</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-9774ce75-5fcf-4228-850b-c91c0d91ba1d\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-6a9e32ae-fd9e-4f94-81e6-cc544eb4c791\" style=\"color:#007aa6;\">인바이런먼트 352g 화이트</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-65244b3e-4f98-4020-b3c3-7efecf0ba292\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-e9f44941-b8e1-4aa5-9c12-6aa1735e2442\" style=\"color:#007aa6;\">올드밀 300g 화이트</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b6c1fc54-2923-404b-b673-29b350cb1480\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-840da4a9-2c18-445a-a4d4-f569e609625d\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5d3e2e2b-5638-4d8f-8065-689dfe33fb05\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-49f6d564-bc2b-4353-80f4-843b8b63289b\" style=\"color:#555555;\">만약에 오프셋 인쇄라면 아이보리나 CCP 또는 마닐라지가 일반적일 것입니다. 하지만 여러 가지 특성상 이런 종이로 디지털 인쇄가 가능하지만 자사에서는 취급하지 않고 있음을 양해 바랍니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e0b3dc1e-c906-46d5-9633-a97960b98d38\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-1a9820a7-b714-417f-a7f5-3401f84ea94d\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-71debd67-6f3b-4520-8a1e-34dd4d641495\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-05dd772f-1146-4e51-bb9d-d5e7f8efbd39\" style=\"color:#555555;\">반드시 로얄 또는 일반 아아보리(IV) 종이로 디지털 출력을 원할 경우에는 반드시 별도 문의를 주셔야 합니다. 대부분 오프셋으로만 인쇄하는 것으로 저희 회사는 홍보하고 있습니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-8ade0755-15ae-4402-a19a-69635577c624\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-1cd22751-f18e-4709-a791-bd2a16f21731\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-dc9146f4-9992-4705-8115-5f9c2f4aadfe\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-374afd3e-7fb6-4a80-8b02-a2ec19af1218\" style=\"color:#555555;\"><b>인쇄 제약</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-be884ef5-7308-4dd5-a5e7-31ff96380042\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-2536aea8-aec5-464d-9275-0490463e2cc1\" style=\"color:#555555;\">디지털 인쇄는 특별한 경우를 제외하고는 별색 출력을 하지 않습니다. 물론 요즘은 디지털 인쇄기의 발전으로 인해 금별색이나 은별색 또는 형광색 일부가 출력되는 것으로 알고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-225a93fc-cb79-4119-895a-10748da57134\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-b6e9827a-452a-4f2d-90f4-aec46e0b1bef\" style=\"color:#555555;\">하지만 두꺼운 패키지 종이에 별색 인쇄는 아직은 쉽지 않습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ba3bf96b-5a31-4b35-b100-085d7daa074c\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-bbb7b690-4e19-41ae-9f11-3dda710381ff\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-48fe556c-a10c-4098-bf2a-d770221b7719\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-2e44bad6-322c-4f18-937f-d04d3b7c280d\" style=\"color:#555555;\">기본은 컬러 CMYK 4도 인쇄입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-056e24a6-ec5d-43c3-9d6a-0c3c521cfed9\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-1a12cd27-230f-4984-98ea-e3eaf12b324e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2bef40eb-8444-475c-b2a6-f1e63122b5bd\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-b427b7d8-0037-42bd-8033-0fd57a135be6\" style=\"color:#555555;\">이후 코팅처리는 모두 가능합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-21319d6f-46a4-4a15-bc57-7f5238961c10\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-831ae39b-4d97-440b-a518-7cb9442cd6ac\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-30f3e079-f1c8-4c92-aee6-84a68bdd5661\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-fe6b12d7-bc4f-49c0-bb69-4a8f63b56afc\" style=\"color:#555555;\"><b>후공정 제약</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-20ae184b-476f-4d24-82d5-3797c49143a1\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-1a726535-2515-4a0c-b226-8a84b9cfd36c\" style=\"color:#555555;\">소량 인쇄에서 가장 심한 것은 후공정 파트입니다. 특히 디지털 커팅이 가능한 사이즈 제약이 있습니다. 또한 아직은 디지털 커팅이 100% 목형 + 도무송보다 깔끔하게 처리되지 않습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-84a93b5c-b20e-4ae1-8789-56699a704f3b\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-daf40f45-39c6-4050-a493-6704507c5493\" style=\"color:#555555;\">무조건 샘플용이고 촬영용이라는 점을 말씀드립니다. 하지만 받아 보신 대부분의 고객님은 아무리 소량이라도 제품의 퀄리티를 낮게 평가한 분은 없었습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-c8e2a478-6512-409d-997f-348a82b52d1d\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-f5a6dadf-83de-48a6-b570-7116337c388b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5c78e228-e9f5-467f-bdc2-8a4994d0ad16\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-4cb783da-9752-47f5-a394-6e3a142950c9\" style=\"color:#555555;\">커팅은 국 4절 약 A3 이내 사이즈면 좋고 그 이상이면 다른 방법을 제안 드립니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ce1e9d4b-c20e-4dd2-b413-e4199c66cf09\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-02b1c29c-8bb9-4837-9f09-e0fb41537577\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-59ca5d69-e9fc-462d-8790-7891f2febf6f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-90b1ca8d-3d68-46fb-8c38-6e86122c140a\" style=\"color:#555555;\">또한 접착의 경우 맞뚜껑이나 엇뚜껑, 십자조립 등은 한 면만 접착하기 때문에 접착비가 상대적으로 저렴합니다. 하지만 삼면접착은 3번을 접착해야 하고 이 또한 소량의 경우 100% 수작업이므로 단가가 상승하는 요인이 됩니다. 참고하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-f9a6f2ce-1b4a-450a-a418-b322c1410a39\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-2216610f-d2c4-4a07-8be9-99fd1610ee89\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2d3d5dba-594f-4e6d-acb8-bd70a2b0eb86\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-b244a8a0-3e72-478b-9072-c5799913f4a9\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-e1c4dbe0-3c29-44b3-aad5-69522047f186\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223825339733/007.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-image se-l-default\" id=\"SE-a8554f56-1ec5-4da0-9b07-8c36e92877a1\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223825339733/008.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-006b1f3f-d6d4-4085-863d-a91b8ed40221\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-9ee49208-072f-476e-a6e8-262eb4060eb9\" style=\"\"><span class=\"se-fs-fs13 se-ff-\" id=\"SE-2477e875-c0d0-4362-88fe-69a14f002cc7\" style=\"color:#ff0010;\">본 블로그를 위해 사진이나 디자인을 허락해 주신 대표님께 감사의 말씀드립니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-81a61fa2-9ee8-4956-86f3-0e78f57f2485\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align-center se-l-default\">\n\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n\n</div>\n</div>\n</div>"
