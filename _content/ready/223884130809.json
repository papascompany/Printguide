on se-imageGroup-navigation-button-prev\" type=\"button\"><span class=\"se-blind\">Previous image</span></button>\n<button class=\"se-imageGroup-navigation-button se-imageGroup-navigation-button-next\" type=\"button\"><span class=\"se-blind\">Next image</span></button>\n</div>\n<div class=\"se-imageGroup-progress\"><div class=\"se-imageGroup-thumb\"></div></div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-175391b4-0af8-4444-a868-c6741e6271fd\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-72c3a001-d467-4e77-acb4-314bfca4053d\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-c9797763-b963-49af-92e9-69b7e8e4dd30\" style=\"color:#555555;\"><b>행택도 소량으로 자주 주문하세요.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-80f65093-7ea1-46d6-a3ac-f5309b33a637\" style=\"\"><span class=\"se-fs-fs19 se-ff-nanummaruburi\" id=\"SE-fe529369-140e-4e1b-a1c7-7d01e2e46d8f\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-7f3954e9-77d1-49b2-91be-bba5fe4edc3e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-99e893dc-6bb2-424c-9cb2-b3a4a4afcfd6\" style=\"color:#555555;\">위 형태는 행택으로</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center\" id=\"SE-2028df39-d214-414e-8211-83c2d0dc9a87\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-527f3753-876b-404a-b772-74a65b56ab90\" style=\"color:#555555;\">가장 일반적인 모양입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-a0766d91-66d0-4eef-bd07-a2f07f4c81b2\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-center\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223884130809/004.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-dbbcfc5d-b7bf-4af9-9d32-35a6c2689fb0\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-6fd94469-14f5-4ad2-8984-c8a643d3b4f2\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-250fa8ce-fa86-4806-a88f-520b6c2656ac\" style=\"\">디지털 커팅의 장단점</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-ad5853de-3029-4156-955d-142a5640d924\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-f5d49866-a7ac-4c1c-852c-efae0c7b51f3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-46020ac5-adce-46dc-a9d1-3cbe72340457\" style=\"color:#555555;\">요즘과 같은 소량 다품종 생산 시대에는 디지털 커팅으로 제작되는 경우가 많습니다. 디지털 인쇄가 활성화되기 전에는 통상적으로 5,000장 이상의 대량생산과 목형 + 도무송(톰슨)작업으로 진행되어 기본 총 인쇄비가 비싼 경우가 많았었습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-03705dc1-6dee-464d-a8ec-e5ed308f312d\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ba5426bd-fe78-4677-8163-46ece6ea0d20\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-cfb48ad8-8e82-4658-bfcb-4aa8710f253f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7472be28-f2bb-41cd-93f6-d69d8a3e39a6\" style=\"color:#555555;\">하지만 요즘은 100장에서 1,000장까지 소량 주문을 자주 발주하는 추세로 바뀌기도 합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-cf5c0ea1-b150-4aa2-991e-2bed9e0cb314\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-37e4314e-e072-4e43-b488-c24abf581079\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-eed47050-26b0-476d-ab71-f8274f4687ad\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-bcfd1088-264c-4b7f-836e-4e5c2f20e53b\" style=\"color:#555555;\"><b>디지털 생산의 장점</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-2fae460c-2b02-4c7f-9a9c-a2dd7fe7c683\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d61916d5-d40d-49a2-a834-17dbf8da2283\" style=\"color:#007aa6;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-d3b06e03-da4a-415a-bce8-154d7a667c20\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-fe7b8d23-354b-4aca-a0ce-1a6ce813cb4d\" style=\"color:#007aa6;\">소량 주문이 가능합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-4268f6b5-791c-4993-b222-34c27c39e392\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-cb668ba0-07b3-4dee-bed1-880a615cf8e2\" style=\"color:#007aa6;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-e4c7dc14-41bb-4cdc-a8d0-f845069f612a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-073414a8-cf6f-4d91-be57-7f04abb8fc6c\" style=\"color:#555555;\">디지털은 한 장부터 수천 장까지 소량으로 생산이 가능합니다. 하지만 수량이 많아질수록 오프셋인쇄가 단가적으로 역전되는 수량이 발생됩니다. 일정 수량 이상이 되면 단가가 역전되어 디지털 인쇄가 비싸진다는 이야기입니다. 이 말은 항상 소량 생산 위주의 다품종 품목이 있는 경우가 해당됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-7a885086-9000-4706-ac54-0ceafc3aba19\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-83d3771c-4fad-430d-889e-3e897a8d0ecf\" style=\"color:#54b800;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-f055e3b0-e282-42dc-bd31-aa0a1857f57c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-c6854e69-bd1b-4766-b303-89867010c25a\" style=\"color:#54b800;\"><b>다음과 같은 경우가 해당되는 고객님은 문의하세요.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-77919891-037a-4b05-b3bf-969057bf155e\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-06cc0a46-3723-46da-989b-d1abf7c7bb3e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-c3b5f485-17f6-4132-9341-ce0289ae4fab\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0b7bd164-c95c-46f9-8d99-f1144c91f915\" style=\"color:#555555;\">· 생산 품목이 다품종 소량 위주로 판매하시는 회사 또는 고객님</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-ccfcfc41-acdc-443c-a9b6-87593a2baaa7\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d7396c9d-44da-46e2-bd92-7355dfc16cd5\" style=\"color:#555555;\">· 발주 수량이 500장 미만 발주가 대부분이신 고객</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-fb3677e6-276c-41bc-88d7-5b9be4ab59fe\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-95c31719-7339-492c-92fb-3fdcd87d0ff2\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-0a40bb2e-7db4-4867-9ee1-c31c0ce810dc\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0fd09494-4fac-407e-a9b0-ec6f246689f4\" style=\"color:#007aa6;\">디자인 형태를 변경할 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-ff5a3471-004b-4409-9ad1-7211d694466c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8243bc0a-e9a7-43ba-b315-454c57e5fce0\" style=\"color:#007aa6;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-eb24b184-1629-404d-9a2e-36cd59080ec7\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-70bc21e7-5827-452f-9475-6b2e9f1a8e8a\" style=\"color:#555555;\">오프셋의 경우 형태가 변경되면 목형이 변경되어 추가 비용이 발생됩니다. 하지만 디지털 커팅의 경우 재발주시에도 디자인 형태를 변경해도 추가 비용이 발생되지 않습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-160370be-6dc8-4a4d-8834-6d643d2e744f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-cc35dd78-f541-4853-ae0a-e4f6b455e2ea\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-fae9499f-9d04-491b-bdea-bc1ff7f6089b\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-53230dc2-efb5-4a1f-8dd5-5f7fa6270d61\" style=\"color:#555555;background-color:#9bdfff;\">그러므로 디자인 형태가 자주 바뀌는 고객님은 디지털 소량 주문을 선호하십니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-16ad991f-ce85-4718-9853-a4d12cc6e209\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-971e0db6-afd1-44b3-accf-d6049f20475d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-e1636f8c-6a5e-4cb2-b0ff-125f8d03a6cf\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-600cae4f-3f5d-4efc-8ce7-aa9885eccf7e\" style=\"color:#007aa6;\">디지털 인쇄가 색상 표현이 안정적입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-a0d6e7ea-d6ba-442c-bba4-f3bc4ab8a6b9\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-836ccb91-58f3-4dee-865c-666aac23e67d\" style=\"color:#007aa6;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-e2862715-51c5-410c-b9ad-c6b82dbd4320\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6213743d-3948-4e67-b5e1-28f311163707\" style=\"color:#555555;\">디지털 인쇄의 경우는 인쇄 기장이 색상으로 조정하여 출력하지 않습니다. 오프셋의 경우 색표현을 기장이 조정하여 농도나 색감을 변화하기도 하지만 디지털은 색상이 이미 등록된 인쇄 프로파일 값으로 진행됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-62b262e4-7dbc-4c50-8c9a-857a99b34b86\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7703dc26-7f00-4c50-9b54-3eead48fb40c\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-48736eeb-a45a-4e5b-9d11-6b778c43d95c\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-217b48e9-c24d-4fd0-b8fd-99b0eb9a4547\" style=\"color:#555555;\">이런 이유로 재발주시 디지털 인쇄가 더 안정적인 색상으로 지난번에 발주한 색깔로 나오게 됩니다. 물론 약간의 편차는 있지만 분명한 것은 오프셋보다 더 통일화된 색상이 표현됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-caf0c64a-f44b-4b14-960e-bc0ece950a32\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-561815bd-fdab-4bca-ad5e-fe772f1c6b71\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-b06c3121-e56b-473c-aef7-012ca34167e1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c329ead8-3b92-43da-848c-2f8dff0586df\" style=\"color:#555555;\">이런 이유로 단가가 조금 비싸도 색상의 안정성 때문에 디지털 인쇄를 더 선호하기도 합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-7f65ad56-54b7-4ddf-9865-4bbc1682e1b3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-0d0f0359-1009-4934-b49e-397f34d98f6b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-ee3c654f-d74c-45e1-b7e5-45160f7148e1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-fe270264-9f1a-4b4d-968a-be09fd9bf451\" style=\"color:#555555;background-color:#9bdfff;\">재발주시 인쇄 색상이 통일성 있는 꾸준한 컬러를 원하시는 고객님은 디지털 인쇄로 주문하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-2ccd23b3-b126-41aa-820f-4bdfd1b50363\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-1fd1972f-06a5-4336-b581-7c346949101b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-39c4cecf-b035-4af3-938e-32c078aaa509\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-fccea2c1-f4fc-4ddb-9645-dd58eb65d584\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-43c9cd48-26d8-4c2c-b6f2-86e23d979531\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-15dbe5b4-89ba-4f2b-92b7-3ec8832f8441\" style=\"color:#555555;\"><b>디지털 생산의 단점</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-ac80139f-65ff-41ad-83e1-c6570fcd0ff4\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-19245b4c-6b46-4c0c-94ad-5d0e6d96676a\" style=\"color:#007aa6;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-0e7c24d0-b30b-405c-bfa9-68e4b4d2611f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-dd41e2b0-9c4b-4fc7-a654-e68d519ce4be\" style=\"color:#ff0010;\">대량 주문은 단가가 높아집니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-37ecc459-4239-47dd-8211-5b0b413bad96\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-cf0b261e-4eca-4157-8c42-547bfea90aba\" style=\"color:#ff0010;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-119ebd51-f370-4593-829f-cbb0949eb827\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-80e0ca98-259c-4560-b5dc-ecccf8c41d77\" style=\"color:#555555;\">디지털은 1장에서 수백장까지가 적당합니다. 만약 수천, 수만 장까지 주문이 이루어지면 디지털 인쇄는 단가에서 불리해지게 되어 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-affb0185-ccd7-43c7-8fa3-481644e91ff1\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-60b9a60a-dc4d-4b6a-9abb-ec4c5927925a\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-29f0d2be-5a8e-45e9-9e49-f8bc4396fb75\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-96a1f00f-c4ea-420a-8bfd-0a684fd86b6e\" style=\"color:#555555;\">오프셋은 특성상 많은 인쇄물 제작 시 단가가 싸지는 반면에 디지털은 단가가 절약되지 않습니다. 그러므로 대량 주문 시 디지털 인쇄는 적합하지 않습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-953f682e-bbbe-494b-81da-b6a6cfc05860\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-fe611e33-c2cf-4f0f-8926-54586f6b3d18\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-793b24b1-ac92-443d-bda3-ca5f874ba3d9\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e5f13e40-f71a-40b8-8ac4-3fcd62f168e6\" style=\"color:#555555;\">그러면 몇 장까지가 적당할까?</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-1dd27e74-4e62-4e82-bacc-80922aec4836\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7695f26e-25a8-4591-993d-e3f75bf69ec8\" style=\"color:#555555;\">사이즈에 따라 적정 수량은 정해지겠지만 통상의 경우 A4 사이즈 기준 200장 ~ 500장 내외가 통상 적정 수량이라고 합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-4adda355-83ea-4520-a043-d8c8d59d8759\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-963c3774-0835-425c-b369-f0fe751abf17\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-0bbafa6d-832d-4420-b82e-e11adbf51b24\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-356a23e5-c4e7-4a6f-9ded-d39a5c03a4fa\" style=\"color:#555555;\">카탈로그의 경우에도 200부 이상이 되면 오프셋 인쇄가 싸지는 구간이 나오게 되어 있습니다. 행택의 경우는 500개 정도를 보고 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-372220b1-93b3-4aee-9119-52c65b3645d0\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-74cdcff2-26ce-466a-9cb1-dada90fe5184\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-2420c063-04cb-4b89-8aeb-79947c3a32a3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-3ac5d7fc-9a13-4dfa-8529-f3b2a4f6a6bf\" style=\"color:#555555;background-color:#fdd5f5;\">500개 이내면 무조건(?) 디지털 인쇄가 저렴합니다. 위 이미지 정도의 사이즈라면 500개 이내가 적정 수량이라고 말씀드립니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-5aa9d1e1-375d-4b1c-aebc-91da11698d51\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-3158f36d-2f48-419d-b931-e0e75a602f2b\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-7172e54a-4ada-4c85-8b05-369cec2546dd\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b75a8855-531b-4a79-ac09-c592308c4a5f\" style=\"color:#ff0010;\">커팅 퀄리티가 도무송보다 정교하지 않습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-0bea8bd3-b795-4505-8cea-55ec84da0b3f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8586af87-cc66-49ec-a010-98e5a22a9b3a\" style=\"color:#ff0010;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-16df1812-988a-483d-926d-687753dfa589\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-c1deb98a-3558-4371-8972-43295fd6f658\" style=\"color:#555555;\">디지털 커팅은 아직은 문제가 있습니다. 커팅 시 뜯김이 목형보다는 정교하지 않으며 특히 두꺼운 종이는 오시나 미싱이 약할 수 있습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-1800416f-2c5b-4e74-91eb-9f92a08d5de8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ce126a86-c0ee-4a08-aad1-7e1b2ba990ca\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-9f9357a6-08f9-46b9-9acc-cfadfdfc65f6\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-7f6e05d8-4497-4972-bd9e-ee543b93adea\" style=\"color:#555555;\">또한 직각의 선은 특히 더 뜯김이 심합니다. 이런 이유로 끝부분은 약감 굴림, 라운드를 주고 작업을 합니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-2dcee2d1-fb98-48f5-8607-cae69638dac5\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-justify\" style=\"max-width:757px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223884130809/005.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-02460357-b959-4968-937c-ccad730dd4cc\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-c5fcaed6-f1b5-4f12-a6bb-a93c97a1485f\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-d69dd96c-3c37-4a37-a832-26d5fc455325\" style=\"color:#555555;background-color:#bdfbfa;\">약간의 라운드 처리가 훨씬 깔끔하게 디지털 커팅이 됩니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-b7e1c232-a6dc-44cb-9921-6c9faedd3479\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-ff22ac62-5976-4b1a-b533-43667943a411\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-default\" id=\"SE-dde46fb1-0653-4018-94a7-b74983dbdd2f\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-default se-section-align-justify\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-41d0e90c-5665-48b2-b45a-9f4f11e07601\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-d9771bab-abf2-4c66-8ca2-7fba8a60b094\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-cc633563-2f1d-46c5-8339-b3230674922b\" style=\"color:#ff0010;\">가장 큰 문제는 큰 사이즈 커팅이 어렵다는 겁니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-e2ad81e4-eb0d-46d1-973d-3885c6d42511\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-b0d18a8c-87b4-41f2-9479-d32bf47f99cd\" style=\"color:#ff0010;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-e05e45f9-b6d7-480d-b9d0-1e0ac2171e44\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-e4d0346f-903d-47be-a6da-e6ef21af989a\" style=\"color:#555555;\">디지털 커팅이 안정적이라면 A3 이내 사이즈입니다. 물론 요즘은 큰 사이즈 커팅기가 고가 장비가 있습니다. 하지만 타산의 문제가 발생합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-de972e6a-4ec9-451a-9069-ca10468cd718\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-2039cbe7-9680-4e93-9a01-f6904a2e19eb\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-9d1e9caa-e1f5-423d-afd6-d3795ddeeda3\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-28a6645b-0951-4a36-b1a4-42aa9b559ee7\" style=\"color:#555555;\">5억 장비를 저가로 생산할 수는 없는 노릇입니다. 가장 적당한 장비로 합리적인 가격을 제안 드리는 것이 중요합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-a374b531-3581-4f52-a0cc-bfc803ba58b8\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-a07eb4f3-3548-4998-aabd-034d6eb93163\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-b766267f-13d6-4ab5-a340-337c74f2888a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-04fd903e-bb7e-4559-8ee5-40780cca16be\" style=\"color:#555555;\">아직은 A3 이내 사이즈를 디지털 장비를 이용하여 제작하는 것이 가장 합리적입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-ec720e7f-def8-459f-8705-91785e59a2ca\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-18f61a0a-6d34-4d50-8c0d-9a79fe21b41c\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-18bfb16a-65e0-4c1d-9af7-5cdaf0f0a614\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-5c87a64c-76a0-4118-8eb9-5d0247875578\" style=\"color:#555555;\">패키지가 아닌 행택은 A3 이내에 몇 개가 조판되어 제작되는 것이 단가에서 가장 중요합니다. 가장 합리적인 사이즈는 반드시 문의하시기 바랍니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-quotation se-l-quotation_underline\" id=\"SE-84631b90-6b8b-4ebd-940c-082935e4a074\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-quotation se-l-quotation_underline\">\n<blockquote class=\"se-quotation-container\">\n<div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d860d483-ef8f-448f-b2c2-71f603a7a3f8\" style=\"\"><span class=\"se-fs- se-ff-\" id=\"SE-8fb133f7-5905-43a2-9948-5f681e20a577\" style=\"\">행택을 합리적으로 주문하고 싶으신 고객님은 다음 사항을 체크하세요.</span></p><!-- } SE-TEXT --></div>\n</blockquote>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-7bac4e01-623a-4b89-9bc1-4aef90f376ee\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-466940f2-4ea3-4405-813a-0f276a620dcb\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-9ab59965-ebe9-40f7-9e55-c2dbd426f803\" style=\"color:#54b800;\"><b>□ 고객님의 상품은 소량을 자주 생산하시는 제품이신가요?</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-7ae67e11-f32d-4df2-ae72-694a3bdfe097\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-f17f33c7-71f3-4371-a509-4f4a5f84cd17\" style=\"color:#555555;\">그렇다면 디지털 인쇄 방식으로 제작하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-60e5a5ec-f4a5-470a-b78a-3389dc584a35\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-6f1ae845-ab5b-4f1b-bee5-a43bfa427897\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-8b3e990c-7248-428a-bdfa-5e9c0c5c94ce\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-a3c6ad93-0bea-42da-860b-6726e9287276\" style=\"color:#54b800;\"><b>□ 아직은 대량 생산이 본격적으로 이루어지기 전인 시험적인 파일럿(?) 상품이실까요?</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-20528cbd-5444-4c79-b8ae-bb1f52817c2a\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-873ea72c-8147-4ddc-8bab-894c104de1d4\" style=\"color:#555555;\">제품이 시장에서 반응이 오기까지는 시간이 걸립니다. 본격적인 판매가 이루어지기 전에 반응 보기 위해 디자인도 자주 바뀔 수 있고 종이나 형태도 변경할 수 있다면 반드시 디지털 방식을 선택하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-4eba67cd-1529-48d1-8822-89bfcf1f8777\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-8f2abb8f-f4ce-4771-9bbc-fec797579798\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-90c06406-10a8-47be-b47f-117a59dc8c48\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi\" id=\"SE-c12f17b4-c6c6-4ed1-b679-790e91a1c2bf\" style=\"color:#54b800;\"><b>□ 공간이나 보관비용을 무시할 수 없는 인쇄물</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-6e02aaad-b488-4fec-bd42-6d5e5107f791\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-21844a68-5bcc-4484-b141-f8a32f8f0adf\" style=\"color:#555555;\">이 이야기는 많은 대량이 소진되는 시간이 길어 보관하면 인쇄물이 변질된다거나 아니면 파손의 위험이 있는 제품을 말합니다. 차리라 이럴 바에는 소량으로 자주 발주하여 제품의 자연 소진을 막으시기 바랍니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-sticker se-l-default\" id=\"SE-a4474b2b-2928-4036-9dfb-c77c422c3982\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-sticker se-section-align-justify se-l-default\">\n<div class=\"se-module se-module-sticker\">\n<a class=\"__se_sticker_link __se_link\" data-linktype=\"sticker\" href=\"#\" onclick=\"return false;\">\n<img alt=\"\" class=\"se-sticker-image\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/223884130809/006.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-76c48f5d-fb26-42cc-8418-a6b2238099a1\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-justify\" id=\"SE-d1875c47-23c1-49ff-9257-e89c92ed1f5b\" style=\"line-height:2.0;\"><span class=\"se-fs-fs16 se-ff-nanummaruburi se-weight-unset\" id=\"SE-81055214-9833-4987-9ddf-8830a739b455\" style=\"color:#555555;background-color:#fdd5f5;\">언제든 자사의 제품에 맞는 안정적인 인쇄물에 상담은 환영합니다. 편하게 문의하세요.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-talktalk se-l-default\" id=\"SE-53910440-e932-4d17-80ef-bd87a85f4fb8\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-talktalk se-section-align-center se-l-default\">\n<a class=\"se-module se-module-talktalk\" href=\"https://talk.naver.com/w4tbeb?frm=mblog&amp;ref=https%3A%2F%2Fm.blog.naver.com%2Fcookthedesign%2F223884130809#nafullscreen\" onclick=\"sendClickNlog('pst.talktalk', '');\">\n<span class=\"se-talktalk-banner-text\">\n<span class=\"se-blind\">궁금할 땐 네이버 톡톡하세요!</span>\n</span>\n</a>\n</div>\n</div>\n</div>"
