se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-99395208-fb7c-4711-8d5f-def86e78ac3b\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-78195961-ef06-4a45-a695-ace588974092\" style=\"color:#000000;\"><b>​</b></span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line2\" id=\"SE-41989fa4-ed25-44ef-91e5-98088df64a29\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line2 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-bc53b541-f9ce-45c7-a159-ce0be8b93122\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ed6e93fd-8a34-4ca9-b11b-9cf2f4d1bd93\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-d12cda9a-d903-418e-9197-2b25b71d5df3\" style=\"color:#000000;background-color:#ffffff;\"><b>메인페이지 기획</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a4f7ddd1-c4f0-4523-81b7-d8dc0871c7ac\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-a0e51352-f6c8-45d6-af56-c28044c24873\" style=\"color:#555555;background-color:#ffffff;\">메인페이지 부터 기획합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-ba3fb675-e1d9-46cd-86e4-76d954dd76a2\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-eabfeb5e-4c00-4061-9452-654dd5c2878d\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-08d48371-2985-4b3d-a157-d9b9521263bb\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-883c4307-dc6e-4149-b782-a78314a48a72\" style=\"color:#555555;background-color:#ffffff;\">참고로 요즘은 Figma나 기타 툴로 작업을 많이 합니다. 저는 파워포인트로 하겠습니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-0adcc61b-e46c-4447-afee-f2e783709ee9\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-91d8cc9a-1ff8-4bda-af3a-2799a05e9344\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-0dfba77a-0399-489d-b276-b2074249022d\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/222914751655/002.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-line5\" id=\"SE-d162990f-4712-4f62-a3ec-cf3e382743c1\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line5 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-9aca5aa7-ea94-478a-88a0-fdc61154f328\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-a0610e14-f207-4987-9c7a-993c16a191dd\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-4830f018-c128-4b8a-8d70-3f18b15764ae\" style=\"color:#000000;background-color:#ffffff;\"><b>마우스오버 기능</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d7f0808f-e6a4-4caa-9663-686de8ff2095\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-d83cc57b-d3cc-47e8-9209-797da6ed599f\" style=\"color:#555555;background-color:#ffffff;\">이미지에 마우스가 롤오버되면 이미지영역이 모달형태로 바뀌면서 공유과 찜 기능 아이콘이 생성됩니다. 공유버튼을 누르면 SNS아이콘으로 공유 방식을 선택하는 팝업이 뜨며 찜은 선택과 비선택으로 아이콘이 표시됩니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-2831d6dd-8482-44f2-9a59-c7c4c712b370\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/222914751655/003.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-horizontalLine se-l-line5\" id=\"SE-d24ea61b-3c5f-477a-a28d-c38cdc961f12\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line5 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-2990c878-a444-4ca1-ba4b-8c01ea984052\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e95e95b6-2302-4e15-a54b-827bfc695029\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-34d1652a-4a0b-4f42-81e7-7036e36ee15c\" style=\"color:#000000;background-color:#ffffff;\"><b>상세보기 버튼 기능</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-2edec312-7032-4f63-adf8-fb9aea32af6f\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-b933610d-f163-4e36-8774-60b918055fd0\" style=\"color:#555555;background-color:#ffffff;\">상세보기  · · · 버튼을 클릭하면 보여지는 팝업입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-4efbe646-7034-4719-a75b-78056bdfde46\">\n<div class=\"se-component-content se-component-content-normal\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:854px;\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/222914751655/004.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-d24f7ff9-e9eb-4df8-9c09-b74c7e5cdb4e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b15b212f-2987-408e-8a14-a8d99b76793a\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-bc23a84f-097a-4887-ad79-e730b7a69730\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-5c7fde73-ec74-462d-bdbc-b812d60ac6f1\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-2c53e026-180b-45d3-a37a-a9e068a127a7\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-4cdf4e0a-9907-4896-8795-82033a40b324\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-06f70ff5-be36-44c8-b093-094c3aa71b2a\" style=\"color:#555555;background-color:#ffffff;\"><b>디자인 템플릿명</b></span><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-4e3646c9-29f8-46e6-a85a-ccd812f6a2ff\" style=\"color:#555555;background-color:#ffffff;\"> : 등록시 입력한 디자인 템플릿명을 표시합니다. 이 명칭은 제한숫자 정도로 제한하여 등록하는것을 고려해 봅니다. 기업명이나 상품의 분류를 대부분 넣습니다. 예를들면 미래에셋 A4 3단 리플렛(중복 허용)</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-66b73aaa-99e0-4ed9-91b6-9e049952d485\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-154a2f17-1a7a-4031-9f1b-b3a8cd352055\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7207726d-e319-40dd-88d6-1ec220574996\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-e9a217aa-89b1-49c2-b4cc-529eb0d51ef6\" style=\"color:#555555;background-color:#ffffff;\"><b>태그</b></span><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-e6fe64da-da37-496c-b3b8-b4f11ee148d1\" style=\"color:#555555;background-color:#ffffff;\"> : 등록시 입력한 태그를 표시합니다. 두줄까지 표시되며 그 이상의 태그는 ...으로 표시됩니다. 이 태그에는 종이, 인쇄방법, 사이즈, 페이지, 후가공등의 정보나 검색에 필요한 필수인 그텐다드, 유니크의 검색 태그 키워드도 나열될 수 있습니다. 나열순서는 관리자페이지 진행시 고려합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-da681499-d077-49f1-8d9a-e7dad8fb6007\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-1a95c51a-f99e-42d7-b726-10602fafc90e\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-fbfe141d-7a61-4096-aab7-d4e7ccd415fb\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-be9b5f40-9dcd-4bcc-a971-1c2842630502\" style=\"color:#555555;background-color:#ffffff;\"><b>정보</b></span><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-9a721ca0-21de-4250-962b-21a7e277bb9a\" style=\"color:#555555;background-color:#ffffff;\"> : 이 템플릿을 등록한 날짜와 누구든 이 템플릿을 주문한 최근날짜를 표시합니다. 또한 찜을 한 갯수, 이 템플릿을 주문한 객수, 이 템플릿의 다운로드 수를 보여줍니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-806b3837-711f-4c7a-b091-fd26646d5dfd\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-8e4b9070-b758-4b39-bbf4-e0b3e6ba362b\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-be8873e5-ff04-4bd9-b480-89e1dd7d09e6\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-6296e91a-dc59-408b-b627-5e2a3c18ad3a\" style=\"color:#555555;background-color:#ffffff;\"><b>다운로드 버튼 </b></span><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-d1ee5b65-7f47-4e8a-b194-512e65869843\" style=\"color:#555555;background-color:#ffffff;\">: 다운로드는 목업입니다. 이미지형식의 png, jpg 파일입니다. 디자인이 된 ai, pdf 다운로드는 아닙니다. 인쇄용 PDF는 주문이 성사되었을 때의 기능입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-3d61ae19-3682-4fc5-b6ac-e23dfcccba59\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-56c3cc2b-038d-48bc-852f-e69e30bf2ca2\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-af2c3323-06cb-40e0-8bae-b087f5d8d458\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-14e1f82c-d275-4114-9238-6c54a2c2f6ab\" style=\"color:#555555;background-color:#ffffff;\"><b>주문하기 버튼 </b></span><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-2459ae8a-283d-4aef-bf55-51a7094a6f5b\" style=\"color:#555555;background-color:#ffffff;\">: 주문하기는 주문창으로 바로 넘어갑니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-b614599b-053c-41d2-9b5d-0a5f89117bf1\" style=\"\"><span class=\"se-fs-fs16 se-ff-nanumgothic se-weight-unset se-style-unset\" id=\"SE-83525a26-ac54-4748-b19c-b9b3e5af89df\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line5\" id=\"SE-8ab77f27-f10c-4fe1-aefb-fdee78a8d13e\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line5 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-82c4e098-0d7a-4299-b272-7ed1c68ac68d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d779939d-833e-47c5-86fb-52ad73c46b9c\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-812858ff-15ef-4266-84c8-edd4f99aad7d\" style=\"color:#555555;background-color:#ffffff;\">모바일 화면입니다.</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-image se-l-default\" id=\"SE-195a8a5f-bb29-433c-acac-2680b8d72a76\">\n<div class=\"se-component-content se-component-content-fit\">\n<div class=\"se-section se-section-image se-l-default se-section-align-\">\n<div class=\"se-module se-module-image\" style=\"\">\n<a class=\"se-module-image-link __se_image_link __se_link\" data-linktype=\"img\" href=\"#\" onclick=\"return false;\" style=\"\">\n<img alt=\"\" class=\"se-image-resource\" src=\"https://cdn.jsdelivr.net/gh/papascompany/Printguide@d608cd58b294f3de28c0892f4733cfb9fb9cec62/222914751655/005.png\"/>\n</a>\n</div>\n</div>\n</div>\n</div>\n<div class=\"se-component se-text se-l-default\" id=\"SE-c0d09597-fac0-4317-98b8-9b479fbc8d2d\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-d7c02aa6-af42-4201-b722-01b6eedc5e64\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-8b5c80ce-87bb-4839-8e96-97a13d7c8c9f\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-7a8992f2-9515-4782-b140-7eaea630e209\" style=\"\"><span class=\"se-fs-fs16 se-ff- se-weight-unset se-style-unset\" id=\"SE-2c769972-7bec-4b24-8594-21738edfa2ed\" style=\"color:#555555;\">​</span></p><!-- } SE-TEXT -->\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-horizontalLine se-l-line2\" id=\"SE-05c417f2-a6b1-4709-b753-ae63da58de01\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-horizontalLine se-l-line2 se-section-align-\">\n<div class=\"se-module se-module-horizontalLine\">\n<hr class=\"se-hr\"/>\n</div>\n</div>\n</div>\n</div> <div class=\"se-component se-text se-l-default\" id=\"SE-43cac43e-5519-473c-ab02-8b2a198cc286\">\n<div class=\"se-component-content\">\n<div class=\"se-section se-section-text se-l-default\">\n<div class=\"se-module se-module-text\">\n<!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-\" id=\"SE-e3ccec3b-8bf6-4312-a54d-59cf691f7c82\" style=\"\"><span class=\"se-fs-fs19 se-ff- se-style-unset\" id=\"SE-0e4298f7-00b0-4652-82fd-54669905b62b\" style=\"color:#000000;background-color:#ffffff;\"><b>상세보기에 관한 ppt화면입니다.</b></span></p><!-- } SE-TEXT --><!-- 